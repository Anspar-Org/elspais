{# Partial: _toolbar.html.j2 — Unified filter toolbar #}
{# Implements: REQ-p00006-A, REQ-p00006-B #}

<div class="toolbar" id="edit-toolbar">
    <!-- Left: Search spanning both rows -->
    <div class="toolbar-search">
        <textarea class="filter-text-input" id="edit-filter-text"
                  placeholder="Filter tree... (space=AND, OR, -exclude, =exact, &quot;phrase&quot;)"
                  oninput="onTreeTextFilter()" rows="2"
                  title="Filter the tree view"></textarea>
        <label class="toggle-inline">
            <input type="checkbox" id="toggle-show-parents" checked
                   onchange="toggleShowHiddenParents()">
            <span>Show hidden parents</span>
        </label>
    </div>

    <div class="toolbar-divider"></div>

    <!-- Right: Filter groups in two rows -->
    <div class="toolbar-filters">
        <div class="toolbar-row">
            <!-- Git group -->
            <div class="filter-group" data-group="git">
                <span class="filter-group-label">Git</span>
                <div class="filter-group-buttons">
                    <button class="filter-btn on" data-group="git" data-key="unsaved"
                            onclick="filterGroups.git.handleClick('unsaved', event)">Unsaved</button>
                    <button class="filter-btn on" data-group="git" data-key="uncommitted"
                            onclick="filterGroups.git.handleClick('uncommitted', event)">Uncommitted</button>
                    <button class="filter-btn on" data-group="git" data-key="changed"
                            onclick="filterGroups.git.handleClick('changed', event)">Changed</button>
                    <button class="filter-btn on" data-group="git" data-key="unchanged"
                            onclick="filterGroups.git.handleClick('unchanged', event)">Unchanged</button>
                </div>
            </div>

            <!-- Hierarchy group -->
            <div class="filter-group" data-group="hierarchy">
                <span class="filter-group-label">Hierarchy</span>
                <div class="filter-group-buttons">
                    <button class="filter-btn on" data-group="hierarchy" data-key="root"
                            onclick="filterGroups.hierarchy.handleClick('root', event)">Root</button>
                    <button class="filter-btn on" data-group="hierarchy" data-key="internal"
                            onclick="filterGroups.hierarchy.handleClick('internal', event)">Internal</button>
                    <button class="filter-btn on" data-group="hierarchy" data-key="leaf"
                            onclick="filterGroups.hierarchy.handleClick('leaf', event)">Leaf</button>
                </div>
            </div>

            <!-- Actions -->
            <div class="toolbar-actions">
                <button class="btn" onclick="clearAllFilters()" title="Clear all filters">Clear</button>
                <span class="counter" id="edit-counter" title=""></span>
            </div>
        </div>

        <div class="toolbar-row">
            <!-- Status group (buttons generated from sorted config) -->
            <div class="filter-group" data-group="status">
                <span class="filter-group-label">Status</span>
                <div class="filter-group-buttons" id="status-filter-buttons">
                    {% for status in statuses %}
                    <button class="filter-btn{% if status not in default_hidden_statuses %} on{% endif %}"
                            data-group="status" data-key="{{ status | lower }}"
                            onclick="filterGroups.status.handleClick('{{ status | lower }}', event)"
                            title="Toggle {{ status }} requirements">{{ status }}</button>
                    {% endfor %}
                </div>
            </div>

            <!-- Coverage group -->
            <div class="filter-group" data-group="coverage">
                <span class="filter-group-label">Coverage</span>
                <div class="filter-group-buttons">
                    <button class="filter-btn on" data-group="coverage" data-key="none"
                            onclick="filterGroups.coverage.handleClick('none', event)">None</button>
                    <button class="filter-btn on" data-group="coverage" data-key="partial"
                            onclick="filterGroups.coverage.handleClick('partial', event)">Partial</button>
                    <button class="filter-btn on" data-group="coverage" data-key="full"
                            onclick="filterGroups.coverage.handleClick('full', event)">Full</button>
                </div>
            </div>
        </div>
    </div>
</div>
