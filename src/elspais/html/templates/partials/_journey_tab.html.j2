{# Partial: _journey_tab.html.j2 — Journey cards with search/grouping + edit mode #}

<!-- User Journeys Tab Content -->
<div class="tab-content" id="content-journeys">
    <h2 class="section-title">User Journeys</h2>
    {% if journeys %}
    <div class="journey-toolbar">
        <div class="journey-search">
            <input type="text" id="journey-search" placeholder="Search journeys by ID, title, actor, or goal..." oninput="filterJourneys()">
        </div>
        <div class="journey-group-controls">
            <label for="journey-group-by">Group by:</label>
            <select id="journey-group-by" onchange="regroupJourneys()">
                <option value="none">None</option>
                <option value="descriptor">Descriptor</option>
                <option value="actor">Actor</option>
                <option value="file">File</option>
            </select>
        </div>
        <div class="journey-count">
            <span id="journey-visible-count">{{ journeys|length }}</span> of {{ journeys|length }} journeys
        </div>
        <button class="edit-only journey-add-btn" onclick="onAddJourney()">+ Add Journey</button>
    </div>
    <div class="journey-list" id="journey-list">
        {% for journey in journeys %}
        <div class="journey-card"
             data-journey-id="{{ journey.id }}"
             data-id="{{ journey.id|lower }}"
             data-title="{{ journey.title|lower }}"
             data-actor="{{ (journey.actor or '')|lower }}"
             data-goal="{{ (journey.goal or '')|lower }}"
             data-descriptor="{{ journey.descriptor|lower }}"
             data-file="{{ journey.file|lower }}"
             data-file-id="{{ journey.file_id }}"
             data-refs="{{ journey.referenced_reqs|join(',')|lower }}">
            <div class="journey-card-header">
                <span class="journey-id">{{ journey.id }}</span>
                {# View mode: plain title #}
                <h3 class="journey-title-view">{{ journey.title }}</h3>
                {# Edit mode: inline editable title #}
                <input type="text" class="edit-only journey-title-edit" value="{{ journey.title }}"
                       onblur="onJourneyTitleBlur('{{ journey.id }}', this)">
                <button class="edit-only journey-delete-btn" onclick="onDeleteJourney('{{ journey.id }}')"
                        title="Delete journey">&times;</button>
            </div>
            <div class="journey-meta">
                {% if journey.descriptor %}
                <div class="journey-meta-item">
                    <span class="journey-meta-label">Topic</span>
                    <span class="journey-meta-value">{{ journey.descriptor }}</span>
                </div>
                {% endif %}
                <div class="journey-meta-item">
                    <span class="journey-meta-label">Actor</span>
                    <span class="journey-meta-value journey-field-view">{{ journey.actor or '' }}</span>
                    <input type="text" class="edit-only journey-field-edit" value="{{ journey.actor or '' }}"
                           data-field="actor" data-journey-id="{{ journey.id }}"
                           onblur="onJourneyFieldBlur(this)">
                </div>
                <div class="journey-meta-item">
                    <span class="journey-meta-label">Goal</span>
                    <span class="journey-meta-value journey-field-view">{{ journey.goal or '' }}</span>
                    <input type="text" class="edit-only journey-field-edit" value="{{ journey.goal or '' }}"
                           data-field="goal" data-journey-id="{{ journey.id }}"
                           onblur="onJourneyFieldBlur(this)">
                </div>
                {% if journey.context %}
                <div class="journey-meta-item">
                    <span class="journey-meta-label">Context</span>
                    <span class="journey-meta-value journey-field-view">{{ journey.context }}</span>
                    <input type="text" class="edit-only journey-field-edit" value="{{ journey.context }}"
                           data-field="context" data-journey-id="{{ journey.id }}"
                           onblur="onJourneyFieldBlur(this)">
                </div>
                {% endif %}
                {% if journey.file %}
                <div class="journey-meta-item">
                    <span class="journey-meta-label">Source</span>
                    <span class="journey-meta-value journey-source-link" style="text-transform:none"
                          >{{ journey.file }}{% if journey.file_line %}:{{ journey.file_line }}{% endif %}</span>
                    <button class="edit-only journey-move-btn"
                            onclick="onMoveToFile('{{ journey.id }}')"
                            title="Move to another file">Move</button>
                </div>
                {% endif %}
            </div>
            {# Validates references #}
            <div class="journey-refs">
                <span class="journey-refs-label">Validates:</span>
                {% for req_id in journey.referenced_reqs %}
                <span class="journey-ref-badge" onclick="switchToReqTab('{{ req_id }}')">{{ req_id }}
                    <span class="edit-only journey-ref-delete" onclick="event.stopPropagation(); onDeleteJourneyRef('{{ journey.id }}', '{{ req_id }}')">&times;</span>
                </span>
                {% endfor %}
                <button class="edit-only journey-ref-add-btn"
                        onclick="onAddJourneyRef('{{ journey.id }}')">+ Add</button>
            </div>
            {# Preamble #}
            {% if journey.preamble %}
            <div class="journey-preamble">
                <div class="journey-preamble-view">{{ journey.preamble }}</div>
                <textarea class="edit-only journey-preamble-edit"
                          data-journey-id="{{ journey.id }}"
                          onblur="onJourneyPreambleBlur(this)">{{ journey.preamble }}</textarea>
            </div>
            {% endif %}
            {# Sections #}
            <div class="journey-sections" data-journey-id="{{ journey.id }}">
                {% for section in journey.sections %}
                <div class="journey-section" data-section-name="{{ section.name }}">
                    <div class="journey-section-header">
                        <span class="journey-section-name journey-section-name-view">{{ section.name }}</span>
                        <input type="text" class="edit-only journey-section-name-edit" value="{{ section.name }}"
                               data-journey-id="{{ journey.id }}" data-original-name="{{ section.name }}"
                               onblur="onJourneySectionNameBlur(this)">
                        <button class="edit-only journey-section-delete"
                                onclick="onDeleteJourneySection('{{ journey.id }}', '{{ section.name }}')"
                                title="Delete section">&times;</button>
                    </div>
                    <div class="journey-section-content journey-section-content-view">{{ section.content }}</div>
                    <textarea class="edit-only journey-section-content-edit"
                              data-journey-id="{{ journey.id }}" data-section-name="{{ section.name }}"
                              onblur="onJourneySectionContentBlur(this)">{{ section.content }}</textarea>
                </div>
                {% endfor %}
                <button class="edit-only journey-section-add-btn"
                        onclick="onAddJourneySection('{{ journey.id }}')">+ Add Section</button>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <div class="no-journeys">
        <p>No user journeys found in specification files.</p>
        <p style="font-size: 0.875rem; margin-top: 8px;">User journeys are defined with <code>## JNY-xxx: Title</code> headers in spec files.</p>
        <p style="font-size: 0.8rem; margin-top: 12px; color: #868e96;">
            Example format:<br>
            <code style="display: block; margin-top: 8px; padding: 12px; background: #f1f3f5; border-radius: 4px; text-align: left;">
## JNY-LOGIN-01: User Login<br>
**Actor**: End User<br>
**Goal**: Access the system securely<br><br>
Steps...<br><br>
*End* *JNY-LOGIN-01*
            </code>
        </p>
        <button class="edit-only journey-add-btn" onclick="onAddJourney()" style="margin-top:12px">+ Add Journey</button>
    </div>
    {% endif %}
</div>
