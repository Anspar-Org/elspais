// Partial: _cookie-persistence.js.j2 — Unified state save/load (both modes)
// Implements: REQ-p00006-A
// Single cookie shared between edit and view modes for seamless state transfer

const COOKIE_NAME = 'elspais_trace_state';
const COOKIE_DAYS = 30;
const COOKIE_VERSION = 15;  // v15: viewMode (flat/tree) toggle, removed coverageMode

function saveState() {
    // Serialize filter groups
    var filterState = {};
    if (typeof filterGroups !== 'undefined') {
        for (var gname in filterGroups) {
            filterState[gname] = filterGroups[gname].serialize();
        }
    }
    var showParentsCb = document.getElementById('toggle-show-parents');
    filterState.showHiddenParents = showParentsCb ? showParentsCb.checked : true;

    const stateToSave = {
        _v: COOKIE_VERSION,
        editEnabled: editState.enabled,
        openCardIds: editState.openCardOrder,
        activeNavTab: editState.activeNavTab,
        collapsedTreeNodes: Array.from(editState.collapsedTreeNodes),
        collapsedCards: [],
        filterState: filterState,
        fontSize: editState.fontSize,
        theme: editState.theme,
        toolbarHidden: editState.toolbarHidden,
        cardViewMode: editState.cardViewMode,
        assertionBadgeMode: editState.assertionBadgeMode,
        viewMode: editState.viewMode || 'tree',
        navPanelWidth: document.getElementById('nav-panel').style.width || null,
        fileViewerWidth: document.getElementById('file-viewer-panel').style.width || null
    };
    // Track which cards are collapsed (card body and refs section)
    stateToSave.refsCollapsedCards = [];
    editState.openCards.forEach(function(info, id) {
        if (info.collapsed) stateToSave.collapsedCards.push(id);
        if (info.refsCollapsed) stateToSave.refsCollapsedCards.push(id);
    });
    // Persist filterText
    if (editState.filterText) stateToSave.filterText = editState.filterText;
    var expires = new Date(Date.now() + COOKIE_DAYS * 864e5).toUTCString();
    document.cookie = COOKIE_NAME + '=' + encodeURIComponent(JSON.stringify(stateToSave)) +
        '; expires=' + expires + '; path=/; SameSite=Lax';
}

function loadState() {
    var match = document.cookie.match(new RegExp('(^| )' + COOKIE_NAME + '=([^;]+)'));
    if (!match) return null;
    try {
        var saved = JSON.parse(decodeURIComponent(match[2]));
        if (!saved._v || saved._v < COOKIE_VERSION) return null;  // discard stale cookie
        return saved;
    } catch (e) {
        return null;
    }
}

function clearState() {
    document.cookie = COOKIE_NAME + '=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/; SameSite=Lax';
}
