// Partial: _nav-tree.js.j2 — Nav tree rendering, tabs, header stats, FilterGroup integration

// =====================================================================
// FilterGroup Instances
// =====================================================================

var filterGroups = {};

filterGroups.git = new FilterGroup({
    name: 'git',
    container: document.getElementById('edit-toolbar'),
    buttons: [
        {key: 'unsaved', label: 'Unsaved'},
        {key: 'uncommitted', label: 'Uncommitted'},
        {key: 'changed', label: 'Changed'},
        {key: 'unchanged', label: 'Unchanged'},
    ],
    defaultOn: new Set(['unsaved', 'uncommitted', 'changed', 'unchanged']),
    sensitiveEvents: new Set(['save', 'commit', 'refresh', 'branch-change']),
    countFn: function(key, rows) {
        var count = 0;
        for (var i = 0; i < rows.length; i++) {
            var r = rows[i];
            if (key === 'unsaved' && r.is_unsaved) count++;
            else if (key === 'uncommitted' && r.is_uncommitted) count++;
            else if (key === 'changed' && r.is_changed) count++;
            else if (key === 'unchanged' && !r.is_unsaved && !r.is_uncommitted && !r.is_changed) count++;
        }
        return count;
    },
    matchFn: function(row) {
        var keys = new Set();
        if (row.is_unsaved) keys.add('unsaved');
        if (row.is_uncommitted) keys.add('uncommitted');
        if (row.is_changed) keys.add('changed');
        if (!row.is_unsaved && !row.is_uncommitted && !row.is_changed) keys.add('unchanged');
        return keys;
    },
    onChange: function() { renderNavTree(); saveState(); },
});

filterGroups.hierarchy = new FilterGroup({
    name: 'hierarchy',
    container: document.getElementById('edit-toolbar'),
    buttons: [
        {key: 'root', label: 'Root'},
        {key: 'internal', label: 'Internal'},
        {key: 'leaf', label: 'Leaf'},
    ],
    defaultOn: new Set(['root', 'internal', 'leaf']),
    sensitiveEvents: new Set(['mutation-structure', 'refresh']),
    countFn: function(key, rows) {
        var count = 0;
        for (var i = 0; i < rows.length; i++) {
            var r = rows[i];
            if (key === 'root' && r.depth === 0) count++;
            else if (key === 'leaf' && r.is_leaf) count++;
            else if (key === 'internal' && r.depth > 0 && !r.is_leaf) count++;
        }
        return count;
    },
    matchFn: function(row) {
        if (row.depth === 0) return 'root';
        if (row.is_leaf) return 'leaf';
        return 'internal';
    },
    onChange: function() { renderNavTree(); saveState(); },
});

filterGroups.status = new FilterGroup({
    name: 'status',
    container: document.getElementById('status-filter-buttons'),
    buttons: [
        {% for status in statuses %}
        {key: '{{ status | lower }}', label: '{{ status }}'},
        {% endfor %}
    ],
    defaultOn: new Set([
        {% for status in statuses %}
        {% if status not in default_hidden_statuses %}'{{ status | lower }}',{% endif %}
        {% endfor %}
    ]),
    sensitiveEvents: new Set(['mutation-status', 'refresh']),
    countFn: function(key, rows) {
        var count = 0;
        for (var i = 0; i < rows.length; i++) {
            if ((rows[i].status || '').toLowerCase() === key) count++;
        }
        return count;
    },
    matchFn: function(row) { return (row.status || '').toLowerCase(); },
    onChange: function() { renderNavTree(); saveState(); },
});

filterGroups.coverage = new FilterGroup({
    name: 'coverage',
    container: document.getElementById('edit-toolbar'),
    buttons: [
        {key: 'none', label: 'None'},
        {key: 'partial', label: 'Partial'},
        {key: 'full', label: 'Full'},
    ],
    defaultOn: new Set(['none', 'partial', 'full']),
    sensitiveEvents: new Set(['mutation-edge', 'refresh']),
    countFn: function(key, rows) {
        var count = 0;
        for (var i = 0; i < rows.length; i++) {
            if ((rows[i].coverage || 'none') === key) count++;
        }
        return count;
    },
    matchFn: function(row) { return row.coverage || 'none'; },
    onChange: function() { renderNavTree(); saveState(); },
});

// =====================================================================
// Smart Recompute
// =====================================================================

function onFilterEvent(eventType) {
    for (var gname in filterGroups) {
        if (filterGroups[gname].sensitiveEvents.has(eventType)) {
            filterGroups[gname].recompute(editState.treeData || []);
        }
    }
    updateCounterTooltip();
}

function updateCounterTooltip() {
    var lines = [];
    for (var gname in filterGroups) {
        var hidden = filterGroups[gname].hiddenSummary(editState.treeData || []);
        for (var i = 0; i < hidden.length; i++) {
            lines.push(hidden[i].label + ': ' + hidden[i].count);
        }
    }
    var el = document.getElementById('edit-counter');
    if (el) el.title = lines.join('\n') || 'No filters active';
}

// =====================================================================
// Show Hidden Parents Toggle
// =====================================================================

function toggleShowHiddenParents() {
    renderNavTree();
    saveState();
}

// =====================================================================
// Header Stats
// =====================================================================

function updateHeaderStats() {
    // Compute level + main counts from tree data (unique IDs)
    // Test/result counts come from /api/status (not in tree data)
    var rows = editState.treeData;
    if (!rows || rows.length === 0) return;
    var seen = {};
    var counts = { {% for t in config_types | default([{"name":"prd"},{"name":"ops"},{"name":"dev"}]) %}{{ t.name }}: 0, {% endfor %}main: 0};
    var repoCounts = {};  // { "CAL": 3, "TTN": 2 }
    for (var i = 0; i < rows.length; i++) {
        var r = rows[i];
        if (seen[r.id]) continue;
        seen[r.id] = true;
        if (r.level) {
            var lev = r.level.toLowerCase();
            if (counts[lev] !== undefined) counts[lev]++;
            if (!r.is_associated) counts.main++;
            // Track associated repo prefixes
            if (r.is_associated && r.repo_prefix && r.repo_prefix !== 'CORE') {
                repoCounts[r.repo_prefix] = (repoCounts[r.repo_prefix] || 0) + 1;
            }
        }
    }
    document.getElementById('stat-prd').textContent = 'PRD: ' + counts.prd;
    document.getElementById('stat-ops').textContent = 'OPS: ' + counts.ops;
    document.getElementById('stat-dev').textContent = 'DEV: ' + counts.dev;
    document.getElementById('stat-main').textContent = 'Core: ' + counts.main;

    // Initialize level FilterGroup (in header)
    if (!filterGroups.level) {
        filterGroups.level = new FilterGroup({
            name: 'level',
            container: document.getElementById('header-stats'),
            buttons: [
                {key: 'prd', label: 'PRD'},
                {key: 'ops', label: 'OPS'},
                {key: 'dev', label: 'DEV'},
            ],
            defaultOn: new Set(['prd', 'ops', 'dev']),
            sensitiveEvents: new Set(['refresh']),
            countFn: function(key, rows) {
                var count = 0;
                for (var i = 0; i < rows.length; i++) {
                    if (rows[i].level === key.toUpperCase()) count++;
                }
                return count;
            },
            matchFn: function(row) { return (row.level || '').toLowerCase(); },
            onChange: function() { renderNavTree(); saveState(); },
        });
    }
    filterGroups.level.recompute(rows);

    // Fetch test/result counts from /api/status (informational badges)
    apiFetch('/api/status').then(function(data) {
        if (!data) return;
        var nc = data.node_counts || {};
        var testCount = nc.test || 0;
        var resultCount = nc.test_result || 0;
        var testBadge = document.getElementById('stat-tests');
        var resultBadge = document.getElementById('stat-results');
        if (testCount > 0) {
            testBadge.textContent = 'Tests: ' + testCount;
            testBadge.style.display = '';
        } else {
            testBadge.style.display = 'none';
        }
        if (resultCount > 0) {
            resultBadge.textContent = 'Results: ' + resultCount;
            resultBadge.style.display = '';
        } else {
            resultBadge.style.display = 'none';
        }

        var assocRepos = data.associated_repos || [];
        // Build name lookup from API: { "CAL": "callisto", ... }
        var nameMap = {};
        for (var j = 0; j < assocRepos.length; j++) {
            nameMap[assocRepos[j].code] = assocRepos[j].name;
        }
        var container = document.getElementById('repo-badges-container');
        var sep = document.getElementById('repo-sep');
        if (!container) return;
        container.innerHTML = '';
        var repoPrefixes = Object.keys(repoCounts).sort();
        editState.knownRepos = repoPrefixes;
        if (repoPrefixes.length === 0) {
            if (sep) sep.style.display = 'none';
            // Initialize empty repo group
            if (!filterGroups.repo) {
                filterGroups.repo = new FilterGroup({
                    name: 'repo',
                    container: container,
                    buttons: [],
                    defaultOn: new Set(),
                    sensitiveEvents: new Set(['refresh']),
                    countFn: function() { return 0; },
                    matchFn: function() { return 'main'; },
                    onChange: function() { renderNavTree(); saveState(); },
                });
            }
            return;
        }
        if (sep) sep.style.display = '';
        for (var k = 0; k < repoPrefixes.length; k++) {
            var code = repoPrefixes[k];
            var fullName = nameMap[code];
            var displayName = fullName ? fullName.charAt(0).toUpperCase() + fullName.slice(1) : code;
            var count = repoCounts[code];
            var badge = document.createElement('span');
            badge.className = 'stat-badge repo filter-btn on';
            badge.id = 'stat-repo-' + code;
            badge.title = 'Click to toggle ' + displayName + ' requirements (Shift+click to solo)';
            badge.textContent = displayName + ': ' + count;
            badge.setAttribute('data-group', 'repo');
            badge.setAttribute('data-key', code.toLowerCase());
            badge.setAttribute('data-repo', code);
            badge.onclick = (function(repoCode) {
                return function(event) {
                    if (filterGroups.repo) filterGroups.repo.handleClick(repoCode.toLowerCase(), event);
                };
            })(code);
            container.appendChild(badge);
        }

        // Initialize or recreate repo FilterGroup
        filterGroups.repo = new FilterGroup({
            name: 'repo',
            container: container,
            buttons: repoPrefixes.map(function(code) {
                return {key: code.toLowerCase(), label: code};
            }),
            defaultOn: new Set(repoPrefixes.map(function(c) { return c.toLowerCase(); })),
            sensitiveEvents: new Set(['refresh']),
            countFn: function(key, rows) {
                var count = 0;
                for (var i = 0; i < rows.length; i++) {
                    if ((rows[i].repo_prefix || '').toLowerCase() === key) count++;
                }
                return count;
            },
            matchFn: function(row) { return (row.repo_prefix || 'main').toLowerCase(); },
            onChange: function() { renderNavTree(); saveState(); },
        });
        filterGroups.repo.recompute(rows);
    });
}

async function refreshDirtyCount() {
    const data = await apiFetch('/api/dirty');
    if (!data) return;
    editState.mutationCount = data.mutation_count || 0;
    const badge = document.getElementById('unsaved-badge');
    const btnSave = document.getElementById('btn-save');
    const btnUndo = document.getElementById('btn-undo');
    if (editState.mutationCount > 0) {
        badge.textContent = editState.mutationCount;
        badge.classList.remove('hidden');
        btnSave.disabled = false;
        btnUndo.disabled = false;
    } else {
        badge.classList.add('hidden');
        btnSave.disabled = true;
        btnUndo.disabled = true;
    }
}

// =====================================================================
// Nav Tree
// =====================================================================

async function loadTreeData() {
    const data = await apiFetch('/api/tree-data');
    if (!data) return;
    editState.treeData = data;
    updateHeaderStats();
    onFilterEvent('refresh');
    renderNavTree();
}

function renderNavTree() {
    const container = document.getElementById('nav-tree-container');
    const activeTab = editState.activeNavTab;
    const rows = editState.treeData;

    // Capture focused element's scroll offset before re-render
    var focusOffsetFromTop = null;
    if (editState.focusNodeId) {
        var focusEl = container.querySelector('[data-id="' + editState.focusNodeId + '"]');
        if (focusEl) {
            focusOffsetFromTop = focusEl.getBoundingClientRect().top - container.getBoundingClientRect().top;
        }
    }

    if (!rows || rows.length === 0) {
        container.innerHTML = '<div style="padding:20px;color:#adb5bd;text-align:center;font-size:0.85rem;">No items found</div>';
        return;
    }

    // Filter by tab — req tab shows requirements only
    let filteredRows;
    if (activeTab === 'req') {
        filteredRows = rows.filter(function(r) {
            return r.level && r.level !== '';
        });
    } else {
        filteredRows = rows;
    }

    if (activeTab === 'journey') {
        var journeys = rows.filter(function(r) { return r.kind === 'journey'; });
        if (journeys.length === 0) {
            container.innerHTML = '<div style="padding:20px;color:#adb5bd;text-align:center;font-size:0.85rem;">No journey data available.</div>';
            return;
        }
        var jhtml = '';
        for (var ji = 0; ji < journeys.length; ji++) {
            var j = journeys[ji];
            var jSelected = editState.openCards.has(j.id) ? ' selected' : '';
            jhtml += '<div class="nav-tree-row nav-tree-journey' + jSelected + '" ' +
                'data-id="' + j.id + '" data-kind="journey" ' +
                'onclick="openCard(\'' + j.id + '\')">' +
                '<span class="nav-tree-kind-icon">&#x1F9ED;</span>' +
                '<span class="nav-tree-id" style="color:#6c757d;">' + escapeHtml(j.id) + '</span>' +
                '<span class="nav-tree-title">' + escapeHtml(j.title) + '</span>' +
                '</div>';
        }
        container.innerHTML = jhtml;
        return;
    }

    if (activeTab !== 'req' && activeTab !== 'journey') {
        container.innerHTML = '<div style="padding:20px;color:#adb5bd;text-align:center;font-size:0.85rem;">Select a tab to view content.</div>';
        return;
    }

    // Text filter flag (shared by flat and tree modes)
    var hasTextFilter = editState.textMatchIds !== null;

    // ── FLAT MODE ──────────────────────────────────────────────────────────
    if (editState.viewMode === 'flat' && activeTab === 'req') {
        var flatRows = filteredRows.slice();

        // Apply all FilterGroup filters
        var flatFiltered = [];
        for (var fi = 0; fi < flatRows.length; fi++) {
            var fr = flatRows[fi];
            var fmatch = true;
            for (var fgname in filterGroups) {
                if (!filterGroups[fgname].matches(fr)) { fmatch = false; break; }
            }
            if (fmatch && hasTextFilter && !editState.textMatchIds.has(fr.id)) fmatch = false;
            if (fmatch) flatFiltered.push(fr);
        }

        // Sort by ID
        flatFiltered.sort(function(a, b) {
            return (a.id || '').localeCompare(b.id || '');
        });

        // Update counter
        var flatCounterEl = document.getElementById('edit-counter');
        if (flatCounterEl) {
            var hasAnyFilter = hasTextFilter;
            if (!hasAnyFilter) {
                for (var fgn in filterGroups) {
                    var ffg = filterGroups[fgn];
                    for (var fbi = 0; fbi < ffg.buttons.length; fbi++) {
                        if (!ffg._on.has(ffg.buttons[fbi].key) && (ffg._available.get(ffg.buttons[fbi].key) || 0) > 0) {
                            hasAnyFilter = true; break;
                        }
                    }
                    if (hasAnyFilter) break;
                }
            }
            flatCounterEl.textContent = hasAnyFilter ? (flatFiltered.length + ' / ' + filteredRows.length) : '';
        }
        updateCounterTooltip();

        if (flatFiltered.length === 0) {
            container.innerHTML = '<div style="padding:20px;color:#adb5bd;text-align:center;font-size:0.85rem;">No matching requirements</div>';
            return;
        }

        var flatHtml = '';
        for (var fli = 0; fli < flatFiltered.length; fli++) {
            var flrow = flatFiltered[fli];
            var flSelected = editState.openCards.has(flrow.id) ? ' selected' : '';
            var fllevelClass = flrow.level ? flrow.level.toLowerCase() : '';
            var flshortId = flrow.id.replace('REQ-', '');
            var flvalColor = flrow.validation_color || '';
            var flvalTip = flrow.validation_tip || '';
            var flvalClass = flvalColor ? ' val-' + flvalColor : '';
            var fltipAttr = flvalTip ? ' data-tip="' + escapeHtml(flvalTip) + '"' : '';
            var flstatusBadge = flrow.status
                ? '<span class="status-badge ' + flrow.status.toLowerCase() + flvalClass + '"' + fltipAttr + '>' + flrow.status + '</span>'
                : '';
            flatHtml += '<div class="nav-tree-row' + flSelected + '" ' +
                'data-id="' + flrow.id + '" ' +
                'data-kind="requirement" ' +
                'onclick="openCard(\'' + flrow.id + '\')">' +
                '<button class="nav-tree-toggle leaf" onclick="event.stopPropagation();"></button>' +
                (fllevelClass ? '<span class="nav-tree-level ' + fllevelClass + '">' + flrow.level + '</span>' : '') +
                '<span class="nav-tree-id">' + flshortId + '</span>' +
                '<span class="nav-tree-title">' + escapeHtml(flrow.title || '') + '</span>' +
                flstatusBadge +
                '</div>';
        }
        container.innerHTML = flatHtml;
        return;
    }
    // ── END FLAT MODE ──────────────────────────────────────────────────────

    // Apply filters via FilterGroup
    const totalBeforeFilter = filteredRows.length;

    // Determine if any filter is actually narrowing the result set
    var hasActiveFilter = hasTextFilter;
    for (var gname in filterGroups) {
        var fg = filterGroups[gname];
        // A group is actively filtering if not all available keys are on
        for (var bi = 0; bi < fg.buttons.length; bi++) {
            if (!fg._on.has(fg.buttons[bi].key) && (fg._available.get(fg.buttons[bi].key) || 0) > 0) {
                hasActiveFilter = true;
                break;
            }
        }
        if (hasActiveFilter) break;
    }

    // Track which rows are direct filter matches (vs ancestor context)
    var matchSet = null;
    var directMatchCount = 0;

    if (hasActiveFilter) {
        // Build parent-index map
        var parentIdx = new Array(filteredRows.length);
        for (var i = 0; i < filteredRows.length; i++) {
            parentIdx[i] = -1;
            if (filteredRows[i].parent_id) {
                for (var j = i - 1; j >= 0; j--) {
                    if (filteredRows[j].id === filteredRows[i].parent_id) {
                        parentIdx[i] = j;
                        break;
                    }
                }
            }
        }
        // First pass: mark row indices that directly match all filters
        var matchIndices = new Set();
        for (var i = 0; i < filteredRows.length; i++) {
            var r = filteredRows[i];
            var match = true;

            // Check all filter groups (AND between groups)
            for (var gname in filterGroups) {
                if (!filterGroups[gname].matches(r)) { match = false; break; }
            }

            // Text filter (intersect with search API results)
            if (match && hasTextFilter && !editState.textMatchIds.has(r.id)) match = false;

            if (match) matchIndices.add(i);
        }
        directMatchCount = matchIndices.size;

        // Second pass: include ancestors of matching rows to preserve tree structure
        var showParents = true;
        var showParentsCb = document.getElementById('toggle-show-parents');
        if (showParentsCb) showParents = showParentsCb.checked;

        if (showParents) {
            var allVisible = new Set(matchIndices);
            for (var i = 0; i < filteredRows.length; i++) {
                if (matchIndices.has(i)) {
                    var pi = parentIdx[i];
                    while (pi >= 0) {
                        if (allVisible.has(pi)) break;
                        allVisible.add(pi);
                        pi = parentIdx[pi];
                    }
                }
            }
            // Build matchSet for dimming context-only rows
            matchSet = new Set();
            var finalIdx = 0;
            for (var i = 0; i < filteredRows.length; i++) {
                if (allVisible.has(i)) {
                    if (matchIndices.has(i)) matchSet.add(finalIdx);
                    finalIdx++;
                }
            }
            filteredRows = filteredRows.filter(function(r, idx) { return allVisible.has(idx); });
        } else {
            // No parent inclusion — only show direct matches
            matchSet = null;
            filteredRows = filteredRows.filter(function(r, idx) { return matchIndices.has(idx); });
        }
    }

    // Update counter
    var counterEl = document.getElementById('edit-counter');
    if (counterEl) {
        if (hasActiveFilter) {
            counterEl.textContent = directMatchCount + ' / ' + totalBeforeFilter;
        } else {
            counterEl.textContent = '';
        }
    }
    updateCounterTooltip();

    if (hasActiveFilter && directMatchCount === 0) {
        container.innerHTML = '<div style="padding:20px;color:#adb5bd;text-align:center;font-size:0.85rem;">No matching requirements</div>';
        return;
    }

    // Pre-compute which rows have visible children in the filtered set.
    var rowsWithVisibleChildren = new Set();
    for (var vi = 0; vi < filteredRows.length; vi++) {
        if (filteredRows[vi].parent_id) {
            for (var vj = vi - 1; vj >= 0; vj--) {
                if (filteredRows[vj].id === filteredRows[vi].parent_id &&
                    filteredRows[vj].depth === filteredRows[vi].depth - 1) {
                    rowsWithVisibleChildren.add(vj);
                    break;
                }
            }
        }
    }

    // Propagate comment indicators upward
    for (var ci = filteredRows.length - 1; ci >= 0; ci--) {
        var crow = filteredRows[ci];
        var crowHasComments = crow.has_comments || crow._has_child_comments;
        if (!crowHasComments) continue;
        if (crow.depth > 0 && isAncestorCollapsed(crow, filteredRows, matchSet, ci)) {
            for (var pi = ci - 1; pi >= 0; pi--) {
                if (filteredRows[pi].depth < crow.depth) {
                    filteredRows[pi]._has_child_comments = true;
                    if (!isAncestorCollapsed(filteredRows[pi], filteredRows, matchSet, pi)) {
                        break;
                    }
                }
            }
        }
    }

    let html = '';
    filteredRows.forEach(function(row, arrIdx) {
        // Determine if collapsed
        const isCollapsed = editState.collapsedTreeNodes.has(row.id);
        // Check if parent is collapsed (skip rendering)
        if (row.depth > 0 && isAncestorCollapsed(row, filteredRows, matchSet, arrIdx)) {
            return; // don't render
        }

        const indents = [];
        for (let i = 0; i < row.depth; i++) {
            indents.push('<span class="nav-tree-indent"></span>');
        }

        const visibleChildren = rowsWithVisibleChildren.has(arrIdx);
        const toggleClass = visibleChildren
            ? (isCollapsed ? 'nav-tree-toggle' : 'nav-tree-toggle')
            : 'nav-tree-toggle leaf';
        const toggleIcon = visibleChildren
            ? (isCollapsed ? '&#9654;' : '&#9660;')
            : '';

        const selectedClass = editState.openCards.has(row.id) ? ' selected' : '';
        // Dim context-only rows when filters are active
        const dimClass = (matchSet && !matchSet.has(arrIdx)) ? ' filter-dim' : '';

        // ── REQUIREMENT row rendering ──
        const levelClass = row.level ? row.level.toLowerCase() : '';
        const shortId = row.id.replace('REQ-', '');

        // Status badge — color driven by combined (all) coverage
        var statusBadge = '';
        if (row.status) {
            var statusLower = row.status.toLowerCase();
            var valColor = row.validation_color || '';
            var valTip = row.validation_tip || '';
            var valClass = valColor ? ' val-' + valColor : '';
            var tipAttr = valTip ? ' data-tip="' + escapeHtml(valTip) + '"' : '';
            statusBadge = '<span class="status-badge ' + statusLower + valClass + '"' + tipAttr + '>' + row.status + '</span>';
        }

        // Status indicators
        var indicators = '';
        indicators += '<span class="nav-tree-indicator' + (row.has_comments ? ' nav-tree-comment-icon direct' : (row._has_child_comments ? ' nav-tree-comment-icon inherited' : '')) + '"' +
            (row.has_comments ? ' title="Has comments"' : (row._has_child_comments ? ' title="Child has comments"' : '')) +
            '>' + (row.has_comments || row._has_child_comments ? '&#x1F5E9;' : '') + '</span>';
        indicators += '<span class="nav-tree-indicator' + (row.is_unsaved ? ' unsaved' : '') + '"' +
            (row.is_unsaved ? ' title="Unsaved in-memory edit"' : '') +
            '>' + (row.is_unsaved ? '&#x25CF;' : '') + '</span>';
        indicators += '<span class="nav-tree-indicator' + (row.is_uncommitted ? ' uncommitted' : '') + '"' +
            (row.is_uncommitted ? ' title="Saved but not committed"' : '') +
            '>' + (row.is_uncommitted ? '&#x25C6;' : '') + '</span>';
        indicators += '<span class="nav-tree-indicator' + (row.is_changed ? ' changed' : '') + '"' +
            (row.is_changed ? ' title="Changed on this branch vs main"' : '') +
            '>' + (row.is_changed ? '&#x25C6;' : '') + '</span>';

        html += '<div class="nav-tree-row' + selectedClass + dimClass + '" ' +
            'data-id="' + row.id + '" ' +
            'data-parent="' + (row.parent_id || '') + '" ' +
            'data-depth="' + row.depth + '" ' +
            'data-kind="requirement" ' +
            'onclick="openCard(\'' + row.id + '\')">' +
            indents.join('') +
            '<button class="' + toggleClass + '" onclick="event.stopPropagation(); toggleTreeNode(\'' + row.id + '\')">' +
            toggleIcon + '</button>' +
            (levelClass ? '<span class="nav-tree-level ' + levelClass + '">' + row.level + '</span>' : '') +
            '<span class="nav-tree-id">' + shortId + '</span>' +
            '<span class="nav-tree-title">' + escapeHtml(row.title || '') + '</span>' +
            '<span class="nav-tree-indicators">' + indicators + '</span>' +
            statusBadge +
            '</div>';
    });

    container.innerHTML = html;

    // Restore scroll position so the focused item stays in place
    if (focusOffsetFromTop !== null && editState.focusNodeId) {
        var newFocusEl = container.querySelector('[data-id="' + editState.focusNodeId + '"]');
        if (newFocusEl) {
            var newTop = newFocusEl.getBoundingClientRect().top - container.getBoundingClientRect().top;
            container.scrollTop += (newTop - focusOffsetFromTop);
        }
    }
}

function isAncestorCollapsed(row, allRows, matchSet, rowIdx) {
    if (!row.parent_id) return false;
    var parentId = row.parent_id;
    var searchFrom = (rowIdx !== undefined) ? rowIdx : allRows.length;
    var expectedDepth = row.depth - 1;
    while (parentId) {
        var pIdx = -1;
        for (var i = searchFrom - 1; i >= 0; i--) {
            if (allRows[i].id === parentId && allRows[i].depth === expectedDepth) {
                pIdx = i;
                break;
            }
        }
        if (pIdx < 0) break;
        if (editState.collapsedTreeNodes.has(parentId)) {
            if (matchSet && !matchSet.has(pIdx)) {
                searchFrom = pIdx;
                parentId = allRows[pIdx].parent_id;
                expectedDepth--;
                continue;
            }
            return true;
        }
        searchFrom = pIdx;
        parentId = allRows[pIdx].parent_id;
        expectedDepth--;
    }
    return false;
}

function toggleTreeNode(nodeId) {
    editState.focusNodeId = nodeId;
    if (editState.collapsedTreeNodes.has(nodeId)) {
        editState.collapsedTreeNodes.delete(nodeId);
    } else {
        editState.collapsedTreeNodes.add(nodeId);
    }
    renderNavTree();
    saveState();
}

function switchNavTab(kind) {
    editState.activeNavTab = kind;
    document.querySelectorAll('.nav-tab').forEach(function(tab) {
        tab.classList.toggle('active', tab.dataset.kind === kind);
    });
    renderNavTree();
    saveState();
}

// =====================================================================
// Tree Text Filter (calls /api/search)
// =====================================================================

var _treeTextTimer = null;

function onTreeTextFilter() {
    var input = document.getElementById('edit-filter-text');
    var text = input ? input.value.trim() : '';
    editState.filterText = text;

    if (_treeTextTimer) clearTimeout(_treeTextTimer);

    if (!text) {
        editState.textMatchIds = null;
        renderNavTree();
        saveState();
        return;
    }

    _treeTextTimer = setTimeout(function() {
        apiFetch('/api/search?q=' + encodeURIComponent(text) + '&limit=500')
            .then(function(data) {
                var items = data ? (data.results || []) : [];
                if (items.length === 0) {
                    editState.textMatchIds = new Set();
                } else {
                    var ids = new Set();
                    for (var i = 0; i < items.length; i++) {
                        ids.add(items[i].id);
                    }
                    editState.textMatchIds = ids;
                }
                renderNavTree();
                saveState();
            });
    }, 250);
}

// =====================================================================
// Clear All Filters
// =====================================================================

function clearAllFilters() {
    for (var gname in filterGroups) {
        filterGroups[gname].reset();
    }
    editState.filterText = '';
    editState.textMatchIds = null;
    var textInput = document.getElementById('edit-filter-text');
    if (textInput) textInput.value = '';
    var showParentsCb = document.getElementById('toggle-show-parents');
    if (showParentsCb) showParentsCb.checked = true;
    // Re-activate filter toggle button
    var ftb = document.getElementById('filter-toggle-btn');
    if (ftb && !editState.toolbarHidden) ftb.classList.add('active');
    // Reset header stat badge states
    document.querySelectorAll('.stat-badge').forEach(function(b) {
        b.classList.remove('dimmed');
    });
    renderNavTree();
    saveState();
}

// =====================================================================
// Collapse / Expand All
// =====================================================================

function collapseAllTreeNodes() {
    var rows = editState.treeData;
    if (!rows) return;
    for (var i = 0; i < rows.length; i++) {
        if (rows[i].has_children) {
            editState.collapsedTreeNodes.add(rows[i].id);
        }
    }
    renderNavTree();
    saveState();
}

function expandAllTreeNodes() {
    editState.collapsedTreeNodes.clear();
    renderNavTree();
    saveState();
}

function setViewMode(mode) {
    editState.viewMode = mode;
    document.querySelectorAll('.view-mode-btn').forEach(function(btn) {
        btn.classList.toggle('active', btn.getAttribute('data-mode') === mode);
    });
    renderNavTree();
    saveState();
}
