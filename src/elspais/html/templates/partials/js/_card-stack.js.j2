// Implements: REQ-p00006-B
// Implements: REQ-d00232-A, REQ-d00232-B
// Partial: _card-stack.js.j2 — Card rendering, open/close

// =====================================================================
// Card Stack — Unified for all node kinds
// =====================================================================

// Comment data cache: nodeId -> { anchor: [thread, ...], ... }
var cardCommentData = {};

function updateTreeCommentFlag(nodeId) {
    // Update has_comments in cached treeData and re-render tree
    var hasComments = cardCommentData[nodeId] &&
        Object.keys(cardCommentData[nodeId]).length > 0;
    if (editState.treeData) {
        editState.treeData.forEach(function(row) {
            if (row.id === nodeId) {
                row.has_comments = hasComments;
            }
        });
        renderNavTree();
    }
}

async function openCard(nodeId) {
    editState.focusNodeId = nodeId;
    // If already open, just focus it
    if (editState.openCards.has(nodeId)) {
        focusCard(nodeId);
        return;
    }

    // Fetch node data via generic endpoint
    const data = await apiFetch('/api/node/' + encodeURIComponent(nodeId));
    if (!data) return;

    // Store in state with kind from response
    editState.openCards.set(nodeId, { data: data, collapsed: false, kind: data.kind });

    // Add to front of order
    editState.openCardOrder = editState.openCardOrder.filter(function(id) { return id !== nodeId; });
    editState.openCardOrder.unshift(nodeId);

    renderCardStack();
    // Prefetch coverage data so buttons are colored immediately
    if (data.kind === 'requirement') { prefetchCoverage(nodeId); }
    // Fetch comment data for margin indicators
    loadCardComments(nodeId);
    focusCard(nodeId);
    updateNavSelection();
    saveState();
}

function closeCard(nodeId) {
    editState.openCards.delete(nodeId);
    editState.openCardOrder = editState.openCardOrder.filter(function(id) { return id !== nodeId; });
    renderCardStack();
    updateNavSelection();
    saveState();
}

function focusCard(nodeId) {
    // Move to front of order
    editState.openCardOrder = editState.openCardOrder.filter(function(id) { return id !== nodeId; });
    editState.openCardOrder.unshift(nodeId);

    // Render first so DOM is rebuilt with correct order, then scroll
    renderCardStack();
    saveState();

    // Re-query after render since renderCardStack() replaces all DOM nodes
    document.querySelectorAll('.req-card').forEach(function(c) { c.classList.remove('focused'); });
    const card = document.getElementById('card-' + nodeId);
    if (card) {
        card.classList.add('focused');
        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
}

function toggleCardCollapse(nodeId) {
    const info = editState.openCards.get(nodeId);
    if (!info) return;
    info.collapsed = !info.collapsed;
    const card = document.getElementById('card-' + nodeId);
    if (card) {
        card.classList.toggle('collapsed', info.collapsed);
    }
    saveState();
}

function closeAllCards() {
    editState.openCards.clear();
    editState.openCardOrder = [];
    renderCardStack();
    updateNavSelection();
    saveState();
}

function renderCardStack() {
    const body = document.getElementById('card-stack-body');
    const empty = document.getElementById('card-stack-empty');
    const countEl = document.getElementById('card-stack-count');

    if (editState.openCardOrder.length === 0) {
        body.innerHTML = '';
        body.appendChild(empty);
        empty.style.display = 'flex';
        countEl.textContent = 'No cards open';
        return;
    }

    empty.style.display = 'none';
    countEl.textContent = editState.openCardOrder.length + ' card' +
        (editState.openCardOrder.length !== 1 ? 's' : '') + ' open';

    let html = '';
    editState.openCardOrder.forEach(function(nodeId) {
        const info = editState.openCards.get(nodeId);
        if (!info) return;
        var kind = info.kind || 'requirement';
        if (kind === 'journey') {
            html += buildJourneyCardHtml(nodeId, info.data, info.collapsed);
        } else if (kind === 'term') {
            html += buildTermCardHtml(nodeId, info.data, info.collapsed);
        } else if (kind === 'requirement') {
            html += buildCardHtml(nodeId, info.data, info.collapsed);
        } else {
            html += buildGenericCardHtml(nodeId, info.data, info.collapsed);
        }
    });

    body.innerHTML = html;

    // Re-add empty element (hidden) for later
    body.appendChild(empty);

    // Re-apply cached coverage colors after DOM rebuild
    recolorCachedButtons();

    // Re-apply edit mode state after DOM rebuild
    if (editState.enabled) {
        document.querySelectorAll('.card-assertion-text').forEach(function(el) {
            el.contentEditable = 'true';
        });
    }

    // Re-apply cached comment indicators after DOM rebuild
    editState.openCardOrder.forEach(function(nodeId) {
        if (cardCommentData[nodeId]) {
            renderMarginIndicators(nodeId, cardCommentData[nodeId]);
        }
    });
}

// =====================================================================
// Lost Comments Card (Implements: REQ-d00234-A)
// =====================================================================

function loadOrphanedComments() {
    apiFetch('/api/comments/orphaned').then(function(data) {
        if (data && data.success && data.threads.length > 0) {
            renderLostCommentsCard(data.threads);
        } else {
            // Remove existing lost comments card if no orphans
            var existing = document.getElementById('lost-comments-card');
            if (existing) existing.remove();
        }
    });
}

function renderLostCommentsCard(threads) {
    var existing = document.getElementById('lost-comments-card');
    if (existing) existing.remove();

    var html = '<div class="req-card lost-comments-card" id="lost-comments-card">';
    html += '<div class="req-card-header lost-comments-header">';
    html += '<span class="lost-comments-icon">&#9888;</span>';
    html += '<span class="lost-comments-title">Lost Comments (' + threads.length + ')</span>';
    html += '<button class="req-card-close" onclick="document.getElementById(\'lost-comments-card\').remove()" title="Dismiss">&times;</button>';
    html += '</div>';
    html += '<div class="req-card-body">';
    threads.forEach(function(t) {
        html += '<div class="lost-comment-item">';
        html += '<div class="lost-comment-origin">Originally on <code>' +
            escapeHtml(t.anchor || t.root.anchor) + '</code> (deleted)</div>';
        html += '<div class="comment-entry">';
        html += '<span class="comment-author">' + escapeHtml(t.root.author) + '</span>';
        html += ' <span class="comment-date">' + escapeHtml(t.root.date) + '</span>';
        html += '<div class="comment-text">' + escapeHtml(t.root.text) + '</div>';
        html += '</div>';
        if (t.replies && t.replies.length > 0) {
            t.replies.forEach(function(r) {
                html += '<div class="comment-entry comment-reply">';
                html += '<span class="comment-author">' + escapeHtml(r.author) + '</span>';
                html += ' <span class="comment-date">' + escapeHtml(r.date) + '</span>';
                html += '<div class="comment-text">' + escapeHtml(r.text) + '</div>';
                html += '</div>';
            });
        }
        html += '<div class="comment-actions edit-only">';
        html += '<button class="comment-resolve-btn" onclick="resolveLostComment(\'' +
            escapeAttr(t.root.id) + '\')">Resolve</button>';
        html += '</div>';
        html += '</div>';
    });
    html += '</div></div>';

    var body = document.getElementById('card-stack-body');
    if (body) {
        body.insertAdjacentHTML('afterbegin', html);
    }
}

async function resolveLostComment(commentId) {
    var data = await apiFetch('/api/comment/resolve', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({comment_id: commentId})
    });
    if (data && data.success) {
        showToast('Comment resolved', 'success');
        loadOrphanedComments();
    }
}

// =====================================================================
// Comment Margin Indicators (REQ-d00232-B)
// =====================================================================

function loadCardComments(nodeId) {
    apiFetch('/api/comments/card?node_id=' + encodeURIComponent(nodeId))
        .then(function(data) {
            if (data && data.success) {
                cardCommentData[nodeId] = data.threads;
                renderMarginIndicators(nodeId, data.threads);
            }
        });
}

function renderMarginIndicators(nodeId, threads) {
    var cardEl = document.getElementById('card-' + nodeId);
    if (!cardEl) return;
    // Check if this card has any comments at all
    var hasAnyComments = threads && Object.keys(threads).length > 0;
    var anchored = cardEl.querySelectorAll('[data-anchor]');
    anchored.forEach(function(el) {
        var anchor = el.getAttribute('data-anchor');
        // Remove previous gutter state
        el.classList.remove('has-comment-gutter', 'comment-gutter-empty');
        var existingGutter = el.querySelector('.comment-gutter');
        if (existingGutter) existingGutter.remove();
        var count = threads[anchor] ? threads[anchor].length : 0;
        if (count > 0) {
            el.classList.add('has-comment-gutter');
            // Absolute-positioned icon in the left gutter area
            var gutter = document.createElement('span');
            gutter.className = 'comment-gutter';
            gutter.title = count + ' comment' + (count > 1 ? 's' : '') + ' — click to expand';
            gutter.innerHTML = '<span class="comment-gutter-bubble">\uD83D\uDDE9</span><span class="comment-gutter-count">' + count + '</span>';
            gutter.onclick = function(e) {
                e.stopPropagation();
                toggleCommentThread(anchor);
            };
            el.style.position = 'relative';
            el.appendChild(gutter);
        } else if (hasAnyComments) {
            // Empty gutter placeholder so all rows align
            el.classList.add('comment-gutter-empty');
        }
    });
}

// Implements: REQ-d00233-A
function toggleCommentThread(anchor) {
    var existing = document.querySelector('.comment-thread-inline[data-thread-anchor="' + anchor + '"]');
    if (existing) {
        existing.remove();
        return;
    }
    var el = document.querySelector('[data-anchor="' + anchor + '"]');
    if (!el) return;
    var card = el.closest('.req-card');
    if (!card) return;
    var nodeId = (card.id || '').replace(/^card-/, '');
    if (!nodeId) return;
    var threads = cardCommentData[nodeId];
    if (!threads || !threads[anchor]) return;
    var container = document.createElement('div');
    container.className = 'comment-thread-inline';
    container.setAttribute('data-thread-anchor', anchor);
    threads[anchor].forEach(function(t) {
        container.appendChild(buildThreadHtml(t, anchor, nodeId));
    });
    el.after(container);
}

function buildThreadHtml(thread, anchor, nodeId) {
    var div = document.createElement('div');
    div.className = 'comment-thread-item';
    div.setAttribute('data-comment-id', thread.root.id);
    // Root comment
    var html = '<div class="comment-entry">';
    html += '<span class="comment-author">' + escapeHtml(thread.root.author) + '</span>';
    html += ' <span class="comment-date">' + escapeHtml(thread.root.date) + '</span>';
    html += '<div class="comment-text">' + escapeHtml(thread.root.text) + '</div>';
    html += '</div>';
    // Replies
    if (thread.replies && thread.replies.length > 0) {
        thread.replies.forEach(function(r) {
            html += '<div class="comment-entry comment-reply">';
            html += '<span class="comment-author">' + escapeHtml(r.author) + '</span>';
            html += ' <span class="comment-date">' + escapeHtml(r.date) + '</span>';
            html += '<div class="comment-text">' + escapeHtml(r.text) + '</div>';
            html += '</div>';
        });
    }
    // Edit-mode-only controls: Resolve and Reply
    html += '<div class="comment-actions edit-only">';
    html += '<button class="comment-resolve-btn" onclick="resolveComment(\'' +
        escapeAttr(thread.root.id) + '\', \'' + escapeAttr(anchor) + '\', \'' +
        escapeAttr(nodeId) + '\')">Resolve</button>';
    html += '<button class="comment-reply-btn" onclick="showReplyInput(this, \'' +
        escapeAttr(thread.root.id) + '\', \'' + escapeAttr(anchor) + '\', \'' +
        escapeAttr(nodeId) + '\')">Reply</button>';
    html += '</div>';
    div.innerHTML = html;
    return div;
}

async function resolveComment(commentId, anchor, nodeId) {
    var data = await apiFetch('/api/comment/resolve', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({comment_id: commentId})
    });
    if (data && data.success) {
        // Remove thread item from DOM; if it was the last one, remove the container too
        var threadEl = document.querySelector('.comment-thread-item[data-comment-id="' + commentId + '"]');
        if (threadEl) {
            var container = threadEl.closest('.comment-thread-inline');
            threadEl.remove();
            if (container && container.querySelectorAll('.comment-thread-item').length === 0) {
                container.remove();
            }
        }
        // Remove from cache; clean up empty anchor keys
        if (cardCommentData[nodeId] && cardCommentData[nodeId][anchor]) {
            cardCommentData[nodeId][anchor] = cardCommentData[nodeId][anchor].filter(
                function(t) { return t.root.id !== commentId; }
            );
            if (cardCommentData[nodeId][anchor].length === 0) {
                delete cardCommentData[nodeId][anchor];
            }
        }
        // Refresh margin indicators and tree
        renderMarginIndicators(nodeId, cardCommentData[nodeId] || {});
        updateTreeCommentFlag(nodeId);
        showToast('Comment resolved', 'success');
    }
}

function showReplyInput(btn, parentId, anchor, nodeId) {
    // Remove any existing reply input
    var existing = btn.closest('.comment-thread-item').querySelector('.comment-reply-input');
    if (existing) { existing.remove(); return; }
    var inputDiv = document.createElement('div');
    inputDiv.className = 'comment-reply-input';
    inputDiv.innerHTML = '<textarea class="comment-input-text" placeholder="Write a reply..." rows="2"></textarea>' +
        '<div class="comment-input-actions">' +
        '<button class="comment-submit-btn" onclick="submitReply(this, \'' +
        escapeAttr(parentId) + '\', \'' + escapeAttr(anchor) + '\', \'' +
        escapeAttr(nodeId) + '\')">Reply</button>' +
        '<button class="comment-cancel-btn" onclick="this.closest(\'.comment-reply-input\').remove()">Cancel</button>' +
        '</div>';
    btn.closest('.comment-thread-item').appendChild(inputDiv);
    inputDiv.querySelector('textarea').focus();
}

async function submitReply(btn, parentId, anchor, nodeId) {
    var textarea = btn.closest('.comment-reply-input').querySelector('textarea');
    var text = textarea.value.trim();
    if (!text) return;
    var data = await apiFetch('/api/comment/reply', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({parent_id: parentId, text: text})
    });
    if (data && data.success) {
        // Append reply to DOM
        var threadItem = btn.closest('.comment-thread-item');
        var replyDiv = document.createElement('div');
        replyDiv.className = 'comment-entry comment-reply';
        replyDiv.innerHTML = '<span class="comment-author">' + escapeHtml(data.comment.author) + '</span>' +
            ' <span class="comment-date">' + escapeHtml(data.comment.date) + '</span>' +
            '<div class="comment-text">' + escapeHtml(data.comment.text) + '</div>';
        var actions = threadItem.querySelector('.comment-actions');
        threadItem.insertBefore(replyDiv, actions);
        // Remove input
        btn.closest('.comment-reply-input').remove();
        showToast('Reply added', 'success');
    }
}

// Implements: REQ-d00233-B
function showCommentInput(anchor, afterElement) {
    // Remove any existing comment input and highlight
    var existing = document.querySelector('.comment-new-input');
    if (existing) existing.remove();
    var prevTarget = document.querySelector('.comment-target');
    if (prevTarget) prevTarget.classList.remove('comment-target');

    // Remember clicked element's position before DOM changes
    var scrollContainer = document.getElementById('card-stack-body');
    var elTopBefore = afterElement.getBoundingClientRect().top;

    // Expand any existing comment threads on this anchor so user sees context
    var card = afterElement.closest('.req-card');
    if (card) {
        var nodeId = (card.id || '').replace(/^card-/, '');
        var threads = cardCommentData[nodeId];
        if (threads && threads[anchor]) {
            var existingThread = document.querySelector('.comment-thread-inline[data-thread-anchor="' + anchor + '"]');
            if (!existingThread) {
                toggleCommentThread(anchor);
            }
        }
    }

    // Highlight the target element
    afterElement.classList.add('comment-target');
    var inputDiv = document.createElement('div');
    inputDiv.className = 'comment-new-input';
    inputDiv.innerHTML = '<textarea class="comment-input-text" placeholder="Add a comment..." rows="3"></textarea>' +
        '<div class="comment-input-actions">' +
        '<button class="comment-submit-btn" onclick="submitNewComment(this, \'' +
        escapeAttr(anchor) + '\')">Submit</button>' +
        '<button class="comment-cancel-btn" onclick="cancelCommentInput()">Cancel</button>' +
        '</div>';
    afterElement.after(inputDiv);

    // Restore scroll so clicked element stays in the same visual position
    if (scrollContainer) {
        var elTopAfter = afterElement.getBoundingClientRect().top;
        var drift = elTopAfter - elTopBefore;
        if (Math.abs(drift) > 1) {
            scrollContainer.scrollTop += drift;
        }
    }

    inputDiv.querySelector('textarea').focus();
    // Esc to cancel
    inputDiv.querySelector('textarea').addEventListener('keydown', function(e) {
        if (e.key === 'Escape') { cancelCommentInput(); }
    });
}

function cancelCommentInput() {
    var input = document.querySelector('.comment-new-input');
    if (input) input.remove();
    var target = document.querySelector('.comment-target');
    if (target) target.classList.remove('comment-target');
}

async function submitNewComment(btn, anchor) {
    var textarea = btn.closest('.comment-new-input').querySelector('textarea');
    var text = textarea.value.trim();
    if (!text) return;
    var data = await apiFetch('/api/comment/add', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({anchor: anchor, text: text})
    });
    if (data && data.success) {
        // Remove input and highlight
        btn.closest('.comment-new-input').remove();
        var target = document.querySelector('.comment-target');
        if (target) target.classList.remove('comment-target');
        // Find the card and reload comments, then show the thread
        var el = document.querySelector('[data-anchor="' + anchor + '"]');
        if (el) {
            var card = el.closest('.req-card');
            if (card) {
                var nodeId = (card.id || '').replace(/^card-/, '');
                // Reload comment data, then refresh indicators and show thread
                var refreshed = await apiFetch('/api/comments/card?node_id=' + encodeURIComponent(nodeId));
                if (refreshed && refreshed.success) {
                    cardCommentData[nodeId] = refreshed.threads;
                    renderMarginIndicators(nodeId, refreshed.threads);
                    // Auto-expand the thread on the anchor we just commented on
                    // Remove any existing inline thread first
                    var existing = document.querySelector('.comment-thread-inline[data-thread-anchor="' + anchor + '"]');
                    if (existing) existing.remove();
                    toggleCommentThread(anchor);
                }
                updateTreeCommentFlag(nodeId);
            }
        }
        showToast('Comment added', 'success');
    }
}

function buildAssertionHtml(nodeId, a, data) {
    var assertionId = a.id || '';
    var label = a.label || '';
    var text = a.text || '';
    var h = '';
    h += '<div class="card-assertion-wrapper" data-assertion-id="' + assertionId + '" data-anchor="' + nodeId + '#' + label + '">';
    h += '<div class="card-assertion">';
    h += '<span class="card-assertion-label">' + label + '</span>';
    h += '<span class="card-assertion-text editable-field" ' +
        'contenteditable="false" data-assertion-id="' + assertionId + '" ' +
        'data-field="assertion" data-original="' + escapeAttr(text) + '" ' +
        'onblur="onAssertionBlur(this)" onkeydown="onEditableKeydown(event)">' +
        escapeHtml(text) + '</span>';
    // 6 dimension badges — only shown when direct assertion-level links exist
    h += '<span class="assertion-badges-area">';
    var badgeMode = editState.assertionBadgeMode || 'abbrev';
    var aLinks = data.assertion_links ? data.assertion_links[label] : null;
    var dimDefs = [
        {cls: 'assertion-implemented-btn', full: 'Implemented', abbr: 'IMP', dot: 'I', toggle: 'toggleAssertionCode', tip: 'Code implementation', linkKey: 'implemented', edgeKind: 'implements'},
        {cls: 'assertion-refined-btn', full: 'Refined', abbr: 'REF', dot: 'R', toggle: 'toggleAssertionRefines', tip: 'Refines references', linkKey: 'refined'},
        {cls: 'assertion-tested-btn', full: 'Tested', abbr: 'TST', dot: 'T', toggle: 'toggleAssertionTests', tip: 'Test coverage', linkKey: 'tested'},
        {cls: 'assertion-verified-btn', full: 'Verified', abbr: 'VER', dot: 'V', toggle: 'toggleAssertionResults', tip: 'Test results', linkKey: 'tested'},
        {cls: 'assertion-validated-btn', full: 'Validated', abbr: 'VAL', dot: 'U', toggle: 'toggleAssertionUat', tip: 'Journey coverage', linkKey: 'validated'},
        {cls: 'assertion-accepted-btn', full: 'Accepted', abbr: 'ACC', dot: 'A', toggle: 'toggleAssertionUatResults', tip: 'Journey results', linkKey: 'validated'}
    ];
    var anyBadge = false;
    dimDefs.forEach(function(dim) {
        if (aLinks && !aLinks[dim.linkKey]) return;
        anyBadge = true;
        var btnLabel = badgeMode === 'full' ? dim.full : (badgeMode === 'dots' ? dim.dot : dim.abbr);
        var btnStyle = badgeMode === 'dots' ? ' style="min-width:0;padding:2px 4px;font-size:0.55rem;"' : '';
        var extraArg = dim.edgeKind ? ", '" + dim.edgeKind + "'" : '';
        h += '<button class="' + dim.cls + '" ' +
            'data-req-id="' + nodeId + '" data-label="' + escapeAttr(label) + '" ' +
            'title="' + dim.tip + '" ' +
            'onclick="event.stopPropagation(); ' + dim.toggle + '(this, \'' + nodeId + '\', \'' + escapeAttr(label) + '\'' + extraArg + ')"' +
            btnStyle + '>' +
            btnLabel + '</button>';
    });
    if (!anyBadge) {
        h += '<span class="assertion-no-coverage" title="No direct assertion-level coverage" style="font-size:0.6rem;color:var(--secondary-text);opacity:0.5;">no direct coverage</span>';
    }
    h += '</span>'; // close .assertion-badges-area
    h += '<button class="assertion-delete-btn edit-only" ' +
        'title="Deprecate assertion" ' +
        'onclick="event.stopPropagation(); onDeleteAssertion(\'' + nodeId + '\', \'' + escapeAttr(assertionId) + '\')">' +
        '&#8856;</button>';
    h += '</div>';
    h += '<div class="assertion-code-panel" id="assertion-code-' + nodeId + '-' + label + '" style="display:none;"></div>';
    h += '<div class="assertion-refines-panel" id="assertion-refines-' + nodeId + '-' + label + '" style="display:none;"></div>';
    h += '<div class="assertion-tests-panel" id="assertion-tests-' + nodeId + '-' + label + '" style="display:none;"></div>';
    h += '<div class="assertion-results-panel" id="assertion-results-' + nodeId + '-' + label + '" style="display:none;"></div>';
    h += '<div class="assertion-uat-panel" id="assertion-uat-' + nodeId + '-' + label + '" style="display:none;"></div>';
    h += '<div class="assertion-uat-results-panel" id="assertion-uat-results-' + nodeId + '-' + label + '" style="display:none;"></div>';
    h += '</div>';
    return h;
}

function buildRemainderHtml(nodeId, rem, idx) {
    var h = '';
    var remId = rem.id || '';
    var isPreamble = (rem.heading === 'preamble');
    var isDefBlock = (rem.content_type === 'definition_block');
    h += '<div class="card-body-section-wrapper" data-remainder-id="' + escapeAttr(remId) + '" data-anchor="' + nodeId + '#section:' + escapeAttr(rem.heading || '') + '">';
    h += '<div class="card-body-section-heading">';
    if (!isDefBlock && !isPreamble) {
        h += '<span class="remainder-heading-view">' + escapeHtml(rem.heading) + '</span>';
        h += '<input type="text" class="edit-only remainder-heading-edit" value="' + escapeAttr(rem.heading) + '"' +
            ' data-node-id="' + escapeAttr(remId) + '" data-original="' + escapeAttr(rem.heading) + '"' +
            ' onblur="onRemainderHeadingBlur(this)" style="font-weight:600;flex:1;">';
    } else {
        h += '<span>' + escapeHtml(rem.heading) + '</span>';
    }
    h += '<span class="card-body-section-toggle" id="body-section-toggle-' + nodeId + '-' + idx + '" ' +
        'onclick="toggleBodySection(\'' + nodeId + '\', ' + idx + ')">[-]</span>';
    if (!isDefBlock) {
        h += '<button class="edit-only remainder-delete-btn" ' +
            'onclick="event.stopPropagation(); onRemainderDelete(\'' + escapeAttr(remId) + '\')" ' +
            'title="Delete section">&times;</button>';
    }
    h += '</div>';
    h += '<div class="card-body-section-content remainder-text-view" id="body-section-content-' + nodeId + '-' + idx + '">' +
        simpleMarkdown(rem.text || '', true) + '</div>';
    if (!isDefBlock) {
        h += '<textarea class="edit-only remainder-text-edit" data-node-id="' + escapeAttr(remId) + '"' +
            ' data-original="' + escapeAttr(rem.text || '') + '"' +
            ' onblur="onRemainderTextBlur(this)"' +
            ' style="width:100%;min-height:120px;font-size:0.8rem;border:1px solid var(--border-color);border-radius:4px;padding:6px;resize:vertical;background:var(--card-bg);color:var(--input-text);">' +
            escapeHtml(rem.text || '') + '</textarea>';
    }
    h += '</div>';
    return h;
}

function buildCardHtml(nodeId, data, collapsed) {
    const collapsedClass = collapsed ? ' collapsed' : '';
    const focusedClass = editState.openCardOrder[0] === nodeId ? ' focused' : '';
    const shortId = nodeId;
    const title = escapeHtml(data.title || '');
    var props = data.properties || {};
    const level = (props.level || '').toUpperCase();
    const status = (props.status || '').toLowerCase();
    const statusDisplay = status.charAt(0).toUpperCase() + status.slice(1);
    const hash = props.hash || '';
    const sourcePath = (data.source && data.source.path) || '';
    const sourceLine = (data.source && data.source.line) || 0;

    let html = '<div class="req-card' + collapsedClass + focusedClass + '" id="card-' + nodeId + '">';

    // Header — with inline title editing
    html += '<div class="req-card-header" onclick="toggleCardCollapse(\'' + nodeId + '\')">';
    html += '<span class="req-card-expand">&#9660;</span>';
    html += '<span class="req-card-id">' + shortId + '</span>';
    html += '<span class="req-card-title-display view-only">' + title + '</span>';
    html += '<input type="text" class="edit-only req-card-title-edit" value="' + escapeAttr(data.title || '') + '"' +
        ' onclick="event.stopPropagation()" onblur="onTitleBlur(this)" data-node-id="' + nodeId + '"' +
        ' data-original="' + escapeAttr(data.title || '') + '"' +
        ' style="font-size:0.9rem;font-weight:600;border:none;border-bottom:1px dashed var(--border-color);background:transparent;color:var(--input-text);flex:1;outline:none;padding:1px 4px;">';
    html += '<button class="req-card-delete edit-only" ' +
        'onclick="event.stopPropagation(); onDeleteRequirement(\'' + nodeId + '\')" ' +
        'title="Delete requirement">&#x1F5D1;</button>';
    html += '<button class="req-card-close" onclick="event.stopPropagation(); closeCard(\'' + nodeId + '\')" title="Close card">&times;</button>';
    html += '</div>';

    // Body
    html += '<div class="req-card-body">';

    // Coverage dimension badges (above metadata)
    // Only shown when data exists; always clickable to expand links + flash assertions
    if (data.coverage_dimensions) {
        var rLinks = data.req_level_links || {};
        var aLinksAll = data.assertion_links || {};
        html += '<div class="card-section card-coverage-badges" style="padding:4px 12px 0;display:flex;gap:6px;flex-wrap:wrap;">';
        var headerDims = [
            {key: 'implemented', linkKey: 'implemented', assertLinkKey: 'implemented', label: 'IMPLEMENTED'},
            {key: null, linkKey: 'refined', assertLinkKey: 'refined', label: 'REFINED'},
            {key: 'tested', linkKey: 'tested', assertLinkKey: 'tested', label: 'TESTED'},
            {key: 'verified', linkKey: 'verified', assertLinkKey: 'tested', label: 'VERIFIED'},
            {key: 'uat_coverage', linkKey: 'validated', assertLinkKey: 'validated', label: 'VALIDATED'},
            {key: 'uat_verified', linkKey: 'accepted', assertLinkKey: 'validated', label: 'ACCEPTED'}
        ];
        headerDims.forEach(function(d) {
            var dim = d.key ? data.coverage_dimensions[d.key] : null;
            var hasReqLinks = d.linkKey && rLinks[d.linkKey] && rLinks[d.linkKey].length > 0;
            // Check if any assertion has direct links for this dimension
            var hasAssertionLinks = false;
            for (var lbl in aLinksAll) {
                if (aLinksAll[lbl][d.assertLinkKey]) { hasAssertionLinks = true; break; }
            }
            var hasData = (dim && dim.color) || hasReqLinks || hasAssertionLinks;
            if (!hasData) return; // hide badge if no data
            var colorClass = dim && dim.color ? ' active val-' + dim.color : '';
            var tipParts = [];
            if (dim && dim.status_tip) tipParts.push(dim.status_tip);
            if (hasReqLinks) tipParts.push(rLinks[d.linkKey].length + ' REQ-level link(s)');
            if (hasAssertionLinks) tipParts.push('Click to highlight assertions');
            var tip = tipParts.length > 0 ? tipParts.join(' \u2014 ') : d.label;
            html += '<span class="status-badge' + colorClass + ' card-dim-badge" ' +
                'title="' + escapeHtml(tip) + '" style="font-size:0.6rem;padding:1px 5px;" ' +
                'onclick="event.stopPropagation(); toggleReqLevelLinks(this, \'' + nodeId + '\', \'' + d.linkKey + '\', \'' + d.assertLinkKey + '\')">' +
                d.label + '</span>';
        });
        html += '</div>';
        // Expandable link panels (one per header dimension, hidden by default)
        ['implemented', 'refined', 'tested', 'verified', 'validated', 'accepted'].forEach(function(dimKey) {
            html += '<div class="req-level-links-panel" id="req-links-' + nodeId + '-' + dimKey + '" style="display:none;margin:0 12px;padding:6px 10px;background:var(--assertion-code-panel-bg);border-radius:4px;border-left:3px solid var(--impl-yes-border);font-size:0.78rem;"></div>';
        });
    }

    // Metadata section — source file right-justified on label line
    var reqSourceLink = '';
    if (sourcePath) {
        reqSourceLink = '<span style="margin-left:auto;display:flex;align-items:baseline;gap:4px;text-transform:none;">' +
            '<a href="#" onclick="event.preventDefault(); showSource(\'' +
            escapeHtml(sourcePath) + '\', ' + sourceLine + ')" ' +
            'style="color:#0d6efd;cursor:pointer;font-size:0.7rem;text-decoration:none;">' +
            escapeHtml(sourcePath.split('/').pop()) + ':' + sourceLine + '</a>' +
            '<button class="card-move-file-btn edit-only" ' +
            'onclick="event.preventDefault(); onMoveToFile(\'' + nodeId + '\', \'' + escapeHtml(sourcePath) + '\')" ' +
            'title="Move to different file" style="font-size:0.65rem;">Move</button>' +
            '</span>';
    }
    html += '<div class="card-section" data-anchor="' + nodeId + '"><div class="card-section-label" style="display:flex;align-items:baseline;">Metadata' + reqSourceLink + '</div>';
    html += '<div class="card-meta">';

    // Level
    html += '<div class="card-meta-item">';
    html += '<span class="card-meta-key">Level:</span>';
    html += '<span class="card-meta-value">' + level + '</span>';
    html += '</div>';

    // Status (badge or select)
    html += '<div class="card-meta-item">';
    html += '<span class="card-meta-key">Status:</span>';
    html += '<span class="status-badge-wrapper"><span class="status-badge ' + status + '">' + statusDisplay + '</span></span>';
    html += '<span class="status-select-wrapper edit-only">';
    html += '<select class="status-select" data-node-id="' + nodeId + '" data-original="' + status + '" onchange="onStatusChange(this)">';
    ['Active', 'Draft', 'Deprecated', 'Proposed'].forEach(function(s) {
        const sel = s.toLowerCase() === status ? ' selected' : '';
        html += '<option value="' + s + '"' + sel + '>' + s + '</option>';
    });
    html += '</select></span>';
    html += '</div>';

    // Hash
    html += '<div class="card-meta-item">';
    html += '<span class="card-meta-key">Hash:</span>';
    html += '<span class="card-meta-value" style="font-family:monospace;font-size:0.75rem;">' + hash + '</span>';
    html += '</div>';

    html += '</div></div>';

    // Parents section (relationship editor in edit mode)
    html += '<div class="card-section"><div class="card-section-label">Outgoing Links</div>';
    html += '<div class="card-parents">';
    if (data.parents && data.parents.length > 0) {
        data.parents.forEach(function(p) {
            const edgeKind = (p.edge_kind || 'implements').toLowerCase();
            const edgeKindDisplay = edgeKind.charAt(0).toUpperCase() + edgeKind.slice(1);
            html += '<div class="card-parent-row" data-anchor="' + nodeId + '#edge:' + p.id + '">';
            // View-only kind badge
            html += '<span class="card-parent-kind view-only">' + edgeKindDisplay.toUpperCase() + '</span>';
            // Edit-only kind toggle
            html += '<button class="card-parent-kind-toggle edit-only" ' +
                'data-source="' + nodeId + '" data-target="' + p.id + '" data-kind="' + edgeKind + '" ' +
                'onclick="event.preventDefault(); onToggleEdgeKind(this)" ' +
                'title="Click to cycle edge kind">' + edgeKindDisplay + '</button>';
            var pTargetsJson = (p.assertion_targets && p.assertion_targets.length > 0)
                ? escapeAttr(JSON.stringify(p.assertion_targets)) : '';
            html += '<a class="card-parent-link" href="#" onclick="event.preventDefault(); openCardAndFlash(\'' + p.id + '\', ' +
                (pTargetsJson ? 'JSON.parse(this.dataset.targets)' : '[]') + ')"' +
                (pTargetsJson ? ' data-targets="' + pTargetsJson + '"' : '') + '>';
            html += (p.ref_id || p.id) + ' - ' + escapeHtml(p.title || '');
            if (p.assertion_targets && p.assertion_targets.length > 0) {
                html += ' <span class="card-parent-targets">[' + p.assertion_targets.join(', ') + ']</span>';
            }
            html += '</a>';
            // Assertion targets picker button (edit mode)
            html += '<button class="card-parent-targets-btn edit-only" ' +
                'onclick="event.preventDefault(); editEdgeTargets(\'' + nodeId + '\', \'' + p.id + '\', this)" ' +
                'title="Edit assertion targets">&#9998;</button>';
            html += '<button class="card-parent-delete edit-only" ' +
                'onclick="event.preventDefault(); onDeleteEdge(\'' + nodeId + '\', \'' + p.id + '\')" ' +
                'title="Remove relationship">&times;</button>';
            html += '</div>';
        });
    } else {
        html += '<div class="card-parents-empty">No parent relationships</div>';
    }
    html += '</div>';
    // Add relationship button (edit mode only)
    html += '<button class="card-add-rel-btn edit-only" ' +
        'onclick="onAddRelationship(\'' + nodeId + '\', this)">+ Add Relationship</button>';
    html += '</div>';

    // Structure section — assertions and body sections
    var allChildren = data.children || [];
    var assertions = allChildren.filter(function(c) { return c.kind === 'assertion'; });
    var remainders = allChildren.filter(function(c) { return c.kind === 'remainder' && c.heading; });

    if (editState.cardViewMode === 'complete') {
        // Complete view: interleave assertions and sections in document order
        var structItems = assertions.map(function(a) { return {type: 'assertion', data: a, order: a.render_order != null ? a.render_order : (a.line || 0)}; })
            .concat(remainders.map(function(r, i) { return {type: 'remainder', data: r, idx: i, order: r.render_order != null ? r.render_order : (r.line || 0)}; }));
        structItems.sort(function(a, b) { return a.order - b.order; });

        html += '<div class="card-section">';
        html += '<div class="card-assertions">';
        var assertionHeaderShown = false;
        structItems.forEach(function(item) {
            if (item.type === 'assertion') {
                if (!assertionHeaderShown) {
                    html += '<div class="card-section-label" style="margin-top:4px;">Assertions (' + assertions.length + ')</div>';
                    assertionHeaderShown = true;
                }
                html += buildAssertionHtml(nodeId, item.data, data);
            } else {
                html += buildRemainderHtml(nodeId, item.data, item.idx);
            }
        });
        html += '</div>';
        html += '<button class="card-add-assertion-btn edit-only" onclick="onAddAssertion(\'' + nodeId + '\')">+ Add Assertion</button>';
        html += '<button class="card-add-section-btn edit-only" onclick="onRemainderAdd(\'' + nodeId + '\')">+ Add Section</button>';
        html += '</div>';
    } else {
        // Compact view: assertions only
        if (assertions.length > 0) {
            html += '<div class="card-section"><div class="card-section-label">Assertions (' + assertions.length + ')</div>';
            html += '<div class="card-assertions">';
            assertions.forEach(function(a) {
                html += buildAssertionHtml(nodeId, a, data);
            });
            html += '</div>';
            html += '<button class="card-add-assertion-btn edit-only" onclick="onAddAssertion(\'' + nodeId + '\')">+ Add Assertion</button>';
            html += '</div>';
        } else {
            html += '<div class="card-section"><div class="card-section-label">Assertions</div>';
            html += '<div style="font-size:0.8rem;color:var(--secondary-text);">No assertions defined</div>';
            html += '<button class="card-add-assertion-btn edit-only" onclick="onAddAssertion(\'' + nodeId + '\')">+ Add Assertion</button>';
            html += '</div>';
        }
    }

    // Children (requirements only)
    const childReqs = (data.children || []).filter(function(c) {
        return c.kind === 'requirement';
    });
    if (childReqs.length > 0) {
        html += '<div class="card-section"><div class="card-section-label">Children (' + childReqs.length + ')</div>';
        html += '<div class="card-children">';
        childReqs.forEach(function(c) {
            html += '<a class="card-child-link" href="#" onclick="event.preventDefault(); openCard(\'' + c.id + '\')">';
            html += c.id.replace('REQ-', '');
            if (c.title) html += ' - ' + escapeHtml(c.title);
            html += '</a>';
        });
        html += '</div></div>';
    }

    html += '</div>'; // end req-card-body
    html += '</div>'; // end req-card

    return html;
}

function updateNavSelection() {
    document.querySelectorAll('.nav-tree-row').forEach(function(row) {
        row.classList.toggle('selected', editState.openCards.has(row.dataset.id));
    });
}

// =====================================================================
// Journey Cards — reads from generic /api/node/ response
// =====================================================================

function buildJourneyCardHtml(nodeId, data, collapsed) {
    var collapsedClass = collapsed ? ' collapsed' : '';
    var focusedClass = editState.openCardOrder[0] === nodeId ? ' focused' : '';
    var title = escapeHtml(data.title || '');
    var shortId = escapeHtml(data.id || nodeId);
    var props = data.properties || {};
    var sourcePath = (data.source && data.source.path) || '';
    var sourceLine = (data.source && data.source.line) || 1;

    var html = '<div class="req-card journey-card' + collapsedClass + focusedClass + '" id="card-' + nodeId + '" data-journey-id="' + nodeId + '">';

    // Header — show journey ID + editable title
    html += '<div class="req-card-header" onclick="toggleCardCollapse(\'' + nodeId + '\')">';
    html += '<span class="req-card-expand">&#9660;</span>';
    html += '<span class="req-card-id">' + shortId + '</span>';
    html += '<span class="req-card-title-display view-only">' + title + '</span>';
    // Edit mode: inline title input
    html += '<input type="text" class="edit-only journey-title-edit" value="' + escapeAttr(data.title || '') + '"' +
        ' onclick="event.stopPropagation()" onblur="onJourneyTitleBlur(\'' + nodeId + '\', this)"' +
        ' style="font-size:0.9rem;font-weight:600;border:none;border-bottom:1px dashed var(--border-color);background:transparent;color:var(--input-text);flex:1;outline:none;">';
    // Edit mode: delete journey
    html += '<button class="edit-only journey-delete-btn" onclick="event.stopPropagation(); onDeleteJourney(\'' + nodeId + '\')" title="Delete journey">&#x1F5D1;</button>';
    html += '<button class="req-card-close" onclick="event.stopPropagation(); closeCard(\'' + nodeId + '\')" title="Close card">&times;</button>';
    html += '</div>';

    // Body
    html += '<div class="req-card-body">';

    // Metadata section — source file right-justified on the label line
    var sourceLink = '';
    if (sourcePath) {
        sourceLink = '<a href="#" onclick="event.preventDefault(); showSource(\'' +
            escapeHtml(sourcePath) + '\', ' + sourceLine + ')" ' +
            'style="color:#0d6efd;cursor:pointer;font-size:0.7rem;text-decoration:none;text-transform:none;margin-left:auto;">' +
            escapeHtml(sourcePath.split('/').pop()) + ':' + sourceLine + '</a>';
        sourceLink += '<button class="edit-only journey-move-btn" onclick="event.preventDefault(); onMoveToFile(\'' + nodeId + '\')" style="margin-left:4px;">Move</button>';
    }
    html += '<div class="card-section" data-anchor="' + nodeId + '"><div class="card-section-label" style="display:flex;align-items:baseline;">Metadata' + sourceLink + '</div>';
    html += '<div class="card-meta">';

    // Actor — view + edit
    html += '<div class="card-meta-item">';
    html += '<span class="card-meta-key">Actor:</span>';
    html += '<span class="card-meta-value journey-field-view">' + escapeHtml(props.actor || '') + '</span>';
    html += '<input type="text" class="edit-only journey-field-edit" value="' + escapeAttr(props.actor || '') + '"' +
        ' data-field="actor" data-journey-id="' + nodeId + '" onblur="onJourneyFieldBlur(this)"' +
        ' style="font-size:inherit;border:none;border-bottom:1px dashed var(--border-color);background:transparent;color:var(--input-text);width:90%;outline:none;">';
    html += '</div>';

    // Goal — view + edit
    html += '<div class="card-meta-item">';
    html += '<span class="card-meta-key">Goal:</span>';
    html += '<span class="card-meta-value journey-field-view">' + escapeHtml(props.goal || '') + '</span>';
    html += '<input type="text" class="edit-only journey-field-edit" value="' + escapeAttr(props.goal || '') + '"' +
        ' data-field="goal" data-journey-id="' + nodeId + '" onblur="onJourneyFieldBlur(this)"' +
        ' style="font-size:inherit;border:none;border-bottom:1px dashed var(--border-color);background:transparent;color:var(--input-text);width:90%;outline:none;">';
    html += '</div>';

    if (props.descriptor) {
        html += '<div class="card-meta-item">';
        html += '<span class="card-meta-key">Topic:</span>';
        html += '<span class="card-meta-value">' + escapeHtml(props.descriptor) + '</span>';
        html += '</div>';
    }

    html += '</div></div>';

    // Context (view + edit) — styled like remainder sections (Steps, Expected Outcome)
    if (props.context || editState.enabled) {
        html += '<div class="card-body-section-wrapper">';
        html += '<div class="card-body-section-heading"><span>Context</span></div>';
        html += '<div class="card-body-section-content journey-field-view">' + simpleMarkdown(props.context || '', true) + '</div>';
        html += '<textarea class="edit-only journey-field-edit" data-field="context" data-journey-id="' + nodeId + '"' +
            ' onblur="onJourneyFieldBlur(this)"' +
            ' style="width:100%;min-height:120px;font-size:0.8rem;border:1px solid var(--border-color);border-radius:4px;padding:6px;resize:vertical;background:var(--card-bg);color:var(--input-text);">' +
            escapeHtml(props.context || '') + '</textarea>';
        html += '</div>';
    }

    // Validates — with assertion targets and edit controls (same pattern as REQ parents)
    var refs = (data.links || []).filter(function(l) { return l.edge_kind === 'validates'; });
    html += '<div class="card-section journey-refs"><div class="card-section-label">Validates (' + refs.length + ')</div>';
    html += '<div class="card-parents">';
    refs.forEach(function(link) {
        html += '<div class="card-parent-row">';
        var lTargetsJson = (link.assertion_targets && link.assertion_targets.length > 0)
            ? escapeAttr(JSON.stringify(link.assertion_targets)) : '';
        html += '<a class="card-parent-link" href="#" onclick="event.preventDefault(); openCardAndFlash(\'' + link.id + '\', ' +
            (lTargetsJson ? 'JSON.parse(this.dataset.targets)' : '[]') + ')"' +
            (lTargetsJson ? ' data-targets="' + lTargetsJson + '"' : '') + '>';
        html += link.id + ' - ' + escapeHtml(link.title || '');
        if (link.assertion_targets && link.assertion_targets.length > 0) {
            html += ' <span class="card-parent-targets">[' + link.assertion_targets.join(', ') + ']</span>';
        }
        html += '</a>';
        // Assertion targets picker button (edit mode)
        html += '<button class="card-parent-targets-btn edit-only" ' +
            'onclick="event.preventDefault(); editEdgeTargets(\'' + nodeId + '\', \'' + link.id + '\', this)" ' +
            'title="Edit assertion targets">&#9998;</button>';
        html += '<button class="card-parent-delete edit-only" ' +
            'onclick="event.preventDefault(); onDeleteEdge(\'' + nodeId + '\', \'' + link.id + '\')" ' +
            'title="Remove relationship">&times;</button>';
        html += '</div>';
    });
    html += '</div>';
    html += '<button class="card-add-rel-btn edit-only" ' +
        'onclick="onAddJourneyRef(\'' + nodeId + '\', this)">+ Add Relationship</button>';
    html += '</div>';

    // Sections (view + edit)
    var sections = props.sections || [];
    html += '<div class="journey-sections" data-journey-id="' + nodeId + '">';
    sections.forEach(function(sec) {
        html += '<div class="card-body-section-wrapper journey-section" data-section-name="' + escapeAttr(sec.name) + '" data-anchor="' + nodeId + '#section:' + escapeAttr(sec.name) + '">';
        // Section header — view + edit
        html += '<div class="card-body-section-heading journey-section-header">';
        html += '<span class="journey-section-name-view">' + escapeHtml(sec.name) + '</span>';
        html += '<input type="text" class="edit-only journey-section-name-edit" value="' + escapeAttr(sec.name) + '"' +
            ' data-journey-id="' + nodeId + '" data-original-name="' + escapeAttr(sec.name) + '"' +
            ' onblur="onJourneySectionNameBlur(this)" style="font-weight:600;flex:1;">';
        html += '<button class="edit-only journey-section-delete" onclick="onDeleteJourneySection(\'' + nodeId + '\', \'' + escapeAttr(sec.name) + '\')" title="Delete section">&times;</button>';
        html += '</div>';
        // Section content — view + edit
        html += '<div class="card-body-section-content journey-section-content-view">' + simpleMarkdown(sec.content || '', true) + '</div>';
        html += '<textarea class="edit-only journey-section-content-edit" data-journey-id="' + nodeId + '"' +
            ' data-section-name="' + escapeAttr(sec.name) + '" onblur="onJourneySectionContentBlur(this)"' +
            ' style="width:100%;min-height:120px;font-size:0.8rem;border:1px solid var(--border-color);border-radius:4px;padding:6px;resize:vertical;background:var(--card-bg);color:var(--input-text);">' +
            escapeHtml(sec.content || '') + '</textarea>';
        html += '</div>';
    });
    html += '<button class="edit-only journey-section-add-btn" onclick="onAddJourneySection(\'' + nodeId + '\')">+ Add Section</button>';
    html += '</div>';

    html += '</div>'; // end req-card-body
    html += '</div>'; // end req-card

    return html;
}

// =====================================================================
// Generic Card — fallback for TEST, CODE, RESULT, etc.
// =====================================================================

function buildGenericCardHtml(nodeId, data, collapsed) {
    var collapsedClass = collapsed ? ' collapsed' : '';
    var focusedClass = editState.openCardOrder[0] === nodeId ? ' focused' : '';
    var title = escapeHtml(data.title || nodeId);
    var kind = data.kind || 'unknown';
    var kindLabel = kind.charAt(0).toUpperCase() + kind.slice(1);
    var props = data.properties || {};
    var sourcePath = (data.source && data.source.path) || '';
    var sourceLine = (data.source && data.source.line) || 0;

    var html = '<div class="req-card' + collapsedClass + focusedClass + '" id="card-' + nodeId + '">';

    // Header
    html += '<div class="req-card-header" onclick="toggleCardCollapse(\'' + nodeId + '\')">';
    html += '<span class="req-card-expand">&#9660;</span>';
    html += '<span class="req-card-id">' + escapeHtml(kindLabel) + '</span>';
    html += '<span class="req-card-title-display">' + title + '</span>';
    html += '<button class="req-card-close" onclick="event.stopPropagation(); closeCard(\'' + nodeId + '\')" title="Close card">&times;</button>';
    html += '</div>';

    // Body
    html += '<div class="req-card-body">';

    // Source
    if (sourcePath) {
        html += '<div class="card-section"><div class="card-section-label">Source</div>';
        html += '<div class="card-meta"><div class="card-meta-item">';
        html += '<a class="card-meta-value" href="#" onclick="event.preventDefault(); showSource(\'' +
            escapeHtml(sourcePath) + '\', ' + sourceLine + ')" ' +
            'style="color:#0d6efd;cursor:pointer;font-size:0.75rem;text-decoration:none;">' +
            escapeHtml(sourcePath.split('/').pop()) + ':' + sourceLine + '</a>';
        html += '</div></div></div>';
    }

    // Properties as key-value pairs
    var propKeys = Object.keys(props);
    if (propKeys.length > 0) {
        html += '<div class="card-section"><div class="card-section-label">Properties</div>';
        html += '<div class="card-meta">';
        propKeys.forEach(function(key) {
            var val = props[key];
            if (val === null || val === undefined || val === '') return;
            html += '<div class="card-meta-item">';
            html += '<span class="card-meta-key">' + escapeHtml(key) + ':</span>';
            html += '<span class="card-meta-value">' + escapeHtml(String(val)) + '</span>';
            html += '</div>';
        });
        html += '</div></div>';
    }

    // Links
    var links = data.links || [];
    if (links.length > 0) {
        html += '<div class="card-section"><div class="card-section-label">Links (' + links.length + ')</div>';
        html += '<div class="card-parents">';
        links.forEach(function(link) {
            html += '<a class="card-parent-link" href="#" onclick="event.preventDefault(); openCard(\'' + link.id + '\')">';
            html += '<span class="card-parent-kind">' + escapeHtml(link.edge_kind || '') + '</span> ';
            html += escapeHtml(link.id);
            if (link.title) html += ' - ' + escapeHtml(link.title);
            html += '</a>';
        });
        html += '</div></div>';
    }

    html += '</div>'; // end req-card-body
    html += '</div>'; // end req-card

    return html;
}

// =====================================================================
// Simple Markdown Renderer (for journey body text)
// =====================================================================

// Implements: REQ-d00245-A
function simpleMarkdown(text, annotateTerms) {
    // Escape HTML first, then add minimal formatting
    var lines = text.split('\n');
    var result = [];
    for (var i = 0; i < lines.length; i++) {
        var line = escapeHtml(lines[i]);
        // Bold: **text**
        line = line.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
        // Headers: ## text -> bold
        line = line.replace(/^(#{1,3})\s+(.+)$/, '<strong>$2</strong>');
        // Numbered steps: 1. text
        line = line.replace(/^(\d+)\.\s+/, '<strong>$1.</strong> ');
        // Bullet items: - text
        line = line.replace(/^(\s*)-\s+/, '$1&bull; ');
        result.push(line);
    }
    var output = result.join('\n');

    // Term annotation pass (after markdown transforms)
    if (annotateTerms && editState.termsLookup && Object.keys(editState.termsLookup).length > 0) {
        if (!editState.termsRegex) {
            _buildTermsRegex();
        }
        if (editState.termsRegex) {
            output = output.replace(editState.termsRegex, function(match) {
                var key = match.toLowerCase();
                var entry = editState.termsLookup[key];
                if (!entry) return match;
                var tip = entry.definition_short || entry.definition || '';
                if (tip.length > 80) tip = tip.substring(0, 80) + '...';
                return '<span class="defined-term" data-term-key="' + escapeAttr(key) +
                    '" data-tip="' + escapeAttr(tip) + '">' + match + '</span>';
            });
        }
    }

    return output;
}

function _buildTermsRegex() {
    var keys = Object.keys(editState.termsLookup);
    if (keys.length === 0) { editState.termsRegex = null; return; }
    // Sort longest-first to avoid partial matches
    keys.sort(function(a, b) { return b.length - a.length; });
    // Escape regex special chars and build alternation
    var escaped = keys.map(function(k) {
        return k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    });
    // Word-boundary anchored, case-insensitive
    editState.termsRegex = new RegExp('\\b(' + escaped.join('|') + ')\\b', 'gi');
}

// Implements: REQ-d00245-B — delegated click handler for .defined-term spans
document.addEventListener('DOMContentLoaded', function() {
    var body = document.getElementById('card-stack-body');
    if (body) {
        body.addEventListener('click', function(e) {
            var span = e.target.closest('.defined-term');
            if (span) {
                e.preventDefault();
                var key = span.getAttribute('data-term-key');
                if (key) openTermCard(key);
            }
        });
    }
});

