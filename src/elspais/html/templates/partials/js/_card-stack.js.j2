function renderAssertionResults(panel, reqId, label, data) {
    var assertionData = data.assertion_tests[label];
    if (!assertionData) {
        panel.innerHTML = '<div class="assertion-tests-empty">No data for this assertion</div>';
        return;
    }

    // Collect all results across all tests
    var resultItems = [];
    var tests = assertionData.tests;
    for (var i = 0; i < tests.length; i++) {
        var t = tests[i];
        if (t.results && t.results.length > 0) {
            for (var j = 0; j < t.results.length; j++) {
                resultItems.push({ result: t.results[j], testLabel: t.label || t.id });
            }
        }
    }

    if (resultItems.length === 0) {
        panel.innerHTML = '<div class="assertion-tests-empty">No test results for this assertion</div>';
        return;
    }

    var html = '';
    for (var k = 0; k < resultItems.length; k++) {
        var r = resultItems[k].result;
        var tLabel = resultItems[k].testLabel;
        var status = (r.status || '').toLowerCase();
        var statusIcon = '';
        var statusClass = '';
        if (status === 'passed' || status === 'pass' || status === 'success') {
            statusIcon = '&#x2705;'; statusClass = 'test-passed';
        } else if (status === 'failed' || status === 'fail' || status === 'failure' || status === 'error') {
            statusIcon = '&#x274C;'; statusClass = 'test-failed';
        } else {
            statusIcon = '&#x2753;'; statusClass = '';
        }

        html += '<div class="assertion-test-item ' + statusClass + '">';
        html += '<span class="assertion-test-icon">' + statusIcon + '</span>';
        if (r.file) {
            html += '<a class="assertion-test-link" href="#" onclick="event.preventDefault(); showSource(\'' +
                escapeHtml(r.file) + '\', ' + (r.line || 0) + ')">' +
                escapeHtml(tLabel) + ' [' + escapeHtml(r.status) + ']</a>';
        } else {
            html += '<span class="assertion-test-link">' + escapeHtml(tLabel) + ' [' + escapeHtml(r.status) + ']</span>';
        }
        html += '</div>';
    }
    panel.innerHTML = html;
}

// Shared helper: classify test/journey coverage into a state class
function _classifyTestState(items) {
    // items = array of test/journey objects with .results arrays
    // Returns: 'validation-pass', 'validation-partial', 'validation-fail', or 'validation-unknown'
    if (items.length === 0) return 'validation-fail';
    var allResults = [];
    for (var j = 0; j < items.length; j++) {
        if (items[j].results) {
            for (var k = 0; k < items[j].results.length; k++) {
                allResults.push(items[j].results[k].status);
            }
        }
    }
    if (allResults.length === 0) return 'validation-unknown'; // exists but no results = unknown
    var allPassed = allResults.every(function(s) { return s === 'passed'; });
    var anyFailed = allResults.some(function(s) { return s === 'failed' || s === 'failure' || s === 'error'; });
    if (allPassed) return 'validation-pass';
    if (anyFailed) return 'validation-partial';
    return 'validation-pass'; // unknown statuses (skipped) = covered
}

function updateAllTestedButtons(reqId, data) {
    // TESTED: do tests exist for this assertion? (yes/no, same CSS as implemented)
    var buttons = document.querySelectorAll('.assertion-tested-btn[data-req-id="' + reqId + '"]');
    for (var i = 0; i < buttons.length; i++) {
        var btn = buttons[i];
        var label = btn.dataset.label;
        var assertionData = data.assertion_tests[label];
        if (!assertionData) continue;
        btn.classList.remove('implemented-yes', 'implemented-no');
        btn.classList.add(assertionData.tests.length > 0 ? 'implemented-yes' : 'implemented-no');
    }
}

function updateAllVerifiedButtons(reqId, data) {
    // VERIFIED: do test results pass? (pass/partial/fail)
    var buttons = document.querySelectorAll('.assertion-verified-btn[data-req-id="' + reqId + '"]');
    for (var i = 0; i < buttons.length; i++) {
        var btn = buttons[i];
        var label = btn.dataset.label;
        var assertionData = data.assertion_tests[label];
        if (!assertionData) continue;
        btn.classList.remove('validation-pass', 'validation-partial', 'validation-fail', 'validation-unknown');
        btn.classList.add(_classifyTestState(assertionData.tests));
    }
}

