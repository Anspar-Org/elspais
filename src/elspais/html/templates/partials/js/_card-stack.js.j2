    var buttons = document.querySelectorAll('.assertion-accepted-btn[data-req-id="' + reqId + '"]');
    for (var i = 0; i < buttons.length; i++) {
        var btn = buttons[i];
        var label = btn.dataset.label;
        var assertionData = data.assertion_journeys[label];
        if (!assertionData) continue;
        btn.classList.remove('validation-pass', 'validation-partial', 'validation-fail', 'validation-unknown');
        btn.classList.add(_classifyTestState(assertionData.journeys));
    }
}

// =====================================================================
// Assertion UAT Results — Journey Result Files (ACC badge)
// =====================================================================

async function toggleAssertionUatResults(btn, reqId, label) {
    var panelId = 'assertion-uat-results-' + reqId + '-' + label;
    var panel = document.getElementById(panelId);
    if (!panel) return;

    if (panel.style.display !== 'none') {
        panel.style.display = 'none';
        btn.classList.remove('active');
        return;
    }

    panel.style.display = 'block';
    btn.classList.add('active');

    if (!assertionUatCache[reqId]) {
        panel.innerHTML = '<div class="assertion-tests-loading">Loading...</div>';
        var data = await apiFetch('/api/uat-coverage/' + encodeURIComponent(reqId));
        if (!data || !data.success) {
            panel.innerHTML = '<div class="assertion-tests-loading">Failed to load UAT results</div>';
            return;
        }
        assertionUatCache[reqId] = data;
        updateAllValidatedButtons(reqId, data);
        updateAllAcceptedButtons(reqId, data);
    }

    renderAssertionUatResults(panel, reqId, label, assertionUatCache[reqId]);
}

function renderAssertionUatResults(panel, reqId, label, data) {
    var assertionData = data.assertion_journeys[label];
    if (!assertionData) {
        panel.innerHTML = '<div class="assertion-tests-empty">No data for this assertion</div>';
        return;
    }

    var resultItems = [];
    var journeys = assertionData.journeys;
    for (var i = 0; i < journeys.length; i++) {
        var j = journeys[i];
        if (j.results && j.results.length > 0) {
            for (var k = 0; k < j.results.length; k++) {
                resultItems.push({ result: j.results[k], jnyLabel: j.label || j.id, jnyId: j.id });
            }
        }
    }

    if (resultItems.length === 0) {
        panel.innerHTML = '<div class="assertion-tests-empty">No journey results for this assertion</div>';
        return;
    }

    var html = '';
    for (var r = 0; r < resultItems.length; r++) {
        var res = resultItems[r].result;
        var jLabel = resultItems[r].jnyLabel;
        var status = (res.status || '').toLowerCase();
        var statusIcon = '', statusClass = '';
        if (status === 'passed' || status === 'pass' || status === 'success') {
            statusIcon = '&#x2705;'; statusClass = 'test-passed';
        } else if (status === 'failed' || status === 'fail' || status === 'failure' || status === 'error') {
            statusIcon = '&#x274C;'; statusClass = 'test-failed';
        } else {
            statusIcon = '&#x2753;';
        }

        html += '<div class="assertion-test-item ' + statusClass + '">';
        html += '<span class="assertion-test-icon">' + statusIcon + '</span>';
        if (res.file) {
            html += '<a class="assertion-test-link" href="#" onclick="event.preventDefault(); showSource(\'' +
                escapeHtml(res.file) + '\', ' + (res.line || 0) + ')">' +
                escapeHtml(jLabel) + ' [' + escapeHtml(res.status) + ']</a>';
        } else {
            html += '<a class="assertion-test-link" href="#" onclick="event.preventDefault(); openCard(\'' +
                escapeHtml(resultItems[r].jnyId) + '\')">' +
                escapeHtml(jLabel) + ' [' + escapeHtml(res.status) + ']</a>';
        }
        html += '</div>';
    }
    panel.innerHTML = html;
}

// =====================================================================
// REQ-Level Link Expansion (header badge click)
// =====================================================================

function toggleReqLevelLinks(badge, reqId, dimKey, assertLinkKey) {
    var panelId = 'req-links-' + reqId + '-' + dimKey;
    var panel = document.getElementById(panelId);

    if (panel && panel.style.display !== 'none') {
        // Closing — just hide, no flash/scroll
        panel.style.display = 'none';
        return;
    }

    // Opening — flash assertions that have direct links
    _flashAssertions(reqId, assertLinkKey || dimKey);

    if (!panel) return;

    // Find the card data from editState
    var cardState = editState.openCards.get(reqId);
    if (!cardState || !cardState.data || !cardState.data.req_level_links) {
        return; // no panel to show, flash was enough
    }

    var links = cardState.data.req_level_links[dimKey] || [];
    if (links.length === 0) {
        return; // no REQ-level links, flash was enough
    }

    var html = '';
    for (var i = 0; i < links.length; i++) {
        var link = links[i];
        // Result status icon for TEST/JNY nodes
        var statusIcon = '';
        if (link.result_status === 'passed') statusIcon = '&#x2705; ';
        else if (link.result_status === 'failed') statusIcon = '&#x274C; ';
        else if (link.result_status === 'mixed') statusIcon = '&#x26A0; ';

        var statusClass = '';
        if (link.result_status === 'failed') statusClass = ' test-failed';
        else if (link.result_status === 'passed') statusClass = ' test-passed';

        if (link.kind === 'journey') {
            html += '<div class="assertion-test-item' + statusClass + '">';
            html += '<span class="assertion-test-icon">' + statusIcon + '&#x1F4D6;</span>';
            html += '<a class="assertion-test-link" href="#" onclick="event.preventDefault(); openCard(\'' +
                escapeHtml(link.id) + '\')">' + escapeHtml(link.title) + '</a>';
            html += '</div>';
        } else {
            var icon = link.kind === 'requirement' ? '&#x1F4CB;' : (link.kind === 'test' ? '&#x1F9EA;' : '&#x1F4C4;');
            html += '<div class="assertion-test-item' + statusClass + '">';
            html += '<span class="assertion-test-icon">' + statusIcon + icon + '</span>';
            if (link.file) {
                html += '<a class="assertion-test-link" href="#" onclick="event.preventDefault(); showSource(\'' +
                    escapeHtml(link.file) + '\', ' + (link.line || 0) + ')">' + escapeHtml(link.title) + '</a>';
            } else {
                html += '<a class="assertion-test-link" href="#" onclick="event.preventDefault(); openCard(\'' +
                    escapeHtml(link.id) + '\')">' + escapeHtml(link.title) + '</a>';
            }
            html += '</div>';
        }
    }
    panel.innerHTML = html;
    panel.style.display = 'block';
}

function _flashAssertionsByLabel(reqId, labels) {
    // Flash specific assertion labels (e.g., ["A", "B"]) on a card
    if (!labels || labels.length === 0) return;
    var card = document.getElementById('card-' + reqId);
    if (!card) return;

    var targets = [];
    var wrappers = card.querySelectorAll('.card-assertion-wrapper');
    for (var i = 0; i < wrappers.length; i++) {
        var assertionDiv = wrappers[i].querySelector('.card-assertion');
        if (!assertionDiv) continue;
        var labelEl = assertionDiv.querySelector('.card-assertion-label');
        if (labelEl && labels.indexOf(labelEl.textContent.trim()) >= 0) {
            targets.push(assertionDiv);
        }
    }

    if (targets.length > 0) {
        targets[0].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    setTimeout(function() {
        for (var j = 0; j < targets.length; j++) {
            targets[j].style.transition = 'none';
            targets[j].style.backgroundColor = 'rgba(13, 110, 253, 0.3)';
        }
        setTimeout(function() {
            for (var j = 0; j < targets.length; j++) {
                targets[j].style.transition = 'background-color 1s ease-out';
                targets[j].style.backgroundColor = '';
            }
        }, 400);
    }, 50);
}

async function openCardAndFlash(targetId, assertionTargets) {
    await openCard(targetId);
    if (assertionTargets && assertionTargets.length > 0) {
        // Small delay to ensure card DOM is rendered
        setTimeout(function() { _flashAssertionsByLabel(targetId, assertionTargets); }, 150);
    }
}

function _flashAssertions(reqId, assertLinkKey) {
    // Find card data to get assertion_links
    var cardState = editState.openCards.get(reqId);
    if (!cardState || !cardState.data || !cardState.data.assertion_links) return;

    var aLinks = cardState.data.assertion_links;
    var card = document.getElementById('card-' + reqId);
    if (!card) return;

    // Collect matching .card-assertion elements (they have the visible background)
    var targets = [];
    for (var label in aLinks) {
        if (!aLinks[label][assertLinkKey]) continue;
        var wrappers = card.querySelectorAll('.card-assertion-wrapper');
        for (var i = 0; i < wrappers.length; i++) {
            var assertionDiv = wrappers[i].querySelector('.card-assertion');
            if (!assertionDiv) continue;
            var labelEl = assertionDiv.querySelector('.card-assertion-label');
            if (labelEl && labelEl.textContent.trim() === label) {
                targets.push(assertionDiv);
            }
        }
    }

    if (targets.length > 0) {
        targets[0].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // Use inline style flash (same pattern as file-viewer line flash)
    setTimeout(function() {
        for (var j = 0; j < targets.length; j++) {
            targets[j].style.transition = 'none';
            targets[j].style.backgroundColor = 'rgba(13, 110, 253, 0.3)';
        }
        setTimeout(function() {
            for (var j = 0; j < targets.length; j++) {
                targets[j].style.transition = 'background-color 1s ease-out';
                targets[j].style.backgroundColor = '';
            }
        }, 400);
    }, 50);
}

// =====================================================================
// Term Cards (Implements: REQ-d00244-A, REQ-d00244-B, REQ-d00244-C)
// =====================================================================

async function openTermCard(termKey) {
    var cardId = 'term:' + termKey.toLowerCase();
    editState.focusNodeId = cardId;

    if (editState.openCards.has(cardId)) {
        focusCard(cardId);
        return;
    }

    var data = await apiFetch('/api/term/' + encodeURIComponent(termKey));
    if (!data) return;

    editState.openCards.set(cardId, { data: data, collapsed: false, kind: 'term', refsCollapsed: data.references && data.references.length > 20 });
    editState.openCardOrder = editState.openCardOrder.filter(function(id) { return id !== cardId; });
    editState.openCardOrder.unshift(cardId);

    renderCardStack();
    focusCard(cardId);
    updateNavSelection();
    saveState();
}

function toggleTermRefs(cardId) {
    var cardState = editState.openCards.get(cardId);
    if (!cardState) return;
    cardState.refsCollapsed = !cardState.refsCollapsed;
    var el = document.getElementById('term-refs-' + cardId);
    if (el) el.style.display = cardState.refsCollapsed ? 'none' : 'block';
    saveState();
}

function buildTermCardHtml(cardId, data, collapsed) {
    var collapsedClass = collapsed ? ' collapsed' : '';
    var focusedClass = editState.openCardOrder[0] === cardId ? ' focused' : '';
    var termName = escapeHtml(data.term || '');
    var collectionBadge = data.collection ? ' <span class="term-collection-badge">Collection</span>' : '';

    var html = '<div class="req-card term-card' + collapsedClass + focusedClass + '" id="card-' + escapeAttr(cardId) + '">';

    // Header (read-only, no edit controls)
    html += '<div class="req-card-header" onclick="toggleCardCollapse(\'' + escapeAttr(cardId) + '\')">';
    html += '<span class="req-card-expand">&#9660;</span>';
    html += '<span class="req-card-id" style="color:var(--secondary-text);">Term</span>';
    html += '<span class="req-card-title-display">' + termName + collectionBadge + '</span>';
    html += '<button class="req-card-close" onclick="event.stopPropagation(); closeCard(\'' + escapeAttr(cardId) + '\')" title="Close card">&times;</button>';
    html += '</div>';

    // Body
    html += '<div class="req-card-body">';

    // Definition section
    html += '<div class="card-section"><div class="card-section-label">Definition</div>';
    html += '<div class="term-definition">' + simpleMarkdown(data.definition || '') + '</div>';
    html += '</div>';

    // Source section
    html += '<div class="card-section"><div class="card-section-label">Source</div>';
    html += '<div class="card-meta">';
    if (data.defined_in) {
        html += '<div class="card-meta-item"><span class="card-meta-key">Defined in:</span>';
        html += '<a class="card-meta-value" href="#" onclick="event.preventDefault(); openCard(\'' + escapeAttr(data.defined_in) + '\')">' + escapeHtml(data.defined_in) + '</a>';
        html += '</div>';
    }
    if (data.namespace) {
        html += '<div class="card-meta-item"><span class="card-meta-key">Namespace:</span>';
        html += '<span class="card-meta-value">' + escapeHtml(data.namespace) + '</span>';
        html += '</div>';
    }
    html += '</div></div>';

    // References section (collapsible)
    var refs = data.references || [];
    var refSectionId = 'term-refs-' + escapeAttr(cardId);
    html += '<div class="card-section term-references">';
    var refsHidden = false;
    var cardState = editState.openCards.get(cardId);
    if (cardState && cardState.refsCollapsed !== undefined) {
        refsHidden = cardState.refsCollapsed;
    } else {
        refsHidden = refs.length > 20;
    }
    html += '<div class="card-section-label" style="cursor:pointer;user-select:none;" onclick="toggleTermRefs(\'' + escapeAttr(cardId) + '\')">';
    html += '<span style="font-size:0.7rem;margin-right:4px;">&#9660;</span>References (' + refs.length + ')</div>';
    html += '<div id="' + refSectionId + '"' + (refsHidden ? ' style="display:none"' : '') + '>';
    if (refs.length === 0) {
        html += '<div style="padding:8px;color:var(--secondary-text);font-size:0.8rem;font-style:italic;">No references resolved yet</div>';
    } else {
        // Separate file refs from non-file refs, group file refs by path
        var fileGroups = {};  // file_path -> [{line, fp}]
        var fileGroupOrder = [];
        var nonFileRefs = [];
        for (var ri = 0; ri < refs.length; ri++) {
            var ref = refs[ri];
            var nid = ref.node_id;
            var filePath = ref.file_path;
            var fileMatch = nid.match(/^(?:rem|code|test|file):(.+?)(?::(\d+))?$/);
            if (fileMatch || filePath) {
                var fp = filePath || fileMatch[1];
                if (!fileGroups[fp]) { fileGroups[fp] = []; fileGroupOrder.push(fp); }
                fileGroups[fp].push({ line: ref.line || 1, ref: ref });
            } else {
                nonFileRefs.push(ref);
            }
        }
        // Sort non-file refs by node_id then line number numerically
        nonFileRefs.sort(function(a, b) {
            if (a.node_id < b.node_id) return -1;
            if (a.node_id > b.node_id) return 1;
            return (a.line || 0) - (b.line || 0);
        });
        // Sort file groups by path
        fileGroupOrder.sort();

        html += '<div class="term-ref-compact" style="padding:6px 8px;line-height:1.8;">';
        // Non-file refs (requirements, assertions, journeys)
        for (var ri = 0; ri < nonFileRefs.length; ri++) {
            var ref = nonFileRefs[ri];
            var nid = ref.node_id;
            var ncClass = ref.canonical === false ? ' term-ref-noncanonical' : '';
            if (ref.parent_req_id) {
                var assertLabel = nid.substring(ref.parent_req_id.length + 1);
                html += '<a class="term-ref-chip' + ncClass + '" href="#" onclick="event.preventDefault();openCardAndFlash(\'' + escapeAttr(ref.parent_req_id) + '\',[\'' + escapeAttr(assertLabel) + '\'])"';
                html += ' title="' + escapeAttr(nid + (ref.node_title ? ' - ' + ref.node_title : '') + ' L' + ref.line) + '">';
                html += escapeHtml(nid);
                html += '<sub>' + ref.line + '</sub>';
                html += '</a>';
            } else {
                html += '<a class="term-ref-chip' + ncClass + '" href="#" onclick="event.preventDefault();openCard(\'' + escapeAttr(nid) + '\')"';
                html += ' title="' + escapeAttr(nid + (ref.node_title ? ' - ' + ref.node_title : '') + ' L' + ref.line) + '">';
                html += escapeHtml(nid);
                html += '<sub>' + ref.line + '</sub>';
                html += '</a>';
            }
        }
        // File refs grouped by path: each on its own line, path once then line numbers as links
        for (var fi = 0; fi < fileGroupOrder.length; fi++) {
            var fp = fileGroupOrder[fi];
            var lines = fileGroups[fp].slice().sort(function(a, b) { return a.line - b.line; });
            html += '<div class="term-ref-file-group">';
            html += '<span class="term-ref-chip term-ref-file" style="cursor:default;">';
            html += escapeHtml(fp) + '</span>';
            for (var li = 0; li < lines.length; li++) {
                var ln = lines[li].line;
                var lnNcClass = lines[li].ref && lines[li].ref.canonical === false ? ' term-ref-noncanonical' : '';
                html += '<a class="term-ref-file-line' + lnNcClass + '" href="#" onclick="event.preventDefault();showSource(\'' + escapeAttr(fp) + '\',' + ln + ')"';
                html += ' title="' + escapeAttr(fp + ':' + ln) + '">';
                html += ln + '</a>';
                if (li < lines.length - 1) html += ', ';
            }
            html += '</div>';
        }
        html += '</div>';
    }
    html += '</div></div>';

    html += '</div>'; // end req-card-body
    html += '</div>'; // end req-card

    return html;
}
