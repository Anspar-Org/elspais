function onJourneySectionNameBlur(input) {
    var journeyId = input.dataset.journeyId;
    var originalName = input.dataset.originalName;
    var newName = input.value.trim();
    if (!newName || newName === originalName) { input.value = originalName; return; }
    mutate('/api/mutate/journey/section', {
        node_id: journeyId, action: 'update', name: originalName, new_name: newName
    }).then(function(r) {
        if (r && r.success) {
            input.dataset.originalName = newName;
            input.defaultValue = newName;
            // Update view-mode name and data attributes
            var section = input.closest('.journey-section');
            if (section) {
                section.dataset.sectionName = newName;
                var viewName = section.querySelector('.journey-section-name-view');
                if (viewName) viewName.textContent = newName;
                // Update content textarea data attribute
                var contentTA = section.querySelector('.journey-section-content-edit');
                if (contentTA) contentTA.dataset.sectionName = newName;
            }
        } else { input.value = originalName; }
    });
}

