function onJourneyTitleBlur(journeyId, input) {
    var original = input.defaultValue;
    var newVal = input.value.trim();
    if (!newVal || newVal === original) { input.value = original; return; }
    mutate('/api/mutate/title', { node_id: journeyId, new_title: newVal }).then(function(r) {
        if (r && r.success) {
            input.defaultValue = newVal;
            // Update view-mode title
            var card = input.closest('.journey-card');
            if (card) {
                var viewTitle = card.querySelector('.journey-title-view');
                if (viewTitle) viewTitle.textContent = newVal;
            }
        } else { input.value = original; }
    });
}

function onJourneyFieldBlur(input) {
    var journeyId = input.dataset.journeyId;
    var field = input.dataset.field;
    var original = input.defaultValue;
    var newVal = input.value.trim();
    if (newVal === original) return;
    mutate('/api/mutate/journey/field', { node_id: journeyId, field: field, value: newVal }).then(function(r) {
        if (r && r.success) {
            input.defaultValue = newVal;
            // Update view-mode span
            var item = input.closest('.journey-meta-item');
            if (item) {
                var viewSpan = item.querySelector('.journey-field-view');
                if (viewSpan) viewSpan.textContent = newVal;
            }
        } else { input.value = original; }
    });
}

function onJourneyPreambleBlur(textarea) {
    var journeyId = textarea.dataset.journeyId;
    var original = textarea.defaultValue;
    var newVal = textarea.value;
    if (newVal === original) return;
    mutate('/api/mutate/journey/field', { node_id: journeyId, field: 'preamble', value: newVal }).then(function(r) {
        if (r && r.success) {
            textarea.defaultValue = newVal;
            var viewDiv = textarea.parentNode.querySelector('.journey-preamble-view');
