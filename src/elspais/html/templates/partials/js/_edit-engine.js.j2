function showCheckpointModal() {
    // Guard: prompt to save if unsaved mutations
    if (editState.mutationCount > 0) {
        if (!confirm('You have ' + editState.mutationCount + ' unsaved changes. Save before checkpointing?')) {
            return;
        }
        apiFetch('/api/save', {method: 'POST'}).then(function(saveResult) {
            if (saveResult && saveResult.success !== false) {
                refreshDirtyCount();
                _openCheckpointModal();
            } else {
                showErrorModal('Save failed', (saveResult && saveResult.error) || 'Unknown error');
            }
        });
        return;
    }
    _openCheckpointModal();
}

function _openCheckpointModal() {
    var checkpointBtn = document.getElementById('btn-checkpoint');
    if (checkpointBtn) { checkpointBtn.disabled = true; checkpointBtn.textContent = 'Loading...'; }

    apiFetch('/api/git/status').then(function(data) {
        if (checkpointBtn) { checkpointBtn.disabled = false; checkpointBtn.textContent = 'Checkpoint'; }
        if (!data) return;
        var specFiles = data.dirty_spec_files || [];
        var otherFiles = data.dirty_other_files || [];
        var allFiles = specFiles.concat(otherFiles);
        if (allFiles.length === 0) {
            showToast('No uncommitted files', 'info');
            return;
        }

        var old = document.getElementById('branch-modal-overlay');
        if (old) old.remove();

        // Build file list with checkboxes — spec files pre-checked, others unchecked
        var fileListHtml = '';
        if (specFiles.length > 0) {
            fileListHtml += '<div class="modal-file-group-label">Spec files</div>';
            specFiles.forEach(function(f, i) {
                fileListHtml += '<label class="modal-file-checkbox"><input type="checkbox" checked data-file="' + escapeHtml(f) + '" class="checkpoint-file-cb"> ' + escapeHtml(f) + '</label>';
            });
        }
        if (otherFiles.length > 0) {
            fileListHtml += '<div class="modal-file-group-label" style="margin-top:8px;">Other files</div>';
            otherFiles.forEach(function(f) {
                fileListHtml += '<label class="modal-file-checkbox"><input type="checkbox" data-file="' + escapeHtml(f) + '" class="checkpoint-file-cb"> ' + escapeHtml(f) + '</label>';
            });
        }

        var overlay = document.createElement('div');
        overlay.id = 'branch-modal-overlay';
        overlay.className = 'modal-overlay visible';
        overlay.innerHTML =
            '<div class="modal-dialog">' +
                '<div class="modal-title">Checkpoint</div>' +
                '<div class="modal-label">Branch: <strong>' + escapeHtml(data.branch || '(detached)') + '</strong></div>' +
                '<div class="modal-label" style="margin-top:12px">Files to include:</div>' +
                '<div class="modal-file-list">' + fileListHtml + '</div>' +
                '<label class="modal-label" style="margin-top:12px">Commit message:</label>' +
                '<textarea class="modal-input" id="checkpoint-message-input" rows="4" placeholder="Describe this checkpoint..." style="resize:vertical;font-family:monospace;font-size:12px;"></textarea>' +
                '<div class="modal-error hidden" id="checkpoint-modal-error"></div>' +
                '<div class="modal-actions">' +
                    '<button class="btn btn-warning" id="checkpoint-modal-confirm" disabled>Checkpoint</button>' +
                    '<button class="btn" id="checkpoint-modal-cancel">Cancel</button>' +
                '</div>' +
            '</div>';
        document.body.appendChild(overlay);

        var textarea = document.getElementById('checkpoint-message-input');
        var confirmBtn = document.getElementById('checkpoint-modal-confirm');
        var errorEl = document.getElementById('checkpoint-modal-error');

        function getSelectedFiles() {
            var checked = [];
            overlay.querySelectorAll('.checkpoint-file-cb:checked').forEach(function(cb) {
                checked.push(cb.dataset.file);
            });
            return checked;
        }

        function updateConfirmState() {
            var hasFiles = getSelectedFiles().length > 0;
            var hasMsg = textarea.value.trim() !== '';
            confirmBtn.disabled = !hasFiles || !hasMsg;
        }

        // Update confirm state when checkboxes change
        overlay.querySelectorAll('.checkpoint-file-cb').forEach(function(cb) {
            cb.addEventListener('change', updateConfirmState);
        });

        // Auto-generate commit message from server
        apiFetch('/api/git/commit-message').then(function(msgData) {
            if (msgData && msgData.message) {
                textarea.value = msgData.message;
            } else {
                textarea.value = specFiles.join('\n');
            }
            updateConfirmState();
        });

        textarea.addEventListener('input', updateConfirmState);
        textarea.focus();

        function doCheckpoint() {
            var msg = textarea.value.trim();
            var selectedFiles = getSelectedFiles();
            if (!msg || selectedFiles.length === 0) return;
            confirmBtn.disabled = true;
            confirmBtn.textContent = 'Committing...';
            showLoadingOverlay('Creating checkpoint...');
            apiFetch('/api/git/commit', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({message: msg, files: selectedFiles})
            }).then(function(result) {
                hideLoadingOverlay();
                if (result && result.success) {
                    overlay.remove();
                    showToast('Checkpoint created', 'success');
                    refreshBranchStatus();
                    refreshDirtyCount();
                } else {
                    overlay.remove();
                    showErrorModal('Checkpoint failed', (result && result.error) || 'Unknown error');
                    confirmBtn.disabled = false;
                    confirmBtn.textContent = 'Checkpoint';
                }
            });
        }

        confirmBtn.onclick = doCheckpoint;
        document.getElementById('checkpoint-modal-cancel').onclick = function() { overlay.remove(); };
        overlay.addEventListener('click', function(e) { if (e.target === overlay) overlay.remove(); });
        textarea.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') overlay.remove();
            if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) doCheckpoint();
        });
    });
}

// =====================================================================
// Slide-to-Share Widget
// =====================================================================

function initShareSlider() {
    var shareBtn = document.getElementById('btn-share');
    if (!shareBtn) return;

    shareBtn.onclick = function(e) {
        if (shareBtn.disabled) return;
        e.stopPropagation();

        // Replace button with track
        var track = document.createElement('div');
        track.className = 'share-track';
        track.id = 'share-track';

        var fill = document.createElement('div');
        fill.className = 'share-fill';
        track.appendChild(fill);

        var handle = document.createElement('div');
        handle.className = 'share-handle';
        handle.textContent = 'Share \u2192';
        track.appendChild(handle);

        var dest = document.createElement('div');
        dest.className = 'share-destination';
        dest.textContent = 'origin';
        track.appendChild(dest);

        shareBtn.style.display = 'none';
        shareBtn.parentNode.insertBefore(track, shareBtn.nextSibling);

        var trackWidth = track.offsetWidth;
        var handleWidth = handle.offsetWidth;
        var maxLeft = trackWidth - handleWidth - 6;
        var threshold = maxLeft * 0.9;
        var dragging = false;
        var startX = 0;
        var currentLeft = 0;

        var collapseTimeout = setTimeout(collapseTrack, 3000);

        function onStart(clientX) {
            dragging = true;
            startX = clientX - currentLeft;
            handle.classList.add('dragging');
            fill.classList.add('dragging');
            clearTimeout(collapseTimeout);
        }
        function onMove(clientX) {
            if (!dragging) return;
            var newLeft = Math.max(0, Math.min(clientX - startX, maxLeft));
            currentLeft = newLeft;
            handle.style.left = (3 + newLeft) + 'px';
            fill.style.width = newLeft + 'px';
        }
        function onEnd() {
            if (!dragging) return;
            dragging = false;
            handle.classList.remove('dragging');
            fill.classList.remove('dragging');
            if (currentLeft >= threshold) {
                handle.style.left = (3 + maxLeft) + 'px';
                fill.style.width = maxLeft + 'px';
                handle.textContent = 'Sharing...';
                handle.classList.add('sharing');
                doPush();
            } else {
                currentLeft = 0;
                handle.style.left = '3px';
                fill.style.width = '0';
                collapseTimeout = setTimeout(collapseTrack, 3000);
            }
        }

        // Mouse events
        handle.addEventListener('mousedown', function(e) { e.preventDefault(); onStart(e.clientX); });
        var onMM = function(e) {
            if (!document.getElementById('share-track')) { document.removeEventListener('mousemove', onMM); return; }
            onMove(e.clientX);
        };
        var onMU = function() {
            if (!document.getElementById('share-track')) { document.removeEventListener('mouseup', onMU); return; }
            onEnd();
        };
        document.addEventListener('mousemove', onMM);
        document.addEventListener('mouseup', onMU);

        // Touch events
        handle.addEventListener('touchstart', function(e) { e.preventDefault(); onStart(e.touches[0].clientX); });
        handle.addEventListener('touchmove', function(e) { e.preventDefault(); onMove(e.touches[0].clientX); });
        handle.addEventListener('touchend', onEnd);

        function collapseTrack() {
            if (track.parentNode) track.remove();
            shareBtn.style.display = '';
            document.removeEventListener('mousemove', onMM);
            document.removeEventListener('mouseup', onMU);
        }

        function doPush() {
            apiFetch('/api/git/push', {method: 'POST'}).then(function(result) {
                collapseTrack();
                if (result && result.success) {
                    showToast('Pushed to origin/' + (result.branch || ''), 'success');
                    refreshBranchStatus();
                } else {
                    showErrorModal('Push failed', (result && result.error) || 'Unknown error');
                }
            });
        }

        // Click outside to collapse
        var onOutside = function(evt) {
            if (!document.getElementById('share-track')) { document.removeEventListener('click', onOutside); return; }
            if (!track.contains(evt.target)) {
                collapseTrack();
                document.removeEventListener('click', onOutside);
            }
        };
        setTimeout(function() { document.addEventListener('click', onOutside); }, 0);
    };
}

// Keyboard alternative: hold Enter for 1s on Share button
(function() {
    var shareBtn = document.getElementById('btn-share');
    if (!shareBtn) return;
    var holdTimer = null;
    shareBtn.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !holdTimer && !shareBtn.disabled) {
            e.preventDefault();
            shareBtn.classList.add('hold-progress');
            holdTimer = setTimeout(function() {
                shareBtn.classList.remove('hold-progress');
                holdTimer = null;
                apiFetch('/api/git/push', {method: 'POST'}).then(function(result) {
                    if (result && result.success) {
                        showToast('Pushed to origin/' + (result.branch || ''), 'success');
                        refreshBranchStatus();
                    } else {
                        showErrorModal('Push failed', (result && result.error) || 'Unknown error');
                    }
                });
            }, 1000);
        }
    });
    shareBtn.addEventListener('keyup', function(e) {
        if (e.key === 'Enter' && holdTimer) {
            clearTimeout(holdTimer);
            holdTimer = null;
            shareBtn.classList.remove('hold-progress');
        }
    });
})();

