// =====================================================================
// Mutation Helper
// =====================================================================

async function mutate(endpoint, payload) {
    const data = await apiFetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    if (data && data.success) {
        showToast('Change applied', 'success');
        await refreshDirtyCount();
    } else if (data) {
        showToast(data.error || 'Mutation failed', 'error');
    }
    return data;
}

// =====================================================================
// Toast Notifications
// =====================================================================

function showToast(message, type) {
    type = type || 'info';
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.textContent = message;
    container.appendChild(toast);
    setTimeout(function() {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.3s';
        setTimeout(function() { toast.remove(); }, 300);
    }, 3000);
}

// =====================================================================
// Edit Mode
// =====================================================================

function toggleEditMode() {
    editState.enabled = !editState.enabled;
    document.body.classList.toggle('edit-mode', editState.enabled);
    document.getElementById('edit-toggle').classList.toggle('active', editState.enabled);

    // Toggle contenteditable on assertion text fields
    document.querySelectorAll('.card-assertion-text').forEach(function(el) {
        el.contentEditable = editState.enabled ? 'true' : 'false';
    });

    // .edit-only visibility is handled by CSS:
    //   .edit-only { display: none; }
    //   body.edit-mode .edit-only { display: inline-flex; }

    saveState();
}

// =====================================================================
// Edit Handlers
// =====================================================================

function onStatusChange(selectEl) {
    const nodeId = selectEl.dataset.nodeId;
    const newStatus = selectEl.value;
    const original = selectEl.dataset.original;

    if (newStatus.toLowerCase() === original) {
        selectEl.classList.remove('dirty');
        return;
    }

    selectEl.classList.add('dirty');
    mutate('/api/mutate/status', { node_id: nodeId, new_status: newStatus }).then(function(result) {
        if (result && result.success) {
            selectEl.dataset.original = newStatus.toLowerCase();
            selectEl.classList.remove('dirty');
            // Refresh the card data
            refreshCard(nodeId);
        }
    });
}

function onTitleBlur(el) {
    if (!editState.enabled) return;
    const nodeId = el.dataset.nodeId;
    const newTitle = el.textContent.trim();
    const original = el.dataset.original;

    if (newTitle === original) {
        el.classList.remove('dirty');
        return;
    }

    if (!newTitle) {
        el.textContent = original;
        el.classList.remove('dirty');
        showToast('Title cannot be empty', 'error');
        return;
    }

    el.classList.add('dirty');
    mutate('/api/mutate/title', { node_id: nodeId, new_title: newTitle }).then(function(result) {
        if (result && result.success) {
            el.dataset.original = newTitle;
            el.classList.remove('dirty');
            refreshCard(nodeId);
        } else {
            el.textContent = original;
            el.classList.remove('dirty');
        }
    });
}

function onAssertionBlur(el) {
    if (!editState.enabled) return;
    const assertionId = el.dataset.assertionId;
    const newText = el.textContent.trim();
    const original = el.dataset.original;

    if (newText === original) {
        el.classList.remove('dirty');
        return;
    }

    if (!newText) {
        el.textContent = original;
        el.classList.remove('dirty');
        showToast('Assertion text cannot be empty', 'error');
        return;
    }

    el.classList.add('dirty');
    mutate('/api/mutate/assertion', { assertion_id: assertionId, new_text: newText }).then(function(result) {
        if (result && result.success) {
            el.dataset.original = newText;
            el.classList.remove('dirty');
        } else {
            el.textContent = original;
            el.classList.remove('dirty');
        }
    });
}

function onAddAssertion(nodeId) {
    const label = prompt('Assertion label (e.g., A, B, C):');
    if (!label) return;
    const text = prompt('Assertion text (SHALL statement):');
    if (!text) return;

    mutate('/api/mutate/assertion/add', {
        req_id: nodeId,
        label: label.trim().toUpperCase(),
        text: text.trim()
    }).then(function(result) {
        if (result && result.success) {
            refreshCard(nodeId);
        }
    });
}

function onDeleteRequirement(nodeId) {
    if (!confirm('Delete ' + nodeId + ' and all its assertions? This can be undone with Ctrl+Z.')) return;
    mutate('/api/mutate/requirement/delete', {
        node_id: nodeId,
        confirm: true
    }).then(function(result) {
        if (result && result.success) {
            closeCard(nodeId);
            loadTreeData();
        }
    });
}

function onDeleteAssertion(nodeId, assertionId) {
    if (!confirm('Delete assertion ' + assertionId + '? This can be undone with Ctrl+Z.')) return;
    mutate('/api/mutate/assertion/delete', {
        assertion_id: assertionId,
        confirm: true
    }).then(function(result) {
        if (result && result.success) {
            refreshCard(nodeId);
        }
    });
}

function onEditableKeydown(event) {
    // Enter key = blur (save)
    if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        event.target.blur();
    }
    // Escape = revert
    if (event.key === 'Escape') {
        event.target.textContent = event.target.dataset.original;
        event.target.classList.remove('dirty');
        event.target.blur();
    }
}

async function refreshCard(nodeId) {
    const data = await apiFetch('/api/requirement/' + encodeURIComponent(nodeId));
    if (!data) return;
    const info = editState.openCards.get(nodeId);
    if (!info) return;
    info.data = data;
    // Invalidate assertion caches for this requirement
    delete assertionTestsCache[nodeId];
    delete assertionCodeCache[nodeId];
    renderCardStack();
}

// =====================================================================
// Save / Revert / Undo
// =====================================================================

async function doSave() {
    const result = await mutate('/api/save', {});
    if (result && result.success) {
        showToast('Saved to disk', 'success');
    }
    // Even if it returns 501 (not yet implemented), display message
    if (result && result.message) {
        showToast(result.message, 'info');
    }
}

async function doRevert() {
    if (!confirm('Revert all unsaved changes? This cannot be undone.')) return;
    const result = await mutate('/api/revert', {});
    if (result && result.success) {
        showToast('All changes reverted', 'success');
        // Reload all open cards
        editState.openCardOrder.forEach(function(id) {
            refreshCard(id);
        });
    }
    if (result && result.message) {
        showToast(result.message, 'info');
    }
}

async function doUndo() {
    const result = await mutate('/api/mutate/undo', {});
    if (result && result.success) {
        // Reload all open cards to reflect undo
        editState.openCardOrder.forEach(function(id) {
            refreshCard(id);
        });
    }
}

// =====================================================================
// Relationship Editor
// =====================================================================

function onToggleEdgeKind(el) {
    var sourceId = el.dataset.source;
    var targetId = el.dataset.target;
    var currentKind = el.dataset.kind;
    var newKind = currentKind === 'implements' ? 'refines' : 'implements';

    mutate('/api/mutate/edge', {
        action: 'change_kind',
        source_id: sourceId,
        target_id: targetId,
        new_kind: newKind
    }).then(function(result) {
        if (result && result.success) {
            refreshCard(sourceId);
        }
    });
}

function onDeleteEdge(sourceId, targetId) {
    if (!confirm('Remove relationship from ' + sourceId + ' to ' + targetId + '?')) return;

    mutate('/api/mutate/edge', {
        action: 'delete',
        source_id: sourceId,
        target_id: targetId
    }).then(function(result) {
        if (result && result.success) {
            refreshCard(sourceId);
            loadTreeData();
        }
    });
}

function onAddRelationship(nodeId, btn) {
    // If form already exists, remove it
    var existing = btn.parentNode.querySelector('.card-add-rel-form');
    if (existing) {
        existing.remove();
        return;
    }

    var form = document.createElement('div');
    form.className = 'card-add-rel-form';

    // Type select
    var typeRow = document.createElement('div');
    typeRow.className = 'add-rel-row';
    typeRow.innerHTML = '<label class="add-rel-label">Type:</label>';
    var typeSelect = document.createElement('select');
    typeSelect.className = 'add-rel-select';
    typeSelect.innerHTML = '<option value="implements">Implements</option><option value="refines">Refines</option>';
    typeRow.appendChild(typeSelect);
    form.appendChild(typeRow);

    // Requirement picker
    var pickerRow = document.createElement('div');
    pickerRow.className = 'add-rel-row';
    pickerRow.innerHTML = '<label class="add-rel-label">Target:</label>';
    var pickerContainer = document.createElement('div');
    pickerContainer.className = 'add-rel-picker-container';
    pickerRow.appendChild(pickerContainer);
    form.appendChild(pickerRow);

    // Assertion target dropdown (populated after requirement selection)
    var assertionRow = document.createElement('div');
    assertionRow.className = 'add-rel-row';
    assertionRow.style.display = 'none';
    assertionRow.innerHTML = '<label class="add-rel-label">Assertion:</label>';
    var assertionSelect = document.createElement('select');
    assertionSelect.className = 'add-rel-select';
    assertionSelect.innerHTML = '<option value="">(Whole requirement)</option>';
    assertionRow.appendChild(assertionSelect);
    form.appendChild(assertionRow);

    // Buttons
    var btnRow = document.createElement('div');
    btnRow.className = 'add-rel-buttons';
    var addBtn = document.createElement('button');
    addBtn.className = 'add-rel-add-btn';
    addBtn.textContent = 'Add';
    addBtn.disabled = true;
    var cancelBtn = document.createElement('button');
    cancelBtn.className = 'add-rel-cancel-btn';
    cancelBtn.textContent = 'Cancel';
    btnRow.appendChild(addBtn);
    btnRow.appendChild(cancelBtn);
    form.appendChild(btnRow);

    var picker = createReqPicker(pickerContainer, {
        placeholder: 'Search for target requirement...',
        fetchAssertions: true,
        onSelect: function(item) {
            addBtn.disabled = false;
            // Populate assertion dropdown
            assertionSelect.innerHTML = '<option value="">(Whole requirement)</option>';
            if (item.assertions && item.assertions.length > 0) {
                item.assertions.forEach(function(a) {
                    var opt = document.createElement('option');
                    opt.value = a.label || '';
                    opt.textContent = (a.label || '') + ': ' + (a.text || '').substring(0, 60);
                    assertionSelect.appendChild(opt);
                });
                assertionRow.style.display = 'flex';
            } else {
                assertionRow.style.display = 'none';
            }
        },
        onClear: function() {
            addBtn.disabled = true;
            assertionRow.style.display = 'none';
            assertionSelect.innerHTML = '<option value="">(Whole requirement)</option>';
        }
    });

    addBtn.addEventListener('click', function() {
        var selected = picker.getSelected();
        if (!selected) return;

        var edgeKind = typeSelect.value;
        var targetId = selected.id;
        var assertionLabel = assertionSelect.value;

        var payload = {
            action: 'add',
            source_id: nodeId,
            target_id: targetId,
            edge_kind: edgeKind
        };

        if (assertionLabel) {
            payload.assertion_targets = [assertionLabel];
        }

        mutate('/api/mutate/edge', payload).then(function(result) {
            if (result && result.success) {
                form.remove();
                refreshCard(nodeId);
                loadTreeData();
            }
        });
    });

    cancelBtn.addEventListener('click', function() {
        picker.destroy();
        form.remove();
    });

    btn.parentNode.insertBefore(form, btn);
}

