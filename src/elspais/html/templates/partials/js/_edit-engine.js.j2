// Partial: _edit-engine.js.j2 — toast, edit toggle, mutations, undo/save/revert, search
// Note: apiFetch() is now defined in _api-adapter.js.j2 (shared by both modes)

// =====================================================================
// Mutation Helper
// =====================================================================

async function mutate(endpoint, payload) {
    const data = await apiFetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    if (data && data.success) {
        showToast('Change applied', 'success');
        await refreshDirtyCount();
    } else if (data) {
        showToast(data.error || 'Mutation failed', 'error');
    }
    return data;
}

// =====================================================================
// Toast Notifications
// =====================================================================

function showToast(message, type) {
    type = type || 'info';
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.textContent = message;
    container.appendChild(toast);
    setTimeout(function() {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.3s';
        setTimeout(function() { toast.remove(); }, 300);
    }, 3000);
}

// =====================================================================
// Loading Overlay
// =====================================================================

function showLoadingOverlay(message) {
    var existing = document.getElementById('loading-overlay');
    if (existing) existing.remove();
    var overlay = document.createElement('div');
    overlay.id = 'loading-overlay';
    overlay.className = 'loading-overlay';
    overlay.innerHTML = '<div class="loading-message">' + escapeHtml(message || 'Loading...') + '</div>';
    document.body.appendChild(overlay);
}

function hideLoadingOverlay() {
    var el = document.getElementById('loading-overlay');
    if (el) el.remove();
}

// =====================================================================
// Edit Mode
// =====================================================================

function _activateEditMode() {
    editState.enabled = true;
    document.body.classList.add('edit-mode');
    document.getElementById('edit-toggle').classList.add('active');
    document.querySelectorAll('.card-assertion-text').forEach(function(el) {
        el.contentEditable = 'true';
    });
    saveState();
}

function _deactivateEditMode() {
    editState.enabled = false;
    document.body.classList.remove('edit-mode');
    document.getElementById('edit-toggle').classList.remove('active');
    document.querySelectorAll('.card-assertion-text').forEach(function(el) {
        el.contentEditable = 'false';
    });
    saveState();
}

function toggleEditMode() {
    if (editState.enabled) {
        _deactivateEditMode();
        return;
    }
    refreshBranchStatus().then(function(data) {
        if (!data) return;
        if (data.is_detached) {
            // Rewound state — need to create a branch first
            showBranchFromDetachedModal(data);
        } else if (data.is_main) {
            showBranchModal('You are on the main branch. Create a working branch before editing.', function() {
                _activateEditMode();
            });
        } else {
            _activateEditMode();
        }
    });
}

// =====================================================================
// Branch Status & Git Pull (REQ-p00004-C, REQ-p00004-D)
// =====================================================================

async function refreshBranchStatus() {
    var data = await apiFetch('/api/git/status');
    if (!data) return null;
    var dot = document.getElementById('branch-status-dot');
    var nameEl = document.getElementById('branch-name');
    var syncBtn = document.getElementById('btn-sync');
    var warningEl = document.getElementById('branch-warning');
    if (!dot || !nameEl) return data;
    editState.isMain = !!data.is_main;
    if (data.is_detached && data.originating_branch) {
        nameEl.textContent = data.originating_branch + ' (<<' + (data.commits_behind_head || '?') + ')';
        dot.classList.add('orange');
        nameEl.parentElement.title = 'Viewing historical checkpoint — click to switch branch';
    } else if (data.branch) {
        nameEl.textContent = data.branch;
        nameEl.parentElement.title = 'Click to switch branch';
    } else if (data.is_detached) {
        // Detached HEAD without originating branch (e.g. worktree started detached)
        var commitLabel = data.detached_commit || 'unknown';
        nameEl.textContent = 'detached @ ' + commitLabel;
        nameEl.parentElement.title = 'Detached HEAD — click to switch to a branch';
    } else {
        nameEl.textContent = 'no branch';
        nameEl.parentElement.title = 'Not on a branch — click to choose one';
    }
    dot.className = 'branch-status-dot';
    if (data.is_main) { dot.classList.add('red'); }
    else if (data.is_detached) { dot.classList.add('orange'); }
    else if (data.local_ahead > 0) { dot.classList.add('blue'); }
    else { dot.classList.add('green'); }
    // Sync button: visible when remote has diverged OR main has moved ahead
    var needsSync = data.remote_diverged || data.main_diverged;
    if (syncBtn) {
        syncBtn.classList.toggle('hidden', !needsSync);
    }
    if (warningEl) {
        warningEl.classList.toggle('hidden', !data.main_diverged);
    }
    // Checkpoint button: enabled when uncommitted files exist
    var checkpointBtn = document.getElementById('btn-checkpoint');
    if (checkpointBtn) {
        var uncommittedCount = data.uncommitted_file_count || 0;
        checkpointBtn.disabled = uncommittedCount === 0 || data.is_detached;
        var uncommittedBadge = document.getElementById('uncommitted-badge');
        if (uncommittedBadge) {
            if (uncommittedCount > 0) {
                uncommittedBadge.textContent = uncommittedCount + ' file' + (uncommittedCount > 1 ? 's' : '');
                uncommittedBadge.classList.remove('hidden');
            } else {
                uncommittedBadge.classList.add('hidden');
            }
        }
    }
    // Share button: enabled when unpushed commits exist
    var shareBtn = document.getElementById('btn-share');
    if (shareBtn) {
        shareBtn.disabled = data.is_main || !(data.local_ahead > 0) || data.is_detached;
    }
    // Detached state: grey all edit buttons
    if (data.is_detached) {
        ['btn-undo', 'btn-save', 'btn-checkpoint', 'btn-share'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.disabled = true;
        });
    }
    editState.lastBranchStatus = data;
    return data;
}

async function doGitSync() {
    var syncBtn = document.getElementById('btn-sync');
    if (syncBtn) { syncBtn.disabled = true; syncBtn.textContent = 'Syncing...'; }
    var result = await apiFetch('/api/git/pull', {method: 'POST'});
    if (syncBtn) { syncBtn.disabled = false; syncBtn.innerHTML = '&#x21bb; Sync'; }
    if (result && result.success) {
        showToast(result.message || 'Synced', 'success');
        refreshBranchStatus();
    } else {
        showToast((result && result.error) || 'Sync failed', 'error');
        refreshBranchStatus();
    }
}

// =====================================================================
// Branch Creation Modal (REQ-p00004-D)
// =====================================================================

function showBranchModal(reason, callback) {
    var overlay = document.createElement('div');
    overlay.className = 'modal-overlay visible';
    overlay.id = 'branch-modal-overlay';

    var dialog = document.createElement('div');
    dialog.className = 'modal-dialog';

    var title = document.createElement('div');
    title.className = 'modal-title';
    title.textContent = 'Create a Working Branch';

    var reasonEl = document.createElement('p');
    reasonEl.style.fontSize = '0.9em';
    reasonEl.style.marginBottom = '12px';
    reasonEl.textContent = reason;

    var label = document.createElement('label');
    label.className = 'modal-label';
    label.textContent = 'Branch name';
    label.htmlFor = 'branch-name-input';

    var input = document.createElement('input');
    input.className = 'modal-input';
    input.id = 'branch-name-input';
    input.type = 'text';
    input.placeholder = 'e.g. feat/my-changes';

    var errorEl = document.createElement('div');
    errorEl.className = 'modal-error';
    errorEl.style.display = 'none';

    var actions = document.createElement('div');
    actions.className = 'modal-actions';

    var cancelBtn = document.createElement('button');
    cancelBtn.className = 'btn';
    cancelBtn.textContent = 'Cancel';

    var createBtn = document.createElement('button');
    createBtn.className = 'btn btn-primary';
    createBtn.textContent = 'Create Branch';

    actions.appendChild(cancelBtn);
    actions.appendChild(createBtn);

    dialog.appendChild(title);
    dialog.appendChild(reasonEl);
    dialog.appendChild(label);
    dialog.appendChild(input);
    dialog.appendChild(errorEl);
    dialog.appendChild(actions);
    overlay.appendChild(dialog);
    document.body.appendChild(overlay);

    input.focus();

    function closeModal() {
        var el = document.getElementById('branch-modal-overlay');
        if (el) {
            el.classList.remove('visible');
            setTimeout(function() { el.remove(); }, 200);
        }
    }

    function doCreate() {
        var name = input.value.trim();
        if (!name) {
            errorEl.textContent = 'Branch name is required.';
            errorEl.style.display = 'block';
            return;
        }
        createBtn.disabled = true;
        createBtn.textContent = 'Creating...';
        apiFetch('/api/git/branch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name })
        }).then(function(result) {
            if (result && result.success) {
                closeModal();
                showToast('Switched to branch: ' + name, 'success');
                refreshBranchStatus();
                if (callback) callback();
            } else {
                errorEl.textContent = (result && result.error) || 'Failed to create branch.';
                errorEl.style.display = 'block';
                createBtn.disabled = false;
                createBtn.textContent = 'Create Branch';
            }
        }).catch(function(err) {
            console.error('Branch creation error:', err);
            closeModal();
            showToast('Branch may have been created — refresh to check', 'error');
        });
    }

    createBtn.addEventListener('click', doCreate);
    cancelBtn.addEventListener('click', closeModal);

    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); doCreate(); }
        if (e.key === 'Escape') { closeModal(); }
    });

    overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeModal();
    });
}

// =====================================================================
// Branch From Detached Modal (REQ-p00004-D)
// =====================================================================

function showBranchFromDetachedModal(statusData) {
    var baseName = statusData.originating_branch || 'branch';
    apiFetch('/api/git/suggest-branch-name?base=' + encodeURIComponent(baseName)).then(function(data) {
        var suggestedName = (data && data.name) || (baseName + '-v2');
        _showBranchFromDetachedDialog(suggestedName);
    });
}

function _showBranchFromDetachedDialog(suggestedName) {
    var old = document.getElementById('branch-modal-overlay');
    if (old) old.remove();

    var overlay = document.createElement('div');
    overlay.id = 'branch-modal-overlay';
    overlay.className = 'modal-overlay visible';
    overlay.innerHTML =
        '<div class="modal-dialog">' +
            '<div class="modal-title">Create Branch From Checkpoint</div>' +
            '<p style="font-size:0.9em;margin-bottom:12px;">You are viewing a historical checkpoint. To edit, a new branch will be created from this point.</p>' +
            '<label class="modal-label">Branch name:</label>' +
            '<input type="text" class="modal-input" id="detached-branch-input" value="' + escapeHtml(suggestedName) + '">' +
            '<div class="modal-error hidden" id="detached-branch-error"></div>' +
            '<div class="modal-actions">' +
                '<button class="btn btn-primary" id="detached-branch-confirm">Create &amp; Edit</button>' +
                '<button class="btn" id="detached-branch-cancel">Cancel</button>' +
            '</div>' +
        '</div>';
    document.body.appendChild(overlay);

    var input = document.getElementById('detached-branch-input');
    input.focus();
    input.select();

    function doCreate() {
        var name = input.value.trim();
        if (!name) return;
        var confirmBtn = document.getElementById('detached-branch-confirm');
        var errorEl = document.getElementById('detached-branch-error');
        confirmBtn.disabled = true;
        confirmBtn.textContent = 'Creating...';
        apiFetch('/api/git/branch', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({name: name})
        }).then(function(result) {
            if (result && result.success) {
                overlay.remove();
                showToast('Branch ' + name + ' created', 'success');
                refreshBranchStatus();
                _activateEditMode();
            } else {
                errorEl.textContent = (result && result.error) || 'Failed to create branch';
                errorEl.classList.remove('hidden');
                confirmBtn.disabled = false;
                confirmBtn.textContent = 'Create & Edit';
            }
        });
    }

    document.getElementById('detached-branch-confirm').onclick = doCreate;
    document.getElementById('detached-branch-cancel').onclick = function() { overlay.remove(); };
    overlay.addEventListener('click', function(e) { if (e.target === overlay) overlay.remove(); });
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') doCreate();
        if (e.key === 'Escape') overlay.remove();
    });
}

// =====================================================================
// Branch Picker Modal
// =====================================================================

function loadBranchHistory(branch, container) {
    container.innerHTML = '<div style="padding:12px;color:var(--text-secondary,#888);">Loading...</div>';
    apiFetch('/api/git/commits?branch=' + encodeURIComponent(branch) + '&limit=20').then(function(commits) {
        if (!commits || !Array.isArray(commits)) {
            container.innerHTML = '<div style="padding:12px;color:var(--text-secondary,#888);">No history available</div>';
            return;
        }
        container.innerHTML = '';
        var heading = document.createElement('div');
        heading.style.cssText = 'color:var(--text-secondary,#888);font-size:11px;margin-bottom:8px;';
        heading.textContent = 'HISTORY: ' + branch;
        container.appendChild(heading);

        commits.forEach(function(c, i) {
            var row = document.createElement('div');
            row.className = 'history-row' + (i === 0 ? ' head' : '');
            row.dataset.hash = c.hash;

            var dateSpan = document.createElement('span');
            dateSpan.className = 'history-date';
            dateSpan.textContent = c.date;
            row.appendChild(dateSpan);

            var textSpan = document.createElement('span');
            textSpan.className = 'history-text';
            textSpan.textContent = (i === 0 ? 'HEAD' : c.hash) + '  ' + c.message;
            row.appendChild(textSpan);

            if (i > 0) {
                row.addEventListener('click', function() {
                    container.querySelectorAll('.history-row.selected').forEach(function(r) { r.classList.remove('selected'); });
                    row.classList.add('selected');
                    var rewindBtn = document.getElementById('rewind-confirm-btn');
                    if (rewindBtn) {
                        rewindBtn.disabled = false;
                        rewindBtn.dataset.hash = c.hash;
                        rewindBtn.dataset.branch = branch;
                    }
                });
            }
            container.appendChild(row);
        });
    });
}

function showBranchPickerModal() {
    // Guard: unsaved mutations
    if (editState.mutationCount > 0) {
        showToast('Save or revert changes before switching branches', 'warning');
        return;
    }

    apiFetch('/api/git/branches').then(function(data) {
        if (!data) {
            showToast('Failed to load branches', 'error');
            return;
        }

        var localBranches = data.local || [];
        var remoteBranches = data.remote || [];
        var currentBranch = data.current || null;
        // In detached HEAD (after rewind), use the originating branch for highlighting
        var isRewound = false;
        if (currentBranch === null && editState.lastBranchStatus && editState.lastBranchStatus.originating_branch) {
            currentBranch = editState.lastBranchStatus.originating_branch;
            isRewound = true;
        }

        // Remove existing modal
        var old = document.getElementById('branch-modal-overlay');
        if (old) old.remove();

        var overlay = document.createElement('div');
        overlay.id = 'branch-modal-overlay';
        overlay.className = 'modal-overlay visible';

        var dialog = document.createElement('div');
        dialog.className = 'modal-dialog';
        dialog.style.minWidth = '680px';
        dialog.style.maxWidth = '860px';

        var title = document.createElement('div');
        title.className = 'modal-title';
        title.textContent = currentBranch ? 'Switch Branch' : 'You\'re not on any branch — select one to continue';

        // Two-panel container
        var panels = document.createElement('div');
        panels.className = 'branch-picker-panels';

        // Left panel
        var leftPanel = document.createElement('div');
        leftPanel.className = 'branch-picker-left';

        var filterInput = document.createElement('input');
        filterInput.type = 'text';
        filterInput.className = 'modal-input';
        filterInput.placeholder = 'Filter branches...';
        filterInput.style.marginBottom = '8px';

        var listContainer = document.createElement('div');
        listContainer.className = 'branch-list-container';
        listContainer.style.border = 'none';
        listContainer.style.margin = '0';

        leftPanel.appendChild(filterInput);
        leftPanel.appendChild(listContainer);

        // Right panel
        var rightPanel = document.createElement('div');
        rightPanel.className = 'branch-picker-right';

        panels.appendChild(leftPanel);
        panels.appendChild(rightPanel);

        // Build branch items
        function buildList(filter) {
            listContainer.innerHTML = '';
            var filterLower = (filter || '').toLowerCase();

            var filteredLocal = localBranches.filter(function(b) {
                return !filterLower || b.toLowerCase().indexOf(filterLower) >= 0;
            });
            var filteredRemote = remoteBranches.filter(function(b) {
                return !filterLower || b.toLowerCase().indexOf(filterLower) >= 0;
            });

            if (filteredLocal.length > 0) {
                var localHeading = document.createElement('h4');
                localHeading.className = 'branch-list-heading';
                localHeading.textContent = 'Local';
                listContainer.appendChild(localHeading);

                filteredLocal.forEach(function(branch) {
                    var item = document.createElement('div');
                    item.className = 'branch-list-item';
                    if (branch === currentBranch) {
                        item.className += ' current';
                    }

                    var nameSpan = document.createElement('span');
                    nameSpan.textContent = branch;
                    item.appendChild(nameSpan);

                    if (branch === currentBranch) {
                        var tag = document.createElement('span');
                        tag.className = 'branch-current-tag';
                        tag.textContent = isRewound ? '(rewound)' : '(current)';
                        item.appendChild(tag);
                        item.addEventListener('click', function() {
                            loadBranchHistory(branch, rightPanel);
                        });
                    } else {
                        item.addEventListener('click', function() {
                            loadBranchHistory(branch, rightPanel);
                            doSwitchBranch(branch, false);
                        });
                    }

                    listContainer.appendChild(item);
                });
            }

            if (filteredRemote.length > 0) {
                var remoteHeading = document.createElement('h4');
                remoteHeading.className = 'branch-list-heading';
                remoteHeading.textContent = 'Remote';
                listContainer.appendChild(remoteHeading);

                filteredRemote.forEach(function(branch) {
                    var item = document.createElement('div');
                    item.className = 'branch-list-item';

                    var nameSpan = document.createElement('span');
                    nameSpan.textContent = branch;
                    item.appendChild(nameSpan);

                    var tag = document.createElement('span');
                    tag.className = 'branch-remote-tag';
                    tag.textContent = '(remote)';
                    item.appendChild(tag);

                    item.addEventListener('click', function() {
                        loadBranchHistory(branch, rightPanel);
                        doSwitchBranch(branch, true);
                    });

                    listContainer.appendChild(item);
                });
            }

            if (filteredLocal.length === 0 && filteredRemote.length === 0) {
                var empty = document.createElement('div');
                empty.style.padding = '12px';
                empty.style.color = 'var(--text-secondary, #888)';
                empty.style.textAlign = 'center';
                empty.textContent = 'No matching branches';
                listContainer.appendChild(empty);
            }
        }

        filterInput.addEventListener('input', function() {
            buildList(filterInput.value);
        });

        var errorEl = document.createElement('div');
        errorEl.className = 'modal-error hidden';

        var actions = document.createElement('div');
        actions.className = 'modal-actions';

        var rewindBtn = document.createElement('button');
        rewindBtn.id = 'rewind-confirm-btn';
        rewindBtn.className = 'btn btn-success';
        rewindBtn.textContent = 'Rewind to this checkpoint';
        rewindBtn.disabled = true;
        rewindBtn.addEventListener('click', function() {
            var hash = rewindBtn.dataset.hash;
            var branch = rewindBtn.dataset.branch;
            if (!hash || !branch) return;
            rewindBtn.disabled = true;
            rewindBtn.textContent = 'Rewinding...';
            showLoadingOverlay('Rewinding...');
            apiFetch('/api/git/checkout-commit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ hash: hash, branch: branch })
            }).then(function(result) {
                if (result && result.success) {
                    apiFetch('/api/reload', { method: 'POST' }).then(function() {
                        hideLoadingOverlay();
                        closeModal();
                        showToast('Rewound to ' + hash, 'success');
                        refreshBranchStatus();
                        refreshAllOpenCards();
                        loadTreeData();
                        refreshFileViewer();
                        refreshDirtyCount();
                        dismissStaleBanner();
                    });
                } else {
                    hideLoadingOverlay();
                    errorEl.textContent = (result && result.error) || 'Failed to rewind';
                    errorEl.classList.remove('hidden');
                    rewindBtn.disabled = false;
                    rewindBtn.textContent = 'Rewind to this checkpoint';
                }
            });
        });

        var cancelBtn = document.createElement('button');
        cancelBtn.className = 'btn';
        cancelBtn.textContent = 'Cancel';

        actions.appendChild(rewindBtn);
        actions.appendChild(cancelBtn);

        dialog.appendChild(title);
        dialog.appendChild(panels);
        dialog.appendChild(errorEl);
        dialog.appendChild(actions);
        overlay.appendChild(dialog);
        document.body.appendChild(overlay);

        buildList('');
        filterInput.focus();

        // Load history for the current branch by default
        if (currentBranch) {
            loadBranchHistory(currentBranch, rightPanel);
        }

        function closeModal() {
            var el = document.getElementById('branch-modal-overlay');
            if (el) {
                el.classList.remove('visible');
                setTimeout(function() { el.remove(); }, 200);
            }
        }

        function doSwitchBranch(branch, isRemote) {
            // Disable all items and show switching state
            var items = listContainer.querySelectorAll('.branch-list-item');
            items.forEach(function(item) {
                item.style.pointerEvents = 'none';
                item.style.opacity = '0.5';
            });
            // Find the clicked item and update text
            items.forEach(function(item) {
                var nameSpan = item.querySelector('span');
                if (nameSpan && nameSpan.textContent === branch) {
                    nameSpan.textContent = 'Switching...';
                }
            });

            showLoadingOverlay('Switching branch...');
            apiFetch('/api/git/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ branch: branch, is_remote: isRemote })
            }).then(function(result) {
                if (result && result.success) {
                    closeModal();
                    // Reload graph from disk after branch switch
                    apiFetch('/api/reload', { method: 'POST' }).then(function() {
                        hideLoadingOverlay();
                        showToast('Switched to branch: ' + (result.branch || branch), 'success');
                        refreshBranchStatus();
                        refreshAllOpenCards();
                        loadTreeData();
                        refreshFileViewer();
                        refreshDirtyCount();
                        dismissStaleBanner();
                    });
                } else {
                    hideLoadingOverlay();
                    errorEl.textContent = (result && result.error) || 'Failed to switch branch';
                    errorEl.classList.remove('hidden');
                    // Re-enable items
                    items.forEach(function(item) {
                        item.style.pointerEvents = '';
                        item.style.opacity = '';
                    });
                    buildList(filterInput.value);
                    refreshBranchStatus();
                }
            });
        }

        cancelBtn.addEventListener('click', closeModal);

        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) closeModal();
        });

        document.addEventListener('keydown', function onEsc(e) {
            if (e.key === 'Escape') {
                closeModal();
                document.removeEventListener('keydown', onEsc);
            }
        });
    });
}

// =====================================================================
// Edit Handlers
// =====================================================================

function onStatusChange(selectEl) {
    const nodeId = selectEl.dataset.nodeId;
    const newStatus = selectEl.value;
    const original = selectEl.dataset.original;

    if (newStatus.toLowerCase() === original) {
        selectEl.classList.remove('dirty');
        return;
    }

    selectEl.classList.add('dirty');
    mutate('/api/mutate/status', { node_id: nodeId, new_status: newStatus }).then(async function(result) {
        if (result && result.success) {
            selectEl.dataset.original = newStatus.toLowerCase();
            selectEl.classList.remove('dirty');
            await refreshAllOpenCards();
            loadTreeData();
        }
    });
}

function onTitleBlur(el) {
    if (!editState.enabled) return;
    const nodeId = el.dataset.nodeId;
    const newTitle = el.textContent.trim();
    const original = el.dataset.original;

    if (newTitle === original) {
        el.classList.remove('dirty');
        return;
    }

    if (!newTitle) {
        el.textContent = original;
        el.classList.remove('dirty');
        showToast('Title cannot be empty', 'error');
        return;
    }

    el.classList.add('dirty');
    mutate('/api/mutate/title', { node_id: nodeId, new_title: newTitle }).then(async function(result) {
        if (result && result.success) {
            el.dataset.original = newTitle;
            el.classList.remove('dirty');
            await refreshAllOpenCards();
            loadTreeData();
        } else {
            el.textContent = original;
            el.classList.remove('dirty');
        }
    });
}

function onAssertionBlur(el) {
    if (!editState.enabled) return;
    const assertionId = el.dataset.assertionId;
    const newText = el.textContent.trim();
    const original = el.dataset.original;

    if (newText === original) {
        el.classList.remove('dirty');
        return;
    }

    if (!newText) {
        el.textContent = original;
        el.classList.remove('dirty');
        showToast('Assertion text cannot be empty', 'error');
        return;
    }

    el.classList.add('dirty');
    mutate('/api/mutate/assertion', { assertion_id: assertionId, new_text: newText }).then(function(result) {
        if (result && result.success) {
            el.dataset.original = newText;
            el.classList.remove('dirty');
        } else {
            el.textContent = original;
            el.classList.remove('dirty');
        }
    });
}

function onAddAssertion(nodeId) {
    const label = prompt('Assertion label (e.g., A, B, C):');
    if (!label) return;
    const text = prompt('Assertion text (SHALL statement):');
    if (!text) return;

    mutate('/api/mutate/assertion/add', {
        req_id: nodeId,
        label: label.trim().toUpperCase(),
        text: text.trim()
    }).then(async function(result) {
        if (result && result.success) {
            await refreshCard(nodeId);
        }
    });
}

function onDeleteRequirement(nodeId) {
    if (!confirm('Delete ' + nodeId + ' and all its assertions? This can be undone with Ctrl+Z.')) return;
    mutate('/api/mutate/requirement/delete', {
        node_id: nodeId,
        confirm: true
    }).then(function(result) {
        if (result && result.success) {
            closeCard(nodeId);
            loadTreeData();
        }
    });
}

function onDeleteAssertion(nodeId, assertionId) {
    // Look up parent requirement status from open card data
    var info = editState.openCards.get(nodeId);
    var props = info && info.data && info.data.properties ? info.data.properties : {};
    var status = (props.status || '').toLowerCase();
    if (status === 'active') {
        // Active requirements: deprecate assertion (preserve label for traceability)
        if (!confirm('Deprecate assertion ' + assertionId + '? The label will be preserved. This can be undone with Ctrl+Z.')) return;
        mutate('/api/mutate/assertion', {
            assertion_id: assertionId,
            new_text: '[DEPRECATED]'
        }).then(async function(result) {
            if (result && result.success) {
                await refreshCard(nodeId);
            }
        });
    } else {
        // Draft/Deprecated/other: allow full deletion
        if (!confirm('Delete assertion ' + assertionId + '? This can be undone with Ctrl+Z.')) return;
        mutate('/api/mutate/assertion/delete', {
            assertion_id: assertionId,
            confirm: true
        }).then(async function(result) {
            if (result && result.success) {
                await refreshCard(nodeId);
            }
        });
    }
}

function onEditableKeydown(event) {
    // Enter key = blur (save)
    if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        event.target.blur();
    }
    // Escape = revert
    if (event.key === 'Escape') {
        event.target.textContent = event.target.dataset.original;
        event.target.classList.remove('dirty');
        event.target.blur();
    }
}

async function refreshCard(nodeId) {
    const data = await apiFetch('/api/requirement/' + encodeURIComponent(nodeId));
    if (!data) return;
    const info = editState.openCards.get(nodeId);
    if (!info) return;
    info.data = data;
    // Invalidate assertion caches for this requirement
    delete assertionTestsCache[nodeId];
    delete assertionCodeCache[nodeId];
    renderCardStack();
}

async function refreshAllOpenCards() {
    const ids = Array.from(editState.openCards.keys());
    await Promise.all(ids.map(function(id) { return refreshCard(id); }));
}

