/* Partial: _md-tables.css.j2 — pipe-table rendering in viewer
 * Full-grid thin borders (internal + external) on every cell.
 */

.md-table-wrap {
    overflow-x: auto;
    margin: 0.5rem 0;
}

.md-table {
    border-collapse: collapse;
    width: auto;
    font-size: 0.8rem;
    line-height: 1.4;
}

.md-table th,
.md-table td {
    border: 1px solid #ced4da;
    padding: 4px 8px;
    vertical-align: top;
    text-align: left;
}

.md-table thead th {
    background: #f8f9fa;
    font-weight: 600;
}

/* Thin separator row — visual analogue of the `| --- |` markdown line,
 * also serves as the alignment target for the gutter's separator line
 * number in the file viewer's rendered mode. Height matches the gutter
 * number's line-height so the centered line-num doesn't bleed into the
 * adjacent rows. */
.md-table .md-table-separator td {
    padding: 0;
    height: 1.4em;
    background: #e9ecef;
}

html.theme-dark .md-table .md-table-separator td {
    background: #343a40;
}

/* Dark theme: keep grid visible against dark background. */
html.theme-dark .md-table th,
html.theme-dark .md-table td {
    border-color: #495057;
}

html.theme-dark .md-table thead th {
    background: #2b3035;
}
