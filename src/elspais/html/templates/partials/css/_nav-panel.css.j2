/* Partial: _nav-panel.css.j2 — 3-panel layout + nav panel (tree sidebar) */

/* ---------------------------------------------------------------------
   3-Panel Layout
   --------------------------------------------------------------------- */

.layout {
    display: flex;
    flex: 1;
    overflow: hidden;
    min-height: 0;
}

/* --- Nav Panel (Left) --- */

.nav-panel {
    width: 320px;
    min-width: 200px;
    /* Max width is enforced by the divider's JS clamp (viewport-relative); no
       CSS cap so the JS is the single authority. */
    background: var(--panel-bg);
    border-right: 1px solid var(--panel-border);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    overflow: hidden;
}

.nav-tabs {
    display: flex;
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
}

.nav-tab {
    flex: 1;
    padding: 10px 4px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--secondary-text);
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
    text-align: center;
    white-space: nowrap;
}

.nav-tab:hover {
    color: var(--input-text);
    background: var(--body-bg);
}

.nav-tab.active {
    color: var(--primary);
    border-bottom-color: var(--primary);
}

.nav-tree-container {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 4px 0;
}

.nav-tree-row {
    display: flex;
    align-items: center;
    padding: 4px 8px;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--input-text);
    border-left: 3px solid transparent;
    transition: background 0.1s, border-color 0.1s;
    user-select: none;
    gap: 4px;
}

.nav-tree-row:hover {
    background: var(--surface-hover-bg);
}

.nav-tree-row.selected {
    background: var(--primary-light-bg);
    border-left-color: var(--primary);
}

.nav-tree-row.hidden {
    display: none;
}

.nav-tree-indent {
    display: inline-block;
    width: 16px;
    flex-shrink: 0;
}

.nav-tree-toggle {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
    color: var(--muted-text);
    cursor: pointer;
    border: none;
    background: none;
}

.nav-tree-toggle:hover {
    color: var(--input-text);
}

.nav-tree-toggle.leaf {
    visibility: hidden;
}

.nav-tree-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--secondary-text);
    font-size: 0.75rem;
    flex: 1;
    min-width: 0;
}

.nav-tree-level {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 2px;
    flex-shrink: 0;
}

/* Namespace sliver — small vertical color bar glued to the left of the level badge.
   The sliver's background is set inline from row.ns_bg by the JS row template. */
.nav-tree-ns-sliver {
    width: 4px;
    align-self: stretch;
    flex-shrink: 0;
    border-radius: 2px 0 0 2px;
}

/* Both ID spans share the same visual styling; CSS picks which to show per mode. */
.nav-tree-id-full,
.nav-tree-id-component {
    font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
    font-size: 0.75rem;
    color: var(--primary);
    flex-shrink: 0;
}

/* Default mode (no data-mode or data-mode="compact"): show component, hide full. */
#nav-tree-container .nav-tree-id-full      { display: none; }
#nav-tree-container .nav-tree-id-component { display: inline; }

/* Mode: full — show full ID, hide component, hide sliver. */
#nav-tree-container[data-mode="full"] .nav-tree-id-full      { display: inline; }
#nav-tree-container[data-mode="full"] .nav-tree-id-component { display: none; }
#nav-tree-container[data-mode="full"] .nav-tree-ns-sliver    { display: none; }

/* Mode: title-only — hide both ID spans (full ID is in row title= attr for hover). */
#nav-tree-container[data-mode="title-only"] .nav-tree-id-full      { display: none; }
#nav-tree-container[data-mode="title-only"] .nav-tree-id-component { display: none; }

/* Mode: id-only — hide title; ID stays as component. */
#nav-tree-container[data-mode="id-only"] .nav-tree-title { display: none; }

/* Mode: ns-bg — hide both IDs and the sliver; tint row background from --row-ns-tint
   (set inline per-row by the JS template using row.ns_tint). */
#nav-tree-container[data-mode="ns-bg"] .nav-tree-id-full      { display: none; }
#nav-tree-container[data-mode="ns-bg"] .nav-tree-id-component { display: none; }
#nav-tree-container[data-mode="ns-bg"] .nav-tree-ns-sliver    { display: none; }
#nav-tree-container[data-mode="ns-bg"] .nav-tree-row {
    background: var(--row-ns-tint, transparent);
}

/* "Level at end" — orthogonal toggle that moves the level badge to the end of
   the row regardless of which display mode is active. Driven by `data-level-pos`
   on `#nav-tree-container` (set by setLevelAtEnd in _nav-tree.js.j2). */
#nav-tree-container[data-level-pos="end"] .nav-tree-level {
    order: 9;
    margin-left: 6px;
}

{% for l in levels %}
.nav-tree-level.{{ l.key|lower }} { background: {{ l.bg }}; color: {{ l.text }}; }
{% endfor %}

/* Test and result rows in nav tree */
.nav-tree-test {
    background: var(--nav-tree-test-bg);
}
.nav-tree-test:hover {
    background: var(--nav-tree-test-hover-bg);
}
.nav-tree-result {
    background: var(--nav-tree-result-bg);
    font-size: 0.75rem;
}
.nav-tree-result:hover {
    background: var(--nav-tree-result-hover-bg);
}
.nav-tree-result.result-passed { border-left-color: var(--result-passed-border); }
.nav-tree-result.result-failed { border-left-color: var(--result-failed-border); }
.nav-tree-result.result-error { border-left-color: var(--result-error-border); }
.nav-tree-result.result-skipped { border-left-color: var(--result-skipped-border); }

.nav-tree-kind-icon {
    flex-shrink: 0;
    font-size: 0.75rem;
    width: 16px;
    text-align: center;
}
.nav-tree-kind-icon.test-icon {
    font-size: 0.8rem;
}

.nav-tree-result-badge {
    font-size: 0.6rem;
    font-weight: 600;
    padding: 1px 4px;
    border-radius: 2px;
    margin-left: auto;
    flex-shrink: 0;
    text-transform: uppercase;
}
.nav-tree-result-badge.passed { background: var(--result-passed-bg); color: var(--result-passed-text); }
.nav-tree-result-badge.failed, .nav-tree-result-badge.fail, .nav-tree-result-badge.failure { background: var(--result-failed-bg); color: var(--result-failed-text); }
.nav-tree-result-badge.error { background: var(--result-error-bg); color: var(--result-error-text); }
.nav-tree-result-badge.skipped, .nav-tree-result-badge.skip { background: var(--result-skipped-bg); color: var(--result-skipped-text); }

/* Tab spacer and tree action buttons */
.nav-tab-spacer { flex: 1; }

.nav-tree-action {
    padding: 6px 8px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.7rem;
    color: var(--muted-text);
    transition: color 0.15s;
}
.nav-tree-action:hover { color: var(--input-text); }

/* Indicator slots — fixed-width columns to left of status badge */
.nav-tree-indicators {
    display: inline-flex;
    align-items: center;
    margin-left: auto;
    flex-shrink: 0;
}

.nav-tree-indicator {
    display: inline-block;
    width: 12px;
    text-align: center;
    font-size: 0.75rem;
    line-height: 1;
    flex-shrink: 0;
}

/* Comment indicator */
.nav-tree-indicator.nav-tree-comment-icon.direct { color: #d4900a; }
.nav-tree-indicator.nav-tree-comment-icon.inherited { color: #ccc; }

/* Change indicators */
.nav-tree-indicator.unsaved { color: #dc3545; }
.nav-tree-indicator.uncommitted { color: #0d6efd; }
.nav-tree-indicator.changed { color: #6c757d; }

/* Compact status badge within tree rows */
.nav-tree-row .status-badge {
    font-size: 0.65rem;
    padding: 1px 4px;
    margin-left: 2px;
    flex-shrink: 0;
}
