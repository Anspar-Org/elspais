/* Partial: _nav-panel.css.j2 — 3-panel layout + nav panel (tree sidebar) */

/* ---------------------------------------------------------------------
   3-Panel Layout
   --------------------------------------------------------------------- */

.layout {
    display: flex;
    flex: 1;
    overflow: hidden;
    min-height: 0;
}

/* --- Nav Panel (Left) --- */

.nav-panel {
    width: 320px;
    min-width: 200px;
    max-width: 600px;
    background: var(--panel-bg);
    border-right: 1px solid var(--panel-border);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    overflow: hidden;
}

.nav-tabs {
    display: flex;
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
}

.nav-tab {
    flex: 1;
    padding: 10px 4px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--secondary-text);
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
    text-align: center;
    white-space: nowrap;
}

.nav-tab:hover {
    color: var(--input-text);
    background: var(--body-bg);
}

.nav-tab.active {
    color: var(--primary);
    border-bottom-color: var(--primary);
}

.nav-tree-container {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 4px 0;
}

.nav-tree-row {
    display: flex;
    align-items: center;
    padding: 4px 8px;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--input-text);
    border-left: 3px solid transparent;
    transition: background 0.1s, border-color 0.1s;
    user-select: none;
    gap: 4px;
}

.nav-tree-row:hover {
    background: var(--surface-hover-bg);
}

.nav-tree-row.selected {
    background: var(--primary-light-bg);
    border-left-color: var(--primary);
}

.nav-tree-row.hidden {
    display: none;
}

.nav-tree-indent {
    display: inline-block;
    width: 16px;
    flex-shrink: 0;
}

.nav-tree-toggle {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
    color: var(--muted-text);
    cursor: pointer;
    border: none;
    background: none;
}

.nav-tree-toggle:hover {
    color: var(--input-text);
}

.nav-tree-toggle.leaf {
    visibility: hidden;
}

.nav-tree-id {
    font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
    font-size: 0.75rem;
    color: var(--primary);
    flex-shrink: 0;
}

.nav-tree-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--secondary-text);
    font-size: 0.75rem;
}

.nav-tree-level {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 2px;
    flex-shrink: 0;
}

.nav-tree-level.prd { background: var(--nav-level-prd-bg); color: var(--nav-level-prd-text); }
.nav-tree-level.ops { background: var(--nav-level-ops-bg); color: var(--nav-level-ops-text); }
.nav-tree-level.dev { background: var(--nav-level-dev-bg); color: var(--nav-level-dev-text); }

/* Test and result rows in nav tree */
.nav-tree-test {
    background: var(--nav-tree-test-bg);
}
.nav-tree-test:hover {
    background: var(--nav-tree-test-hover-bg);
}
.nav-tree-result {
    background: var(--nav-tree-result-bg);
    font-size: 0.75rem;
}
.nav-tree-result:hover {
    background: var(--nav-tree-result-hover-bg);
}
.nav-tree-result.result-passed { border-left-color: var(--result-passed-border); }
.nav-tree-result.result-failed { border-left-color: var(--result-failed-border); }
.nav-tree-result.result-error { border-left-color: var(--result-error-border); }
.nav-tree-result.result-skipped { border-left-color: var(--result-skipped-border); }

.nav-tree-kind-icon {
    flex-shrink: 0;
    font-size: 0.75rem;
    width: 16px;
    text-align: center;
}
.nav-tree-kind-icon.test-icon {
    font-size: 0.8rem;
}

.nav-tree-result-badge {
    font-size: 0.6rem;
    font-weight: 600;
    padding: 1px 4px;
    border-radius: 2px;
    margin-left: auto;
    flex-shrink: 0;
    text-transform: uppercase;
}
.nav-tree-result-badge.passed { background: var(--result-passed-bg); color: var(--result-passed-text); }
.nav-tree-result-badge.failed, .nav-tree-result-badge.fail, .nav-tree-result-badge.failure { background: var(--result-failed-bg); color: var(--result-failed-text); }
.nav-tree-result-badge.error { background: var(--result-error-bg); color: var(--result-error-text); }
.nav-tree-result-badge.skipped, .nav-tree-result-badge.skip { background: var(--result-skipped-bg); color: var(--result-skipped-text); }

/* Tab spacer and tree action buttons */
.nav-tab-spacer { flex: 1; }

.nav-tree-action {
    padding: 6px 8px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.7rem;
    color: var(--muted-text);
    transition: color 0.15s;
}
.nav-tree-action:hover { color: var(--input-text); }
