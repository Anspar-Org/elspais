/* Partial: _coverage.css.j2 — Coverage icons */

.coverage-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
}

.coverage-icon {
    font-size: 1rem;
}

.coverage-icon.none { color: var(--coverage-none); }
.coverage-icon.partial { color: var(--coverage-partial); }
.coverage-icon.full { color: var(--coverage-full); }

.warning-icon {
    color: var(--coverage-warning);
    font-size: 0.875rem;
}
