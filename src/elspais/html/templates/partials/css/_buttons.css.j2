/* Partial: _buttons.css.j2 — Button styles (save/revert/undo) and unsaved badge */

/* Save/Revert/Undo Buttons */
.btn {
    padding: 6px 14px;
    border: 1px solid var(--btn-border);
    background: var(--btn-bg);
    border-radius: 5px;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--btn-text);
    transition: background 0.15s, border-color 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}

.btn:hover {
    background: var(--btn-hover-bg);
}

.btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Undo button: purple when active, clearly distinct from disabled */
#btn-undo:not(:disabled) {
    background: #9b59b6;
    border-color: #8e44ad;
    color: #fff;
}
#btn-undo:not(:disabled):hover {
    background: #8e44ad;
}

.btn-primary {
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    border-color: var(--btn-primary-border);
}

.btn-primary:hover {
    background: var(--btn-primary-hover);
}

.btn-warning {
    background: var(--btn-warning-bg);
    color: var(--btn-warning-text);
    border-color: var(--btn-warning-border);
}

.btn-warning:hover {
    background: var(--btn-warning-hover);
}

.btn-danger {
    color: var(--btn-danger-text);
    border-color: var(--btn-danger-border);
}

.btn-danger:hover {
    background: var(--btn-danger-hover-bg);
    color: var(--btn-danger-hover-text);
}

.unsaved-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    background: var(--unsaved-badge-bg);
    color: var(--unsaved-badge-text);
    border-radius: 10px;
    font-size: 0.7rem;
    font-weight: 700;
}

.unsaved-badge.hidden {
    display: none;
}
