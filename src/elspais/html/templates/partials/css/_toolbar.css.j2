/* Partial: _toolbar.css.j2 — Unified toolbar controls */

/* Layout */
.toolbar {
    background: var(--panel-bg);
    border-bottom: 1px solid var(--border-color);
    padding: 12px 24px;
    display: flex;
    gap: 12px;
    align-items: stretch;
    transition: max-height 0.2s ease, padding 0.2s ease, opacity 0.2s ease;
    max-height: 200px;
    overflow: hidden;
}

.toolbar.toolbar-hidden {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
    border-bottom: none;
}

.toolbar-search {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 220px;
    max-width: 280px;
}

.toolbar-divider {
    border-left: 1px solid var(--border-light);
    align-self: stretch;
}

.toolbar-filters {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
}

.toolbar-row {
    display: flex;
    align-items: center;
    gap: 12px;
}

.filter-group {
    display: flex;
    align-items: center;
    gap: 6px;
}

.filter-group-label {
    color: var(--secondary-text);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
}

.filter-group-buttons {
    display: flex;
    gap: 2px;
}

/* Filter buttons — base (outlined = hidden) */
.filter-btn {
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    border: 1px solid transparent;
    background: transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    user-select: none;
}

.filter-btn:hover { opacity: 0.85; }

/* Unavailable (dimmed) */
.filter-btn.unavailable {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
}

/* Shake animation for last-button protection */
@keyframes filter-btn-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-2px); }
    75% { transform: translateX(2px); }
}
.filter-btn-shake {
    animation: filter-btn-shake 0.3s ease;
}

/* Per-group per-key colors */
/* Git */
.filter-btn[data-group="git"][data-key="unsaved"]     { border-color: #dc3545; color: #dc3545; }
.filter-btn.on[data-group="git"][data-key="unsaved"]   { background: #dc3545; border-color: #dc3545; color: #fff; }
.filter-btn[data-group="git"][data-key="uncommitted"]  { border-color: #0d6efd; color: #0d6efd; }
.filter-btn.on[data-group="git"][data-key="uncommitted"]{ background: #0d6efd; border-color: #0d6efd; color: #fff; }
.filter-btn[data-group="git"][data-key="changed"]      { border-color: #6c757d; color: #6c757d; }
.filter-btn.on[data-group="git"][data-key="changed"]    { background: #6c757d; border-color: #6c757d; color: #fff; }
.filter-btn[data-group="git"][data-key="unchanged"]    { border-color: var(--secondary-text); color: var(--secondary-text); }
.filter-btn.on[data-group="git"][data-key="unchanged"]  { background: var(--secondary-text); border-color: var(--secondary-text); color: #fff; }

/* Status — use existing CSS variables */
.filter-btn[data-group="status"][data-key="draft"]       { border-color: var(--status-draft-text); color: var(--status-draft-text); }
.filter-btn.on[data-group="status"][data-key="draft"]     { background: var(--status-draft-bg); border-color: var(--status-draft-bg); }
.filter-btn[data-group="status"][data-key="active"]      { border-color: var(--status-active-text); color: var(--status-active-text); }
.filter-btn.on[data-group="status"][data-key="active"]    { background: var(--status-active-bg); border-color: var(--status-active-bg); }
.filter-btn[data-group="status"][data-key="deprecated"]  { border-color: var(--status-deprecated-text); color: var(--status-deprecated-text); }
.filter-btn.on[data-group="status"][data-key="deprecated"]{ background: var(--status-deprecated-bg); border-color: var(--status-deprecated-bg); }
.filter-btn[data-group="status"][data-key="proposed"]    { border-color: var(--status-proposed-text); color: var(--status-proposed-text); }
.filter-btn.on[data-group="status"][data-key="proposed"]  { background: var(--status-proposed-bg); border-color: var(--status-proposed-bg); }

/* Hierarchy */
.filter-btn[data-group="hierarchy"]     { border-color: #6f42c1; color: #6f42c1; }
.filter-btn.on[data-group="hierarchy"]   { background: #6f42c1; border-color: #6f42c1; color: #fff; }

/* Coverage */
.filter-btn[data-group="coverage"][data-key="none"]    { border-color: #dc3545; color: #dc3545; }
.filter-btn.on[data-group="coverage"][data-key="none"]  { background: #dc3545; border-color: #dc3545; color: #fff; }
.filter-btn[data-group="coverage"][data-key="partial"] { border-color: #ffc107; color: #ffc107; }
.filter-btn.on[data-group="coverage"][data-key="partial"]{ background: #ffc107; border-color: #ffc107; color: #000; }
.filter-btn[data-group="coverage"][data-key="full"]    { border-color: #198754; color: #198754; }
.filter-btn.on[data-group="coverage"][data-key="full"]  { background: #198754; border-color: #198754; color: #fff; }

/* Toolbar actions (Clear + counter) */
.toolbar-actions {
    display: flex;
    gap: 8px;
    margin-left: auto;
    align-items: center;
}

/* General buttons */
.btn {
    padding: 8px 16px;
    border: 1px solid var(--border-light);
    background: var(--panel-bg);
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--input-text);
    transition: background 0.15s;
}

.btn:hover {
    background: var(--body-bg);
}

.btn-icon {
    padding: 8px 12px;
}

.counter {
    font-size: 0.875rem;
    color: var(--secondary-text);
}

/* Text filter input (now textarea) */
.filter-text-input {
    padding: 6px 10px;
    border: 1px solid var(--border-light);
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--input-text);
    background: var(--panel-bg);
    resize: none;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
}
.filter-text-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.15);
}
.filter-text-input::placeholder {
    color: var(--muted-text);
}

/* Dim context-only rows (ancestors shown for tree structure but not matching the filter) */
.nav-tree-row.filter-dim {
    opacity: 0.35;
}

.nav-tree-row.filter-dim:hover {
    opacity: 0.7;
}

/* Show hidden parents toggle (inline label under search) */
.toggle-inline {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.75rem;
    color: var(--secondary-text);
    cursor: pointer;
}
.toggle-inline input[type="checkbox"] {
    width: 14px;
    height: 14px;
    cursor: pointer;
    accent-color: var(--primary);
}
