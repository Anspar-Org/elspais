/* Partial: _toolbar.css.j2 — Toolbar controls */

.toolbar {
    background: var(--panel-bg);
    border-bottom: 1px solid var(--border-color);
    padding: 12px 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
}

.btn-group {
    display: flex;
    border: 1px solid var(--border-light);
    border-radius: 4px;
    overflow: hidden;
}

.btn-group .btn {
    border: none;
    border-right: 1px solid var(--border-light);
    background: var(--panel-bg);
    padding: 8px 16px;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--input-text);
    transition: background 0.15s;
}

.btn-group .btn:last-child {
    border-right: none;
}

.btn-group .btn:hover {
    background: var(--body-bg);
}

.btn-group .btn.active {
    background: var(--primary);
    color: white;
}

.toggle-group {
    display: flex;
    gap: 16px;
    align-items: center;
}

.toggle-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    color: var(--input-text);
    cursor: pointer;
}

.toggle-item input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
    accent-color: var(--primary);
}

.toolbar-actions {
    display: flex;
    gap: 8px;
    margin-left: auto;
    align-items: center;
}

.btn {
    padding: 8px 16px;
    border: 1px solid var(--border-light);
    background: var(--panel-bg);
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--input-text);
    transition: background 0.15s;
}

.btn:hover {
    background: var(--body-bg);
}

.btn-icon {
    padding: 8px 12px;
}

.counter {
    font-size: 0.875rem;
    color: var(--secondary-text);
}

/* Status filter badge buttons (filled=on/showing, outline=off/hidden) */
.status-filter-group {
    display: flex;
    gap: 6px;
    align-items: center;
}

.status-filter-btn {
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    user-select: none;
    border: 1px solid transparent;
    background: transparent;
}

/* Outline (off/hidden) — status-specific border+text colors */
.status-filter-btn[data-status="draft"]       { border-color: var(--status-draft-text);      color: var(--status-draft-text); }
.status-filter-btn[data-status="active"]      { border-color: var(--status-active-text);     color: var(--status-active-text); }
.status-filter-btn[data-status="deprecated"]  { border-color: var(--status-deprecated-text); color: var(--status-deprecated-text); }
.status-filter-btn[data-status="proposed"]    { border-color: var(--status-proposed-text);   color: var(--status-proposed-text); }

/* Filled (on/showing) — use status badge bg+text colors */
.status-filter-btn.on[data-status="draft"]       { background: var(--status-draft-bg);      border-color: var(--status-draft-bg); }
.status-filter-btn.on[data-status="active"]      { background: var(--status-active-bg);     border-color: var(--status-active-bg); }
.status-filter-btn.on[data-status="deprecated"]  { background: var(--status-deprecated-bg); border-color: var(--status-deprecated-bg); }
.status-filter-btn.on[data-status="proposed"]    { background: var(--status-proposed-bg);   border-color: var(--status-proposed-bg); }

.status-filter-btn:hover { opacity: 0.85; }

/* Filter dropdown (shared by toolbar) */
.filter-select {
    padding: 6px 8px;
    border: 1px solid var(--border-light);
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--input-text);
    background: var(--panel-bg);
    cursor: pointer;
}

/* Text filter input */
.filter-text-input {
    padding: 6px 10px;
    border: 1px solid var(--border-light);
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--input-text);
    background: var(--panel-bg);
    min-width: 180px;
    flex: 1;
    max-width: 320px;
}
.filter-text-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.15);
}
.filter-text-input::placeholder {
    color: var(--muted-text);
}

/* Dim context-only rows (ancestors shown for tree structure but not matching the filter) */
.nav-tree-row.filter-dim {
    opacity: 0.35;
}

.nav-tree-row.filter-dim:hover {
    opacity: 0.7;
}

/* Hideable toolbar */
.toolbar {
    transition: max-height 0.2s ease, padding 0.2s ease, opacity 0.2s ease;
    max-height: 100px;
    overflow: hidden;
}
.toolbar.toolbar-hidden {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
    border-bottom: none;
}
