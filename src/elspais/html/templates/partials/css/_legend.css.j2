/* Partial: _legend.css.j2 — Legend modal */

.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
}

.modal-overlay.visible {
    opacity: 1;
    visibility: visible;
}

.modal {
    background: var(--modal-bg);
    border-radius: 8px;
    padding: 24px;
    max-width: 500px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}

.modal-title {
    font-size: 1.25rem;
    font-weight: 600;
}

.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--modal-close);
    padding: 0;
    line-height: 1;
}

.modal-close:hover {
    color: var(--modal-close-hover);
}

.legend-section {
    margin-bottom: 20px;
}

.legend-section h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--legend-section-title);
    margin-bottom: 8px;
    border-bottom: 1px solid var(--legend-section-border);
    padding-bottom: 4px;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 0;
    font-size: 0.875rem;
}

.legend-icon {
    width: 24px;
    text-align: center;
    flex-shrink: 0;
}

/* Override nav-tree badge alignment inside legend */
.legend-item .nav-tree-result-badge {
    margin-left: 0;
}

/* Validation tier color swatch */
.legend-swatch {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    flex-shrink: 0;
}
.legend-swatch.val-green { background: var(--val-green-bg); }
.legend-swatch.val-yellow-green { background: var(--val-yellow-green-bg); }
.legend-swatch.val-yellow { background: var(--val-yellow-bg); }
.legend-swatch.val-red { background: var(--val-red-bg); }
.legend-swatch.val-orange { background: var(--val-orange-bg); }
