{
  "$defs": {
    "AssertionConfig": {
      "additionalProperties": false,
      "properties": {
        "label_style": {
          "default": "uppercase",
          "title": "Label Style",
          "type": "string"
        },
        "max_count": {
          "default": 26,
          "title": "Max Count",
          "type": "integer"
        },
        "zero_pad": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Zero Pad"
        },
        "multi_separator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Multi Separator"
        }
      },
      "title": "AssertionConfig",
      "type": "object"
    },
    "AssociateEntryConfig": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "namespace": {
          "title": "Namespace",
          "type": "string"
        }
      },
      "required": [
        "path",
        "namespace"
      ],
      "title": "AssociateEntryConfig",
      "type": "object"
    },
    "ChangelogConfig": {
      "additionalProperties": false,
      "properties": {
        "hash_current": {
          "default": true,
          "title": "Hash Current",
          "type": "boolean"
        },
        "present": {
          "default": false,
          "title": "Present",
          "type": "boolean"
        },
        "id_source": {
          "default": "gh",
          "title": "Id Source",
          "type": "string"
        },
        "date_format": {
          "default": "iso",
          "title": "Date Format",
          "type": "string"
        },
        "author_id_format": {
          "default": "email",
          "title": "Author Id Format",
          "type": "string"
        },
        "allowed_author_ids": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "default": "all",
          "title": "Allowed Author Ids"
        },
        "require": {
          "$ref": "#/$defs/ChangelogRequireConfig"
        }
      },
      "title": "ChangelogConfig",
      "type": "object"
    },
    "ChangelogRequireConfig": {
      "additionalProperties": false,
      "properties": {
        "reason": {
          "default": true,
          "title": "Reason",
          "type": "boolean"
        },
        "author_name": {
          "default": true,
          "title": "Author Name",
          "type": "boolean"
        },
        "author_id": {
          "default": true,
          "title": "Author Id",
          "type": "boolean"
        },
        "change_order": {
          "default": false,
          "title": "Change Order",
          "type": "boolean"
        }
      },
      "title": "ChangelogRequireConfig",
      "type": "object"
    },
    "CodeScanningConfig": {
      "additionalProperties": false,
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "file_patterns": {
          "items": {
            "type": "string"
          },
          "title": "File Patterns",
          "type": "array"
        },
        "skip_files": {
          "items": {
            "type": "string"
          },
          "title": "Skip Files",
          "type": "array"
        },
        "skip_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Skip Dirs",
          "type": "array"
        },
        "source_roots": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Roots"
        }
      },
      "title": "CodeScanningConfig",
      "type": "object"
    },
    "ComponentConfig": {
      "additionalProperties": false,
      "properties": {
        "style": {
          "default": "numeric",
          "title": "Style",
          "type": "string"
        },
        "digits": {
          "default": 5,
          "title": "Digits",
          "type": "integer"
        },
        "leading_zeros": {
          "default": true,
          "title": "Leading Zeros",
          "type": "boolean"
        },
        "pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pattern"
        },
        "max_length": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Length"
        }
      },
      "title": "ComponentConfig",
      "type": "object"
    },
    "CoverageConfig": {
      "additionalProperties": false,
      "description": "Coverage severity configuration for all 5 dimensions.",
      "properties": {
        "implemented": {
          "$ref": "#/$defs/CoverageSeverityConfig"
        },
        "tested": {
          "$ref": "#/$defs/CoverageSeverityConfig"
        },
        "verified": {
          "$ref": "#/$defs/CoverageSeverityConfig"
        },
        "uat_coverage": {
          "$ref": "#/$defs/CoverageSeverityConfig"
        },
        "uat_verified": {
          "$ref": "#/$defs/CoverageSeverityConfig"
        }
      },
      "title": "CoverageConfig",
      "type": "object"
    },
    "CoverageScanningConfig": {
      "additionalProperties": false,
      "description": "Configuration for code coverage report scanning.",
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "file_patterns": {
          "items": {
            "type": "string"
          },
          "title": "File Patterns",
          "type": "array"
        },
        "skip_files": {
          "items": {
            "type": "string"
          },
          "title": "Skip Files",
          "type": "array"
        },
        "skip_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Skip Dirs",
          "type": "array"
        }
      },
      "title": "CoverageScanningConfig",
      "type": "object"
    },
    "CoverageSeverityConfig": {
      "additionalProperties": false,
      "description": "Severity mapping for a single coverage dimension's tier states.\n\nEach tier maps to a severity: 'ok', 'info', 'warning', or 'error'.",
      "properties": {
        "full_direct": {
          "default": "ok",
          "title": "Full Direct",
          "type": "string"
        },
        "full_indirect": {
          "default": "info",
          "title": "Full Indirect",
          "type": "string"
        },
        "partial": {
          "default": "warning",
          "title": "Partial",
          "type": "string"
        },
        "none": {
          "default": "error",
          "title": "None",
          "type": "string"
        },
        "failing": {
          "default": "error",
          "title": "Failing",
          "type": "string"
        }
      },
      "title": "CoverageSeverityConfig",
      "type": "object"
    },
    "DocsScanningConfig": {
      "additionalProperties": false,
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "file_patterns": {
          "items": {
            "type": "string"
          },
          "title": "File Patterns",
          "type": "array"
        },
        "skip_files": {
          "items": {
            "type": "string"
          },
          "title": "Skip Files",
          "type": "array"
        },
        "skip_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Skip Dirs",
          "type": "array"
        }
      },
      "title": "DocsScanningConfig",
      "type": "object"
    },
    "FormatConfig": {
      "additionalProperties": false,
      "properties": {
        "require_hash": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Require Hash"
        },
        "require_assertions": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Require Assertions"
        },
        "require_status": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Require Status"
        },
        "require_rationale": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Require Rationale"
        },
        "allowed_statuses": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allowed Statuses"
        },
        "status_roles": {
          "anyOf": [
            {
              "additionalProperties": {
                "anyOf": [
                  {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status Roles"
        },
        "no_assertions_severity": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "No Assertions Severity"
        }
      },
      "title": "FormatConfig",
      "type": "object"
    },
    "HierarchyConfig": {
      "additionalProperties": false,
      "properties": {
        "cross_repo_implements": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cross Repo Implements"
        },
        "allow_structural_orphans": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allow Structural Orphans"
        },
        "allow_circular": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allow Circular"
        },
        "allow_orphans": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allow Orphans"
        }
      },
      "title": "HierarchyConfig",
      "type": "object"
    },
    "IdPatternsConfig": {
      "additionalProperties": false,
      "properties": {
        "canonical": {
          "default": "{namespace}-{level.letter}{component}",
          "title": "Canonical",
          "type": "string"
        },
        "aliases": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "object"
        },
        "component": {
          "$ref": "#/$defs/ComponentConfig"
        },
        "assertions": {
          "$ref": "#/$defs/AssertionConfig"
        },
        "separators": {
          "items": {
            "type": "string"
          },
          "title": "Separators",
          "type": "array"
        },
        "prefix_optional": {
          "default": false,
          "title": "Prefix Optional",
          "type": "boolean"
        }
      },
      "title": "IdPatternsConfig",
      "type": "object"
    },
    "JourneyScanningConfig": {
      "additionalProperties": false,
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "file_patterns": {
          "items": {
            "type": "string"
          },
          "title": "File Patterns",
          "type": "array"
        },
        "skip_files": {
          "items": {
            "type": "string"
          },
          "title": "Skip Files",
          "type": "array"
        },
        "skip_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Skip Dirs",
          "type": "array"
        }
      },
      "title": "JourneyScanningConfig",
      "type": "object"
    },
    "KeywordsSearchConfig": {
      "additionalProperties": false,
      "properties": {
        "min_length": {
          "default": 3,
          "title": "Min Length",
          "type": "integer"
        }
      },
      "title": "KeywordsSearchConfig",
      "type": "object"
    },
    "LevelConfig": {
      "additionalProperties": false,
      "properties": {
        "rank": {
          "title": "Rank",
          "type": "integer"
        },
        "letter": {
          "title": "Letter",
          "type": "string"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "implements": {
          "items": {
            "type": "string"
          },
          "title": "Implements",
          "type": "array"
        }
      },
      "required": [
        "rank",
        "letter",
        "implements"
      ],
      "title": "LevelConfig",
      "type": "object"
    },
    "OutputConfig": {
      "additionalProperties": false,
      "properties": {
        "formats": {
          "items": {
            "type": "string"
          },
          "title": "Formats",
          "type": "array"
        },
        "dir": {
          "default": "",
          "title": "Dir",
          "type": "string"
        }
      },
      "title": "OutputConfig",
      "type": "object"
    },
    "ProjectConfig": {
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "default": "REQ",
          "title": "Namespace",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        }
      },
      "title": "ProjectConfig",
      "type": "object"
    },
    "ResultScanningConfig": {
      "additionalProperties": false,
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "file_patterns": {
          "items": {
            "type": "string"
          },
          "title": "File Patterns",
          "type": "array"
        },
        "skip_files": {
          "items": {
            "type": "string"
          },
          "title": "Skip Files",
          "type": "array"
        },
        "skip_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Skip Dirs",
          "type": "array"
        },
        "run_meta_file": {
          "default": "",
          "title": "Run Meta File",
          "type": "string"
        }
      },
      "title": "ResultScanningConfig",
      "type": "object"
    },
    "RulesConfig": {
      "additionalProperties": false,
      "properties": {
        "hierarchy": {
          "$ref": "#/$defs/HierarchyConfig"
        },
        "format": {
          "$ref": "#/$defs/FormatConfig"
        },
        "coverage": {
          "$ref": "#/$defs/CoverageConfig"
        },
        "content_rules": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Rules"
        }
      },
      "title": "RulesConfig",
      "type": "object"
    },
    "ScanningConfig": {
      "additionalProperties": false,
      "properties": {
        "skip": {
          "items": {
            "type": "string"
          },
          "title": "Skip",
          "type": "array"
        },
        "spec": {
          "$ref": "#/$defs/SpecScanningConfig"
        },
        "code": {
          "$ref": "#/$defs/CodeScanningConfig"
        },
        "test": {
          "$ref": "#/$defs/TestScanningConfig"
        },
        "result": {
          "$ref": "#/$defs/ResultScanningConfig"
        },
        "coverage": {
          "$ref": "#/$defs/CoverageScanningConfig"
        },
        "journey": {
          "$ref": "#/$defs/JourneyScanningConfig"
        },
        "docs": {
          "$ref": "#/$defs/DocsScanningConfig"
        }
      },
      "title": "ScanningConfig",
      "type": "object"
    },
    "SpecScanningConfig": {
      "additionalProperties": false,
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "file_patterns": {
          "items": {
            "type": "string"
          },
          "title": "File Patterns",
          "type": "array"
        },
        "skip_files": {
          "items": {
            "type": "string"
          },
          "title": "Skip Files",
          "type": "array"
        },
        "skip_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Skip Dirs",
          "type": "array"
        },
        "index_file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Index File"
        }
      },
      "title": "SpecScanningConfig",
      "type": "object"
    },
    "TestScanningConfig": {
      "additionalProperties": false,
      "properties": {
        "directories": {
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "file_patterns": {
          "items": {
            "type": "string"
          },
          "title": "File Patterns",
          "type": "array"
        },
        "skip_files": {
          "items": {
            "type": "string"
          },
          "title": "Skip Files",
          "type": "array"
        },
        "skip_dirs": {
          "items": {
            "type": "string"
          },
          "title": "Skip Dirs",
          "type": "array"
        },
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "prescan_command": {
          "default": "",
          "title": "Prescan Command",
          "type": "string"
        },
        "reference_keyword": {
          "default": "Verifies",
          "title": "Reference Keyword",
          "type": "string"
        },
        "reference_patterns": {
          "items": {
            "type": "string"
          },
          "title": "Reference Patterns",
          "type": "array"
        }
      },
      "title": "TestScanningConfig",
      "type": "object"
    },
    "ValidationConfig": {
      "additionalProperties": false,
      "properties": {
        "hash_mode": {
          "default": "normalized-text",
          "title": "Hash Mode",
          "type": "string"
        },
        "hash_algorithm": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hash Algorithm"
        },
        "hash_length": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hash Length"
        },
        "allow_unresolved_cross_repo": {
          "default": false,
          "title": "Allow Unresolved Cross Repo",
          "type": "boolean"
        },
        "strict_hierarchy": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strict Hierarchy"
        }
      },
      "title": "ValidationConfig",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "version": {
      "default": 3,
      "title": "Version",
      "type": "integer"
    },
    "project": {
      "$ref": "#/$defs/ProjectConfig"
    },
    "id-patterns": {
      "$ref": "#/$defs/IdPatternsConfig"
    },
    "levels": {
      "additionalProperties": {
        "$ref": "#/$defs/LevelConfig"
      },
      "title": "Levels",
      "type": "object"
    },
    "scanning": {
      "$ref": "#/$defs/ScanningConfig"
    },
    "rules": {
      "$ref": "#/$defs/RulesConfig"
    },
    "keywords": {
      "$ref": "#/$defs/KeywordsSearchConfig"
    },
    "validation": {
      "$ref": "#/$defs/ValidationConfig"
    },
    "changelog": {
      "$ref": "#/$defs/ChangelogConfig"
    },
    "output": {
      "$ref": "#/$defs/OutputConfig"
    },
    "associates": {
      "additionalProperties": {
        "$ref": "#/$defs/AssociateEntryConfig"
      },
      "title": "Associates",
      "type": "object"
    },
    "stats": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "File path for MCP tool usage statistics",
      "title": "Stats"
    },
    "cli_ttl": {
      "default": 30,
      "description": "CLI daemon TTL in minutes (>0=auto-start, 0=disabled, <0=no timeout)",
      "title": "Cli Ttl",
      "type": "integer"
    }
  },
  "title": "ElspaisConfig",
  "type": "object"
}
