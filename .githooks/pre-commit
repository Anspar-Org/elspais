#!/bin/bash
# =====================================================
# Pre-Commit Hook: elspais
# =====================================================
#
# Validates code quality before commits:
#   - Branch protection (blocks commits to main/master)
#   - Unstaged src/tests changes (prevents partial commits)
#   - Python code quality (ruff + black)
#   - Markdown linting (markdownlint)
#   - Unit/integration tests with coverage
#   - elspais fix (regenerate INDEX.md, KNOWN_ISSUES.md)
#
# To install this hook:
#   make setup   (or: git config core.hooksPath .githooks)
#
# To bypass (NOT RECOMMENDED):
#   git commit --no-verify
#
# =====================================================

set -e

# Git sets GIT_DIR when invoking hooks — this causes subprocess git
# commands in tests to silently operate on this repo instead of their
# temp directories.  Unset it so pytest child processes get a clean env.
unset GIT_DIR
unset GIT_WORK_TREE
unset GIT_INDEX_FILE
unset GIT_AUTHOR_NAME
unset GIT_AUTHOR_EMAIL
unset GIT_AUTHOR_DATE
unset GIT_COMMITTER_NAME
unset GIT_COMMITTER_EMAIL
unset GIT_COMMITTER_DATE

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# =====================================================
# 1. Branch Protection - Block Commits to Main
# =====================================================

CURRENT_BRANCH=$(git branch --show-current)

if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ]; then
    echo -e "${RED}ERROR: Direct commits to '$CURRENT_BRANCH' branch are not allowed!${NC}"
    echo ""
    echo "This repository enforces a feature branch workflow."
    echo "All changes must go through pull requests."
    echo ""
    echo "To fix this:"
    echo "  1. Create a feature branch: git checkout -b fix/your-fix-name"
    echo "  2. Commit your changes to the feature branch"
    echo "  3. Push and create a pull request"
    echo ""
    exit 1
fi

# =====================================================
# 2. Unstaged Changes in src/ or tests/
# =====================================================

UNSTAGED_SRC_TESTS=$(git diff --name-only -- src/ tests/ 2>/dev/null || true)

if [ -n "$UNSTAGED_SRC_TESTS" ]; then
    echo -e "${RED}ERROR: Unstaged changes detected in src/ or tests/:${NC}"
    echo "$UNSTAGED_SRC_TESTS" | sed 's/^/  /'
    echo ""
    echo "Stage them (git add) or stash them (git stash -k) before committing."
    exit 1
fi

# =====================================================
# 3. Python Code Quality (ruff + black)
# =====================================================

PYTHON_FILES_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$PYTHON_FILES_CHANGED" ]; then
    echo -e "${BLUE}Checking Python code quality...${NC}"
    echo ""

    PYTHON_FAILED=false

    # Run ruff if available
    if command -v ruff &> /dev/null; then
        echo "  Running ruff check..."
        if ! echo "$PYTHON_FILES_CHANGED" | xargs ruff check 2>&1; then
            PYTHON_FAILED=true
            echo -e "${RED}  ruff check failed${NC}"
        else
            echo -e "${GREEN}  ruff check passed${NC}"
        fi
    else
        echo -e "${YELLOW}  WARNING: ruff not installed - skipping${NC}"
    fi

    # Run black if available
    if command -v black &> /dev/null; then
        echo "  Running black check..."
        if ! echo "$PYTHON_FILES_CHANGED" | xargs black --check --quiet 2>&1; then
            echo -e "${YELLOW}  Files need formatting. Applying fixes...${NC}"
            echo "$PYTHON_FILES_CHANGED" | xargs black
            # Re-stage formatted files
            echo "$PYTHON_FILES_CHANGED" | xargs git add
            echo -e "${GREEN}  Formatted files have been staged${NC}"
        else
            echo -e "${GREEN}  black check passed${NC}"
        fi
    else
        echo -e "${YELLOW}  WARNING: black not installed - skipping${NC}"
    fi

    if [ "$PYTHON_FAILED" = true ]; then
        echo ""
        echo -e "${RED}Python code quality checks failed!${NC}"
        echo "Fix the errors above before committing."
        echo ""
        echo "To bypass this check (NOT RECOMMENDED):"
        echo "  git commit --no-verify"
        exit 1
    fi

    echo ""
fi

# =====================================================
# 4. Markdown Linting
# =====================================================

MARKDOWN_FILES_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -n "$MARKDOWN_FILES_CHANGED" ]; then
    echo -e "${BLUE}Linting markdown files...${NC}"
    echo ""

    if command -v markdownlint &> /dev/null; then
        # Check if config exists
        MDLINT_CONFIG=""
        if [ -f ".markdownlint.json" ]; then
            MDLINT_CONFIG="--config .markdownlint.json"
        fi

        if ! echo "$MARKDOWN_FILES_CHANGED" | xargs markdownlint $MDLINT_CONFIG 2>&1; then
            echo ""
            echo -e "${RED}Markdown linting failed!${NC}"
            echo "Fix the errors above before committing."
            echo ""
            echo "To bypass this check (NOT RECOMMENDED):"
            echo "  git commit --no-verify"
            exit 1
        fi

        echo -e "${GREEN}Markdown linting passed!${NC}"
        echo ""
    else
        echo -e "${YELLOW}WARNING: markdownlint not installed - skipping${NC}"
        echo "  Install: npm install -g markdownlint-cli"
        echo ""
    fi
fi

# =====================================================
# 5. Unit/Integration Tests with Coverage (cached)
# =====================================================

REPO_ROOT=$(git rev-parse --show-toplevel)
CACHE_DIR="$REPO_ROOT/.results"
UNIT_CACHE="$CACHE_DIR/.test-cache-unit"

mkdir -p "$CACHE_DIR"

# Compute content hash from HEAD tree (committed state after this commit)
# Uses staged index which reflects what the commit will contain
CONTENT_HASH=$(git write-tree 2>/dev/null | head -c 40)

if [ -f "$UNIT_CACHE" ] && [ "$(cat "$UNIT_CACHE" 2>/dev/null)" = "$CONTENT_HASH" ]; then
    echo -e "${GREEN}Tests cached — no changes since last pass${NC}"
    echo ""
else
    echo -e "${BLUE}Running unit/integration tests with coverage...${NC}"
    echo ""

    if ! pytest tests/ --tb=short -q \
        --cov=src/elspais --cov-context=test --cov-report=json:"$CACHE_DIR/coverage.json" --cov-report= 2>&1; then
        echo ""
        echo -e "${RED}Tests failed!${NC}"
        echo "Fix the errors above before committing."
        echo ""
        echo "To bypass this check (NOT RECOMMENDED):"
        echo "  git commit --no-verify"
        rm -f "$UNIT_CACHE"
        exit 1
    fi

    echo -e "${GREEN}Tests passed!${NC}"
    echo "$CONTENT_HASH" > "$UNIT_CACHE"
    echo ""
fi

# =====================================================
# 6. elspais fix (regenerate INDEX.md, KNOWN_ISSUES.md)
# =====================================================

if command -v elspais &> /dev/null; then
    echo -e "${BLUE}Running elspais fix...${NC}"
    if elspais fix 2>&1; then
        # Stage any regenerated files
        git add -u spec/INDEX.md KNOWN_ISSUES.md 2>/dev/null || true
        echo -e "${GREEN}elspais fix passed${NC}"
    else
        echo -e "${RED}elspais fix failed!${NC}"
        exit 1
    fi
    echo ""
else
    echo -e "${YELLOW}WARNING: elspais not installed - skipping fix${NC}"
    echo ""
fi

# =====================================================
# 7. All Validations Passed
# =====================================================

echo -e "${GREEN}Pre-commit checks passed!${NC}"
exit 0
