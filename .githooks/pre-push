#!/bin/bash
# =====================================================
# Pre-Push Hook: elspais
# =====================================================
#
# Runs ONLY checks that pre-commit doesn't already cover:
#   1. Branch freshness (must be rebased on origin/main)
#   2. Version bump (auto-bumps if same as main)
#   3. E2E tests (cached)
#   4. Secret detection (gitleaks)
#   5. Documentation sync tests
#
# Pre-commit already handles: lint, black, markdown, unit tests,
# elspais fix, commit message format.
#
# PR-aware blocking:
#   - PR/feature branch: failures BLOCK the push
#   - Other branches: failures show warnings only
#
# To install: make setup
# To bypass (NOT RECOMMENDED): git push --no-verify
#
# =====================================================

set -e

# Clean git env for subprocess isolation
unset GIT_DIR
unset GIT_WORK_TREE

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

CURRENT_BRANCH=$(git branch --show-current)

# Skip for main/master (only receives validated PRs)
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ]; then
    echo -e "${BLUE}Skipping pre-push validation for protected branch '$CURRENT_BRANCH'${NC}"
    exit 0
fi

# =====================================================
# 1. Branch Freshness & Version Bump
# =====================================================

git fetch origin main --quiet 2>/dev/null || true

if git rev-parse origin/main >/dev/null 2>&1; then
    BEHIND_COUNT=$(git rev-list --count HEAD..origin/main)
    if [ "$BEHIND_COUNT" -gt 0 ]; then
        echo ""
        echo -e "${RED}======================================${NC}"
        echo -e "${RED}  Branch is $BEHIND_COUNT commit(s) behind origin/main${NC}"
        echo -e "${RED}======================================${NC}"
        echo ""
        echo "Please rebase before pushing:"
        echo "  git pull --rebase origin main"
        echo ""
        exit 1
    fi

    # Auto-bump version if same as main
    MAIN_VERSION=$(git show origin/main:pyproject.toml | grep '^version' | head -1 | sed 's/.*"\(.*\)"/\1/')
    BRANCH_VERSION=$(grep '^version' pyproject.toml | head -1 | sed 's/.*"\(.*\)"/\1/')

    if [ "$MAIN_VERSION" = "$BRANCH_VERSION" ]; then
        CHANGED_FILES=$(git diff --name-only origin/main...HEAD)

        PATCH_ONLY=true
        while IFS= read -r file; do
            [ -z "$file" ] && continue
            case "$file" in
                docs/*|tests/*|spec/*|*.md|.gitignore|.github/workflows/*)
                    ;; # patch-level
                *)
                    PATCH_ONLY=false
                    break
                    ;;
            esac
        done <<< "$CHANGED_FILES"

        IFS='.' read -r MAJOR MINOR PATCH <<< "$MAIN_VERSION"

        if [ "$PATCH_ONLY" = "true" ]; then
            PATCH=$((PATCH + 1))
        else
            MINOR=$((MINOR + 1))
            PATCH=0
        fi

        NEW_VERSION="${MAJOR}.${MINOR}.${PATCH}"

        sed "s/^version = \"${MAIN_VERSION}\"/version = \"${NEW_VERSION}\"/" pyproject.toml > pyproject.toml.tmp && mv pyproject.toml.tmp pyproject.toml
        git add pyproject.toml
        git commit --no-verify -m "chore: auto-bump version to ${NEW_VERSION}"

        echo ""
        echo -e "${GREEN}Auto-bumped version to ${NEW_VERSION}.${NC}"
        echo -e "${YELLOW}Push again to include the bump.${NC}"
        echo ""
        exit 1
    fi
fi

# =====================================================
# 2. PR Detection
# =====================================================

HAS_PR=false
IS_PR_INTENDED_BRANCH=false
SHOULD_BLOCK=false

if [[ "$CURRENT_BRANCH" == feature/* ]] || \
   [[ "$CURRENT_BRANCH" == fix/* ]] || \
   [[ "$CURRENT_BRANCH" == release/* ]]; then
    IS_PR_INTENDED_BRANCH=true
    SHOULD_BLOCK=true
fi

if command -v gh &> /dev/null; then
    if PR_INFO=$(gh pr view "$CURRENT_BRANCH" --json url,state 2>/dev/null); then
        PR_STATE=$(echo "$PR_INFO" | jq -r '.state' 2>/dev/null)
        if [ "$PR_STATE" = "OPEN" ]; then
            HAS_PR=true
            SHOULD_BLOCK=true
        fi
    fi
fi

echo ""
echo -e "${BLUE}======================================${NC}"
echo -e "${BLUE}  elspais Pre-Push Validation${NC}"
echo -e "${BLUE}======================================${NC}"
echo ""

if [ "$SHOULD_BLOCK" = true ]; then
    echo -e "${RED}Validation failures will BLOCK this push.${NC}"
else
    echo -e "${YELLOW}Branch '$CURRENT_BRANCH' has no open PR.${NC}"
    echo -e "${YELLOW}Validation failures will show warnings only.${NC}"
fi
echo ""

VALIDATION_FAILED=false
REPO_ROOT=$(git rev-parse --show-toplevel)

# =====================================================
# 3. E2E Tests (cached)
# =====================================================

CACHE_DIR="$REPO_ROOT/.results"
E2E_CACHE="$CACHE_DIR/.test-cache-e2e"
CONTENT_HASH=$(git write-tree 2>/dev/null | head -c 40)

mkdir -p "$CACHE_DIR"

if [ -f "$E2E_CACHE" ] && [ "$(cat "$E2E_CACHE" 2>/dev/null)" = "$CONTENT_HASH" ]; then
    echo -e "${GREEN}E2E tests cached — passed since last change${NC}"
else
    echo -e "${BLUE}Running e2e tests...${NC}"
    echo ""

    if ! pytest tests/ -m "e2e" --tb=short -q \
        --junitxml="$CACHE_DIR/test-results-e2e.xml" 2>&1; then
        VALIDATION_FAILED=true
        rm -f "$E2E_CACHE"
        echo -e "${RED}E2E tests failed!${NC}"
    else
        echo -e "${GREEN}E2E tests passed!${NC}"
        echo "$CONTENT_HASH" > "$E2E_CACHE"
    fi
fi
echo ""

# Pretty-print JUnit XML for elspais line-level linking
for xml_file in "$CACHE_DIR"/test-results*.xml; do
    [ -f "$xml_file" ] || continue
    python3 -c "
import xml.etree.ElementTree as ET, sys
try:
    tree = ET.parse('$xml_file')
    ET.indent(tree, space='  ')
    tree.write('$xml_file', encoding='unicode', xml_declaration=True)
except Exception:
    sys.exit(0)
" 2>/dev/null || true
done

# =====================================================
# 4. Secret Detection
# =====================================================

echo -e "${BLUE}Running secret detection...${NC}"
echo ""

if command -v gitleaks &> /dev/null; then
    REMOTE_BRANCH=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")
    if [ -n "$REMOTE_BRANCH" ]; then
        if ! gitleaks detect --source="$REPO_ROOT" --log-opts="$REMOTE_BRANCH..HEAD" --no-banner --redact 2>&1; then
            VALIDATION_FAILED=true
            echo -e "${RED}Gitleaks detected secrets!${NC}"
        else
            echo -e "${GREEN}No secrets detected!${NC}"
        fi
    else
        if ! gitleaks detect --source="$REPO_ROOT" --no-banner --redact 2>&1; then
            VALIDATION_FAILED=true
            echo -e "${RED}Gitleaks detected secrets!${NC}"
        else
            echo -e "${GREEN}No secrets detected!${NC}"
        fi
    fi
else
    echo -e "${YELLOW}WARNING: gitleaks not installed - skipping${NC}"
fi
echo ""

# =====================================================
# 5. Documentation Sync Tests
# =====================================================

echo -e "${BLUE}Running documentation sync tests...${NC}"
echo ""

if ! pytest tests/test_doc_sync.py -v --tb=short 2>&1; then
    VALIDATION_FAILED=true
    echo -e "${RED}Documentation sync tests failed!${NC}"
else
    echo -e "${GREEN}Documentation sync tests passed!${NC}"
fi
echo ""

# =====================================================
# 6. Results
# =====================================================

echo -e "${BLUE}======================================${NC}"
echo -e "${BLUE}  Validation Summary${NC}"
echo -e "${BLUE}======================================${NC}"
echo ""

if [ "$VALIDATION_FAILED" = true ]; then
    if [ "$SHOULD_BLOCK" = true ]; then
        echo -e "${RED}VALIDATION FAILED — push BLOCKED${NC}"
        echo ""
        echo "To bypass (NOT RECOMMENDED): git push --no-verify"
        exit 1
    else
        echo -e "${YELLOW}VALIDATION FAILED (warnings only — no open PR)${NC}"
        exit 0
    fi
else
    echo -e "${GREEN}ALL VALIDATIONS PASSED${NC}"
    exit 0
fi
